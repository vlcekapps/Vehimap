[Setup]
AppId={{APP_ID}}
AppName={{APP_NAME}}
AppVersion={{APP_VERSION}}
AppPublisher=vlcekapps
AppPublisherURL=https://github.com/vlcekapps/Vehimap
AppSupportURL=https://github.com/vlcekapps/Vehimap/issues
AppUpdatesURL=https://github.com/vlcekapps/Vehimap/releases
DefaultDirName={localappdata}\Programs\{{INSTALL_FOLDER}}
DefaultGroupName={{APP_NAME}}
DisableProgramGroupPage=yes
PrivilegesRequired=lowest
OutputDir={{OUTPUT_DIR}}
OutputBaseFilename={{OUTPUT_BASE_FILENAME}}
Compression=lzma2
SolidCompression=yes
WizardStyle=modern
SetupIconFile={{SOURCE_DIR}}\Vehimap.ico
UninstallDisplayIcon={app}\Vehimap.ico
SetupLogging=yes
ArchitecturesAllowed=x64compatible
ArchitecturesInstallIn64BitMode=x64compatible
CloseApplications=yes
RestartApplications=no
{{SIGNING_DIRECTIVES}}

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"
Name: "czech"; MessagesFile: "compiler:Languages\Czech.isl"

[CustomMessages]
english.DesktopIconTask=Create a desktop shortcut
czech.DesktopIconTask=Vytvořit zástupce na ploše
english.ShortcutsGroup=Shortcuts:
czech.ShortcutsGroup=Zástupci:
english.LaunchApp=Launch {{APP_NAME}}
czech.LaunchApp=Spustit {{APP_NAME}}

[Tasks]
Name: "desktopicon"; Description: "{cm:DesktopIconTask}"; GroupDescription: "{cm:ShortcutsGroup}"; Flags: unchecked

[Files]
Source: "{{SOURCE_DIR}}\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs; Excludes: "data\*"

[Icons]
Name: "{group}\{{APP_NAME}}"; Filename: "{app}\Vehimap.Desktop.exe"; IconFilename: "{app}\Vehimap.ico"
Name: "{userdesktop}\{{APP_NAME}}"; Filename: "{app}\Vehimap.Desktop.exe"; IconFilename: "{app}\Vehimap.ico"; Tasks: desktopicon

[Run]
Filename: "{app}\Vehimap.Desktop.exe"; Description: "{cm:LaunchApp}"; Flags: nowait postinstall skipifsilent

[Code]
function GetInstallerSeedJson(): String;
begin
  if ActiveLanguage = 'czech' then
  begin
    Result := '{"language":"cs-CZ"}';
  end
  else
  begin
    Result := '{"language":"en-US"}';
  end;
end;

procedure CurStepChanged(CurStep: TSetupStep);
var
  SeedDirectory: String;
  SeedPath: String;
begin
  if CurStep = ssPostInstall then
  begin
    SeedDirectory := ExpandConstant('{userappdata}\{{DATA_FOLDER}}');
    if ForceDirectories(SeedDirectory) then
    begin
      SeedPath := SeedDirectory + '\installer-preferences.json';
      SaveStringToFile(SeedPath, GetInstallerSeedJson(), False);
    end;
  end;
end;
