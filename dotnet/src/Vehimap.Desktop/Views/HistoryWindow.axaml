<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.HistoryWindow"
        x:DataType="vm:HistoryWorkspaceViewModel"
        Width="1320"
        Height="780"
        MinWidth="1080"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="Historie vozidla"
        AutomationProperties.AutomationId="HistoryWindow"
        AutomationProperties.HelpText="Samostatné okno pro práci s historií vybraného vozidla.">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}" />
        <TextBlock Opacity="0.78"
                   Text="{Binding HistorySummary}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              x:Name="CloseHistoryWindowButton"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="Zavřít"
              AutomationProperties.Name="Zavřít okno historie"
              AutomationProperties.AutomationId="CloseHistoryWindowButton" />
    </Grid>

    <workspaces:HistoryWorkspaceView x:Name="HistoryWorkspaceHost"
                                     Grid.Row="1"
                                     Margin="0,18,0,0" />
  </Grid>
</Window>
