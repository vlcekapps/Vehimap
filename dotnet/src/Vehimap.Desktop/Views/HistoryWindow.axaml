<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.HistoryWindow"
        x:DataType="vm:HistoryWorkspaceViewModel"
        Width="1320"
        Height="780"
        MinWidth="1080"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="{i18n:Loc WorkspaceWindow.HistoryName}"
        AutomationProperties.AutomationId="HistoryWindow"
        AutomationProperties.HelpText="{i18n:Loc WorkspaceWindow.HistoryHelpText}">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}"
                   AutomationProperties.Name="{Binding WindowTitle}"
                   AutomationProperties.AutomationId="HistoryWindowHeadingText"
                   AutomationProperties.HeadingLevel="1" />
        <TextBlock Opacity="0.78"
                   Text="{Binding HistorySummary}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              x:Name="CloseHistoryWindowButton"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="{i18n:Loc Common.Close}"
              AutomationProperties.Name="{i18n:Loc WorkspaceWindow.CloseHistoryName}"
              AutomationProperties.AutomationId="CloseHistoryWindowButton" />
    </Grid>

    <workspaces:HistoryWorkspaceView x:Name="HistoryWorkspaceHost"
                                     Grid.Row="1"
                                     Margin="0,18,0,0" />
  </Grid>
</Window>
