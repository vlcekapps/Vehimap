<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.ConfirmationWindow"
        x:DataType="vm:ConfirmationDialogViewModel"
        Width="560"
        Height="280"
        MinWidth="520"
        MinHeight="240"
        CanResize="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="{Binding Title}"
        AutomationProperties.Name="{Binding Title}"
        AutomationProperties.AutomationId="ConfirmationWindow"
        AutomationProperties.HelpText="{i18n:Loc Confirmation.HelpText}">
  <Grid Margin="20" RowDefinitions="Auto,*,Auto">
    <TextBlock FontSize="22"
               FontWeight="SemiBold"
               Text="{Binding Title}"
               AutomationProperties.Name="{Binding Title}"
               AutomationProperties.AutomationId="ConfirmationHeadingText"
               AutomationProperties.HeadingLevel="1" />
    <ScrollViewer Grid.Row="1"
                  Margin="0,16,0,0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  AutomationProperties.Name="{i18n:Loc Confirmation.MessageName}"
                  AutomationProperties.AutomationId="ConfirmationMessageScrollViewer">
      <TextBlock Text="{Binding Message}"
                 TextWrapping="Wrap" />
    </ScrollViewer>
    <StackPanel Grid.Row="2"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10">
      <Button x:Name="ConfirmButton"
              MinWidth="140"
              Click="OnConfirmClick"
              Content="{Binding ConfirmLabel}"
              AutomationProperties.Name="{Binding ConfirmLabel}"
              AutomationProperties.AutomationId="ConfirmationConfirmButton" />
      <Button MinWidth="120"
              Click="OnCancelClick"
              Content="{Binding CancelLabel}"
              AutomationProperties.Name="{Binding CancelLabel}"
              AutomationProperties.AutomationId="ConfirmationCancelButton" />
    </StackPanel>
  </Grid>
</Window>
