<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.UpdateInstallProgressWindow"
        x:DataType="vm:UpdateInstallProgressDialogViewModel"
        Width="560"
        Height="300"
        MinWidth="520"
        MinHeight="260"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="Stahování aktualizace"
        AutomationProperties.Name="Stahování aktualizace"
        AutomationProperties.AutomationId="UpdateInstallProgressWindow"
        AutomationProperties.HelpText="{Binding HelpText}">
  <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*,Auto">
    <TextBlock FontSize="22"
               FontWeight="SemiBold"
               Text="{Binding Heading}" />
    <TextBlock Grid.Row="1"
               Margin="0,12,0,0"
               Text="{Binding StatusMessage}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding StatusMessage}"
               AutomationProperties.AutomationId="UpdateInstallProgressStatusText" />
    <ProgressBar Grid.Row="2"
                 Margin="0,18,0,0"
                 Minimum="0"
                 Maximum="100"
                 Value="{Binding ProgressValue}"
                 IsIndeterminate="{Binding IsIndeterminate}"
                 AutomationProperties.Name="{Binding ProgressText}"
                 AutomationProperties.AutomationId="UpdateInstallProgressBar" />
    <TextBlock Grid.Row="3"
               Margin="0,8,0,0"
               Text="{Binding ProgressText}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding ProgressText}"
               AutomationProperties.AutomationId="UpdateInstallProgressText" />
    <Button x:Name="CancelButton"
            Grid.Row="4"
            Margin="0,18,0,0"
            HorizontalAlignment="Right"
            MinWidth="120"
            Click="OnCancelClick"
            Content="{Binding CancelButtonLabel}"
            AutomationProperties.Name="{Binding CancelButtonLabel}"
            AutomationProperties.AutomationId="CancelUpdateInstallButton" />
  </Grid>
</Window>
