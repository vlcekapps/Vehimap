<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1400"
        Height="920"
        MinWidth="1120"
        MinHeight="760"
        Title="{Binding Title}"
        AutomationProperties.Name="Vehimap Desktop Preview"
        AutomationProperties.HelpText="Multiplatformní preview Vehimapu. Po otevření je fokus v seznamu vozidel vlevo.">
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportCalendarCommand}" />
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusTimelineSearchCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+F" Command="{Binding FocusGlobalSearchCommand}" />
  </Window.KeyBindings>
  <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*,Auto">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="28"
                   FontWeight="SemiBold"
                   Text="{Binding Title}" />
        <TextBlock Opacity="0.75"
                   Text="{Binding Subtitle}" />
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="10"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center">
        <Button Width="110"
                Height="34"
                Click="OnSettingsClick"
                Content="Nastavení"
                AutomationProperties.Name="Otevřít nastavení aplikace" />
        <Button Width="120"
                Height="34"
                Click="OnAboutClick"
                Content="O programu"
                AutomationProperties.Name="Otevřít dialog O programu" />
        <Button Width="140"
                Height="34"
                Click="OnUpdateCheckClick"
                Content="Aktualizace"
                AutomationProperties.Name="Zkontrolovat aktualizace aplikace" />
        <Button Width="150"
                Height="34"
                Command="{Binding ExportCalendarCommand}"
                Content="Exportovat .ics"
                AutomationProperties.Name="Exportovat budoucí termíny do kalendáře" />
        <Button Width="120"
                Height="34"
                Command="{Binding ReloadCommand}"
                Content="Načíst znovu"
                AutomationProperties.Name="Znovu načíst legacy data" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1"
          Margin="0,18,0,0"
          ColumnDefinitions="180,*"
          RowDefinitions="Auto,Auto,Auto">
      <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Režim dat" />
      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DataMode}" />
      <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="Datová složka" />
      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DataPath}" TextWrapping="Wrap" />
      <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Foreground="IndianRed" Text="{Binding LoadError}" TextWrapping="Wrap" />
    </Grid>

    <Grid Grid.Row="2"
          Margin="0,18,0,0"
          ColumnDefinitions="*,*,*,*,*,*,*">
      <Border Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Vozidla" />
          <TextBlock FontSize="22" Text="{Binding VehicleCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Historie" />
          <TextBlock FontSize="22" Text="{Binding HistoryCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Tankování" />
          <TextBlock FontSize="22" Text="{Binding FuelCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="3" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Doklady" />
          <TextBlock FontSize="22" Text="{Binding RecordsCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="4" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Připomínky" />
          <TextBlock FontSize="22" Text="{Binding RemindersCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="5" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Údržba" />
          <TextBlock FontSize="22" Text="{Binding MaintenanceCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="6" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Audit" />
          <TextBlock FontSize="22" Text="{Binding AuditCount}" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.Row="3" Margin="0,18,0,0" ColumnDefinitions="420,*">
      <Border Padding="16" BorderBrush="#304050" BorderThickness="1" CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="Načtená vozidla z legacy dat" />
          <ListBox x:Name="VehicleListBox"
                   Grid.Row="1"
                   Margin="0,12,0,0"
                   ItemsSource="{Binding Vehicles}"
                   SelectedItem="{Binding SelectedVehicle}"
                   AutomationProperties.Name="Seznam načtených vozidel"
                   AutomationProperties.HelpText="Šipkami vyberte vozidlo. Detail a související evidence se zobrazí vpravo.">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:VehicleListItemViewModel">
                <Border Padding="10"
                        Margin="0,0,0,8"
                        Background="#10203040"
                        CornerRadius="6"
                        AutomationProperties.Name="{Binding AccessibleLabel}">
                  <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                    <TextBlock Opacity="0.82" Text="{Binding MakeModel}" />
                    <TextBlock Opacity="0.82" Text="{Binding Category}" />
                    <TextBlock Opacity="0.82" Text="{Binding Plate}" />
                    <TextBlock Opacity="0.72" Text="{Binding StatusSummary}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1" Margin="16,0,0,0" Padding="16" BorderBrush="#304050" BorderThickness="1" CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <Grid RowDefinitions="Auto,Auto">
            <TextBlock FontWeight="SemiBold"
                       Text="Hlavní pracovní karty vybraného vozidla" />
            <WrapPanel Grid.Row="1"
                       Margin="0,12,0,0"
                       AutomationProperties.Name="Hlavní pracovní karty vybraného vozidla"
                       AutomationProperties.HelpText="Tabem přejdete na právě vybranou kartu. Šipkami vlevo a vpravo můžete změnit kartu.">
              <RadioButton x:Name="DetailTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsDetailTabSelected}"
                      IsTabStop="{Binding IsDetailTabSelected}"
                      Tag="0"
                      Click="OnTabHeaderClick"
                      Content="Detail"
                      AutomationProperties.Name="Karta Detail" />
              <RadioButton x:Name="HistoryTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsHistoryTabSelected}"
                      IsTabStop="{Binding IsHistoryTabSelected}"
                      Tag="1"
                      Click="OnTabHeaderClick"
                      Content="Historie"
                      AutomationProperties.Name="Karta Historie" />
              <RadioButton x:Name="FuelTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsFuelTabSelected}"
                      IsTabStop="{Binding IsFuelTabSelected}"
                      Tag="2"
                      Click="OnTabHeaderClick"
                      Content="Tankování"
                      AutomationProperties.Name="Karta Tankování" />
              <RadioButton x:Name="ReminderTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsReminderTabSelected}"
                      IsTabStop="{Binding IsReminderTabSelected}"
                      Tag="3"
                      Click="OnTabHeaderClick"
                      Content="Připomínky"
                      AutomationProperties.Name="Karta Připomínky" />
              <RadioButton x:Name="MaintenanceTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsMaintenanceTabSelected}"
                      IsTabStop="{Binding IsMaintenanceTabSelected}"
                      Tag="4"
                      Click="OnTabHeaderClick"
                      Content="Údržba"
                      AutomationProperties.Name="Karta Údržba" />
              <RadioButton x:Name="TimelineTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsTimelineTabSelected}"
                      IsTabStop="{Binding IsTimelineTabSelected}"
                      Tag="5"
                      Click="OnTabHeaderClick"
                      Content="Časová osa"
                      AutomationProperties.Name="Karta Časová osa" />
              <RadioButton x:Name="RecordTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsRecordTabSelected}"
                      IsTabStop="{Binding IsRecordTabSelected}"
                      Tag="6"
                      Click="OnTabHeaderClick"
                      Content="Doklady"
                      AutomationProperties.Name="Karta Doklady" />
              <RadioButton x:Name="AuditTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsAuditTabSelected}"
                      IsTabStop="{Binding IsAuditTabSelected}"
                      Tag="7"
                      Click="OnTabHeaderClick"
                      Content="Audit"
                      AutomationProperties.Name="Karta Audit" />
              <RadioButton x:Name="CostTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsCostTabSelected}"
                      IsTabStop="{Binding IsCostTabSelected}"
                      Tag="8"
                      Click="OnTabHeaderClick"
                      Content="Náklady"
                      AutomationProperties.Name="Karta Náklady" />
              <RadioButton x:Name="DashboardTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsDashboardTabSelected}"
                      IsTabStop="{Binding IsDashboardTabSelected}"
                      Tag="9"
                      Click="OnTabHeaderClick"
                      Content="Dashboard"
                      AutomationProperties.Name="Karta Dashboard" />
              <RadioButton x:Name="SearchTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsSearchTabSelected}"
                      IsTabStop="{Binding IsSearchTabSelected}"
                      Tag="10"
                      Click="OnTabHeaderClick"
                      Content="Hledání"
                      AutomationProperties.Name="Karta Hledání" />
            </WrapPanel>
          </Grid>

          <Grid Grid.Row="1"
                Margin="0,16,0,0"
                AutomationProperties.Name="Obsah vybrané hlavní pracovní karty"
                AutomationProperties.HelpText="Obsah se mění podle zvolené karty nahoře.">
            <Grid IsVisible="{Binding IsDetailTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,Auto,Auto,*">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding VehiclePanelHeading}" />
              <WrapPanel Grid.Row="1" Margin="0,14,0,0" ItemWidth="128" ItemHeight="34">
                <Button Command="{Binding CreateVehicleCommand}"
                        Content="Nové vozidlo"
                        AutomationProperties.Name="Vytvořit nové vozidlo" />
                <Button Command="{Binding EditSelectedVehicleCommand}"
                        Content="Upravit"
                        AutomationProperties.Name="Upravit vybrané vozidlo" />
                <Button Command="{Binding SaveVehicleCommand}"
                        Content="Uložit"
                        IsVisible="{Binding IsEditingVehicle}"
                        AutomationProperties.Name="Uložit údaje vozidla" />
                <Button Command="{Binding CancelVehicleEditCommand}"
                        Content="Zrušit"
                        IsVisible="{Binding IsEditingVehicle}"
                        AutomationProperties.Name="Zrušit úpravu vozidla" />
              </WrapPanel>
              <TextBlock Grid.Row="2"
                         Margin="0,12,0,0"
                         Opacity="0.82"
                         Text="{Binding VehicleEditorStatus}"
                         TextWrapping="Wrap" />
              <Grid Grid.Row="3"
                    Margin="0,16,0,0"
                    IsVisible="{Binding IsEditingVehicle}"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <Grid ColumnDefinitions="*,180">
                  <StackPanel Margin="0,0,12,0" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="Název vozidla" />
                    <TextBox x:Name="VehicleEditorNameBox"
                             Text="{Binding VehicleEditorName}"
                             PlaceholderText="Například Milena" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="Kategorie" />
                    <TextBox Text="{Binding VehicleEditorCategory}"
                             PlaceholderText="Například Osobní vozidla" />
                  </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Margin="0,14,0,0" ColumnDefinitions="*,200">
                  <StackPanel Margin="0,0,12,0" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="Značka a model" />
                    <TextBox Text="{Binding VehicleEditorMakeModel}"
                             PlaceholderText="Například Škoda 120L" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="SPZ" />
                    <TextBox Text="{Binding VehicleEditorPlate}"
                             PlaceholderText="Například 1AB2345" />
                  </StackPanel>
                </Grid>
                <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="160,160,*">
                  <StackPanel Margin="0,0,12,0" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="Rok" />
                    <TextBox Text="{Binding VehicleEditorYear}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="Výkon" />
                    <TextBox Text="{Binding VehicleEditorPower}" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="Stav vozidla" />
                    <TextBox Text="{Binding VehicleEditorState}"
                             PlaceholderText="Například Běžný provoz" />
                  </StackPanel>
                </Grid>
                <Grid Grid.Row="3" Margin="0,14,0,0" ColumnDefinitions="*,*">
                  <StackPanel Margin="0,0,12,0" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="Poslední TK" />
                    <TextBox Text="{Binding VehicleEditorLastTk}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="Příští TK" />
                    <TextBox Text="{Binding VehicleEditorNextTk}" />
                  </StackPanel>
                </Grid>
                <Grid Grid.Row="4" Margin="0,14,0,0" ColumnDefinitions="*,*">
                  <StackPanel Margin="0,0,12,0" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="Zelená karta od" />
                    <TextBox Text="{Binding VehicleEditorGreenCardFrom}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock FontWeight="SemiBold" Text="Zelená karta do" />
                    <TextBox Text="{Binding VehicleEditorGreenCardTo}" />
                  </StackPanel>
                </Grid>
                <TextBlock Grid.Row="5" Margin="0,14,0,0" FontWeight="SemiBold" Text="Pohon a servisní profil" />
                <TextBox Grid.Row="6"
                         Margin="0,6,0,0"
                         Text="{Binding VehicleEditorPowertrain}"
                         PlaceholderText="Například benzín, diesel nebo elektro" />
                <TextBlock Grid.Row="7" Margin="0,14,0,0" FontWeight="SemiBold" Text="Poznámka k vozidlu" />
                <TextBox Grid.Row="8"
                         Margin="0,6,0,0"
                         Height="110"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         Text="{Binding VehicleEditorNote}" />
                <TextBlock Grid.Row="9"
                           Margin="0,14,0,0"
                           Opacity="0.72"
                           Text="Změna vozidla zachová související historii, tankování, doklady, připomínky i údržbu."
                           TextWrapping="Wrap" />
              </Grid>
              <Grid Grid.Row="3"
                    Margin="0,16,0,0"
                    IsVisible="{Binding IsVehicleDetailVisible}"
                    RowDefinitions="Auto,Auto,Auto,*">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedVehicleHeading}" />
                <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="{Binding SelectedVehicleOverview}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="{Binding SelectedVehicleDates}" TextWrapping="Wrap" />
                <Border Grid.Row="3" Margin="0,16,0,0" Padding="14" Background="#10203040" CornerRadius="8">
                  <TextBlock Text="{Binding SelectedVehicleProfile}" TextWrapping="Wrap" />
                </Border>
              </Grid>
            </Grid>

            <Grid IsVisible="{Binding IsHistoryTabSelected}" Margin="0,8,0,0" ColumnDefinitions="1.2*,*">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="{Binding HistorySummary}" TextWrapping="Wrap" />
                <ListBox x:Name="HistoryListBox"
                         Grid.Row="1"
                         Margin="0,12,12,0"
                         ItemsSource="{Binding SelectedVehicleHistory}"
                         SelectedItem="{Binding SelectedHistory}"
                         AutomationProperties.Name="Historie vybraného vozidla">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VehicleHistoryItemViewModel">
                      <Border Padding="12"
                              Margin="0,0,0,8"
                              Background="#10203040"
                              CornerRadius="6"
                              AutomationProperties.Name="{Binding AccessibleLabel}">
                        <Grid ColumnDefinitions="120,160,130,120,*">
                          <TextBlock Grid.Column="0" Text="{Binding Date}" />
                          <TextBlock Grid.Column="1" Text="{Binding EventType}" />
                          <TextBlock Grid.Column="2" Text="{Binding Odometer}" />
                          <TextBlock Grid.Column="3" Text="{Binding Cost}" />
                          <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding HistoryPanelHeading}" />
                  <WrapPanel Grid.Row="1" Margin="0,14,0,0" ItemWidth="128" ItemHeight="34">
                    <Button Command="{Binding CreateHistoryCommand}"
                            Content="Nový záznam"
                            AutomationProperties.Name="Vytvořit nový historický záznam" />
                    <Button Command="{Binding EditSelectedHistoryCommand}"
                            Content="Upravit"
                            AutomationProperties.Name="Upravit vybraný historický záznam" />
                    <Button Command="{Binding DeleteSelectedHistoryCommand}"
                            Content="Odstranit"
                            AutomationProperties.Name="Odstranit vybraný historický záznam" />
                    <Button Command="{Binding SaveHistoryCommand}"
                            Content="Uložit"
                            IsVisible="{Binding IsEditingHistory}"
                            AutomationProperties.Name="Uložit historický záznam" />
                    <Button Command="{Binding CancelHistoryEditCommand}"
                            Content="Zrušit"
                            IsVisible="{Binding IsEditingHistory}"
                            AutomationProperties.Name="Zrušit úpravu historického záznamu" />
                  </WrapPanel>
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.82"
                             Text="{Binding HistoryEditorStatus}"
                             TextWrapping="Wrap" />
                  <Grid Grid.Row="3"
                        Margin="0,16,0,0"
                        IsVisible="{Binding IsEditingHistory}"
                        RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock FontWeight="SemiBold" Text="Datum" />
                    <TextBox x:Name="HistoryEditorDateBox"
                             Grid.Row="1"
                             Margin="0,6,0,0"
                             Text="{Binding HistoryEditorDate}"
                             PlaceholderText="Například 15.06.2026" />
                    <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="*,160">
                      <StackPanel Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Typ události" />
                        <TextBox Text="{Binding HistoryEditorType}" PlaceholderText="Například Servis" />
                      </StackPanel>
                      <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Tachometr" />
                        <TextBox Text="{Binding HistoryEditorOdometer}" PlaceholderText="Například 123456" />
                      </StackPanel>
                    </Grid>
                    <TextBlock Grid.Row="3" Margin="0,14,0,0" FontWeight="SemiBold" Text="Cena" />
                    <TextBox Grid.Row="4"
                             Margin="0,6,0,0"
                             Text="{Binding HistoryEditorCost}"
                             PlaceholderText="Například 2500" />
                    <TextBlock Grid.Row="5" Margin="0,14,0,0" FontWeight="SemiBold" Text="Poznámka" />
                    <TextBox Grid.Row="6"
                             Margin="0,6,0,0"
                             Height="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Text="{Binding HistoryEditorNote}" />
                  </Grid>
                  <TextBlock Grid.Row="3"
                             Margin="0,16,0,0"
                             IsVisible="{Binding IsHistoryDetailVisible}"
                             Text="{Binding SelectedHistoryDetail}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>

            <Grid IsVisible="{Binding IsFuelTabSelected}" Margin="0,8,0,0" ColumnDefinitions="1.2*,*">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="{Binding FuelSummary}" TextWrapping="Wrap" />
                <ListBox x:Name="FuelListBox"
                         Grid.Row="1"
                         Margin="0,12,12,0"
                         ItemsSource="{Binding SelectedVehicleFuel}"
                         SelectedItem="{Binding SelectedFuel}"
                         AutomationProperties.Name="Tankování vybraného vozidla">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VehicleFuelItemViewModel">
                      <Border Padding="12"
                              Margin="0,0,0,8"
                              Background="#10203040"
                              CornerRadius="6"
                              AutomationProperties.Name="{Binding AccessibleLabel}">
                        <Grid ColumnDefinitions="110,120,110,120,140,*">
                          <TextBlock Grid.Column="0" Text="{Binding Date}" />
                          <TextBlock Grid.Column="1" Text="{Binding FuelType}" />
                          <TextBlock Grid.Column="2" Text="{Binding Liters}" />
                          <TextBlock Grid.Column="3" Text="{Binding TotalCost}" />
                          <TextBlock Grid.Column="4" Text="{Binding Odometer}" />
                          <TextBlock Grid.Column="5" Text="{Binding TankState}" TextWrapping="Wrap" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding FuelPanelHeading}" />
                  <WrapPanel Grid.Row="1" Margin="0,14,0,0" ItemWidth="122" ItemHeight="34">
                    <Button Command="{Binding CreateFuelCommand}"
                            Content="Nové"
                            AutomationProperties.Name="Vytvořit nové tankování" />
                    <Button Command="{Binding EditSelectedFuelCommand}"
                            Content="Upravit"
                            AutomationProperties.Name="Upravit vybrané tankování" />
                    <Button Command="{Binding DeleteSelectedFuelCommand}"
                            Content="Odstranit"
                            AutomationProperties.Name="Odstranit vybrané tankování" />
                    <Button Command="{Binding SaveFuelCommand}"
                            Content="Uložit"
                            IsVisible="{Binding IsEditingFuel}"
                            AutomationProperties.Name="Uložit tankování" />
                    <Button Command="{Binding CancelFuelEditCommand}"
                            Content="Zrušit"
                            IsVisible="{Binding IsEditingFuel}"
                            AutomationProperties.Name="Zrušit úpravu tankování" />
                  </WrapPanel>
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.82"
                             Text="{Binding FuelEditorStatus}"
                             TextWrapping="Wrap" />
                  <Grid Grid.Row="3"
                        Margin="0,16,0,0"
                        IsVisible="{Binding IsEditingFuel}"
                        RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <Grid ColumnDefinitions="*,170">
                      <StackPanel Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Datum" />
                        <TextBox x:Name="FuelEditorDateBox"
                                 Text="{Binding FuelEditorDate}"
                                 PlaceholderText="Například 15.06.2026" />
                      </StackPanel>
                      <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Palivo" />
                        <TextBox Text="{Binding FuelEditorFuelType}" PlaceholderText="Například Benzín" />
                      </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,14,0,0" ColumnDefinitions="*,*,*">
                      <StackPanel Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Litry" />
                        <TextBox Text="{Binding FuelEditorLiters}" PlaceholderText="Například 35.6" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Cena celkem" />
                        <TextBox Text="{Binding FuelEditorTotalCost}" PlaceholderText="Například 1450" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Tachometr" />
                        <TextBox Text="{Binding FuelEditorOdometer}" PlaceholderText="Například 123456" />
                      </StackPanel>
                    </Grid>
                    <CheckBox Grid.Row="2"
                              Margin="0,14,0,0"
                              IsChecked="{Binding FuelEditorFullTank}"
                              Content="Plná nádrž"
                              AutomationProperties.Name="Při tomto tankování byla plná nádrž" />
                    <TextBlock Grid.Row="3" Margin="0,14,0,0" FontWeight="SemiBold" Text="Poznámka" />
                    <TextBox Grid.Row="4"
                             Margin="0,6,0,0"
                             Height="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Text="{Binding FuelEditorNote}" />
                  </Grid>
                  <TextBlock Grid.Row="3"
                             Margin="0,16,0,0"
                             IsVisible="{Binding IsFuelDetailVisible}"
                             Text="{Binding SelectedFuelDetail}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>

            <Grid IsVisible="{Binding IsReminderTabSelected}" Margin="0,8,0,0" ColumnDefinitions="1.2*,*">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="{Binding ReminderSummary}" TextWrapping="Wrap" />
                <ListBox x:Name="ReminderListBox"
                         Grid.Row="1"
                         Margin="0,12,12,0"
                         ItemsSource="{Binding SelectedVehicleReminders}"
                         SelectedItem="{Binding SelectedReminder}"
                         AutomationProperties.Name="Připomínky vybraného vozidla">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VehicleReminderItemViewModel">
                      <Border Padding="12"
                              Margin="0,0,0,8"
                              Background="#10203040"
                              CornerRadius="6"
                              AutomationProperties.Name="{Binding AccessibleLabel}">
                        <Grid ColumnDefinitions="2*,130,130,130,*">
                          <TextBlock Grid.Column="0" Text="{Binding Title}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="1" Text="{Binding DueDate}" />
                          <TextBlock Grid.Column="2" Text="{Binding Status}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="3" Text="{Binding RepeatMode}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding ReminderPanelHeading}" />
                  <WrapPanel Grid.Row="1" Margin="0,14,0,0" ItemWidth="122" ItemHeight="34">
                    <Button Command="{Binding CreateReminderCommand}"
                            Content="Nová"
                            AutomationProperties.Name="Vytvořit novou připomínku" />
                    <Button Command="{Binding EditSelectedReminderCommand}"
                            Content="Upravit"
                            AutomationProperties.Name="Upravit vybranou připomínku" />
                    <Button Command="{Binding DeleteSelectedReminderCommand}"
                            Content="Odstranit"
                            AutomationProperties.Name="Odstranit vybranou připomínku" />
                    <Button Command="{Binding SaveReminderCommand}"
                            Content="Uložit"
                            IsVisible="{Binding IsEditingReminder}"
                            AutomationProperties.Name="Uložit připomínku" />
                    <Button Command="{Binding CancelReminderEditCommand}"
                            Content="Zrušit"
                            IsVisible="{Binding IsEditingReminder}"
                            AutomationProperties.Name="Zrušit úpravu připomínky" />
                  </WrapPanel>
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.82"
                             Text="{Binding ReminderEditorStatus}"
                             TextWrapping="Wrap" />
                  <Grid Grid.Row="3"
                        Margin="0,16,0,0"
                        IsVisible="{Binding IsEditingReminder}"
                        RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock FontWeight="SemiBold" Text="Název připomínky" />
                    <TextBox x:Name="ReminderEditorTitleBox"
                             Grid.Row="1"
                             Margin="0,6,0,0"
                             Text="{Binding ReminderEditorTitle}"
                             PlaceholderText="Například objednat servis" />
                    <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="*,140">
                      <StackPanel Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Termín" />
                        <TextBox Text="{Binding ReminderEditorDueDate}" PlaceholderText="Například 15.06.2026 nebo 06/2026" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Předstih dnů" />
                        <TextBox Text="{Binding ReminderEditorDays}" PlaceholderText="Například 30" />
                      </StackPanel>
                    </Grid>
                    <TextBlock Grid.Row="3" Margin="0,14,0,0" FontWeight="SemiBold" Text="Opakování" />
                    <TextBox Grid.Row="4"
                             Margin="0,6,0,0"
                             Text="{Binding ReminderEditorRepeatMode}"
                             PlaceholderText="Například Ročně nebo bez opakování" />
                    <TextBlock Grid.Row="5" Margin="0,14,0,0" FontWeight="SemiBold" Text="Poznámka" />
                    <TextBox Grid.Row="6"
                             Margin="0,6,0,0"
                             Height="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Text="{Binding ReminderEditorNote}" />
                  </Grid>
                  <TextBlock Grid.Row="3"
                             Margin="0,16,0,0"
                             IsVisible="{Binding IsReminderDetailVisible}"
                             Text="{Binding SelectedReminderDetail}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>

            <Grid IsVisible="{Binding IsMaintenanceTabSelected}" Margin="0,8,0,0" ColumnDefinitions="1.2*,*">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="{Binding MaintenanceSummary}" TextWrapping="Wrap" />
                <ListBox x:Name="MaintenanceListBox"
                         Grid.Row="1"
                         Margin="0,12,12,0"
                         ItemsSource="{Binding SelectedVehicleMaintenance}"
                         SelectedItem="{Binding SelectedMaintenance}"
                         AutomationProperties.Name="Plán údržby vybraného vozidla">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VehicleMaintenanceItemViewModel">
                      <Border Padding="12"
                              Margin="0,0,0,8"
                              Background="#10203040"
                              CornerRadius="6"
                              AutomationProperties.Name="{Binding AccessibleLabel}">
                        <Grid ColumnDefinitions="2*,170,170,180,*">
                          <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="1" Text="{Binding Interval}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="2" Text="{Binding LastService}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="3" Text="{Binding Status}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding MaintenancePanelHeading}" />
                  <WrapPanel Grid.Row="1" Margin="0,14,0,0" ItemWidth="132" ItemHeight="34">
                    <Button Command="{Binding CreateMaintenanceCommand}"
                            Content="Nový plán"
                            AutomationProperties.Name="Vytvořit nový servisní plán" />
                    <Button Command="{Binding EditSelectedMaintenanceCommand}"
                            Content="Upravit"
                            AutomationProperties.Name="Upravit vybraný servisní plán" />
                    <Button Command="{Binding DeleteSelectedMaintenanceCommand}"
                            Content="Odstranit"
                            AutomationProperties.Name="Odstranit vybraný servisní plán" />
                    <Button Command="{Binding SaveMaintenanceCommand}"
                            Content="Uložit"
                            IsVisible="{Binding IsEditingMaintenance}"
                            AutomationProperties.Name="Uložit servisní plán" />
                    <Button Command="{Binding CancelMaintenanceEditCommand}"
                            Content="Zrušit"
                            IsVisible="{Binding IsEditingMaintenance}"
                            AutomationProperties.Name="Zrušit úpravu servisního plánu" />
                  </WrapPanel>
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.82"
                             Text="{Binding MaintenanceEditorStatus}"
                             TextWrapping="Wrap" />
                  <Grid Grid.Row="3"
                        Margin="0,16,0,0"
                        IsVisible="{Binding IsEditingMaintenance}"
                        RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock FontWeight="SemiBold" Text="Název úkonu" />
                    <TextBox x:Name="MaintenanceEditorTitleBox"
                             Grid.Row="1"
                             Margin="0,6,0,0"
                             Text="{Binding MaintenanceEditorTitle}"
                             PlaceholderText="Například Motorový olej" />
                    <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="*,*">
                      <StackPanel Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Interval km" />
                        <TextBox Text="{Binding MaintenanceEditorIntervalKm}" PlaceholderText="Například 15000" />
                      </StackPanel>
                      <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Interval měsíců" />
                        <TextBox Text="{Binding MaintenanceEditorIntervalMonths}" PlaceholderText="Například 12" />
                      </StackPanel>
                    </Grid>
                    <Grid Grid.Row="3" Margin="0,14,0,0" ColumnDefinitions="*,*">
                      <StackPanel Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Poslední servis - datum" />
                        <TextBox Text="{Binding MaintenanceEditorLastServiceDate}" PlaceholderText="Například 15.06.2026" />
                      </StackPanel>
                      <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Poslední servis - tachometr" />
                        <TextBox Text="{Binding MaintenanceEditorLastServiceOdometer}" PlaceholderText="Například 123456" />
                      </StackPanel>
                    </Grid>
                    <CheckBox Grid.Row="4"
                              Margin="0,14,0,0"
                              IsChecked="{Binding MaintenanceEditorIsActive}"
                              Content="Aktivní servisní plán"
                              AutomationProperties.Name="Servisní plán je aktivní" />
                    <TextBlock Grid.Row="5" Margin="0,14,0,0" FontWeight="SemiBold" Text="Poznámka" />
                    <TextBox Grid.Row="6"
                             Margin="0,6,0,0"
                             Height="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Text="{Binding MaintenanceEditorNote}" />
                  </Grid>
                  <TextBlock Grid.Row="3"
                             Margin="0,16,0,0"
                             IsVisible="{Binding IsMaintenanceDetailVisible}"
                             Text="{Binding SelectedMaintenanceDetail}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>

            <Grid IsVisible="{Binding IsTimelineTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.35*,*">
              <TextBlock Grid.ColumnSpan="2" Text="{Binding TimelineSummary}" TextWrapping="Wrap" />

              <Grid Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,12,0,0"
                    ColumnDefinitions="100,170,100,*">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Zobrazit" />
                <ComboBox x:Name="TimelineFilterComboBox"
                          Grid.Column="1"
                          ItemsSource="{Binding TimelineFilters}"
                          SelectedItem="{Binding SelectedTimelineFilter}"
                          AutomationProperties.Name="Filtr časové osy" />
                <TextBlock Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center" Text="Hledat" />
                <TextBox x:Name="TimelineSearchBox"
                         Grid.Column="3"
                         Margin="12,0,0,0"
                         Text="{Binding TimelineSearchText}"
                         PlaceholderText="Položka, stav nebo poznámka"
                         AutomationProperties.Name="Hledání v časové ose" />
              </Grid>

              <ListBox x:Name="TimelineListBox"
                       Grid.Row="2"
                       Margin="0,12,12,0"
                       ItemsSource="{Binding SelectedVehicleTimeline}"
                       SelectedItem="{Binding SelectedTimelineItem}"
                       AutomationProperties.Name="Časová osa vybraného vozidla">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedTimelineItemCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:VehicleTimelineItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <Grid ColumnDefinitions="110,150,220,*,150">
                        <TextBlock Grid.Column="0" Text="{Binding Date}" />
                        <TextBlock Grid.Column="1" Text="{Binding KindLabel}" />
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="3" Text="{Binding Detail}" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="4" Text="{Binding Status}" TextWrapping="Wrap" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Border Grid.Row="2" Grid.Column="1" Margin="12,12,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail časové osy" />
                  <Button Grid.Row="1"
                          x:Name="TimelineOpenButton"
                          Margin="0,12,0,0"
                          Width="150"
                          HorizontalAlignment="Left"
                          Command="{Binding OpenSelectedTimelineItemCommand}"
                          Content="Otevřít položku"
                          AutomationProperties.Name="Otevřít vybranou položku časové osy v aplikaci" />
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.78"
                             Text="{Binding ExportStatus}"
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="3"
                             Margin="0,12,0,0"
                             Opacity="0.72"
                             Text="Technická kontrola a zelená karta otevřou detail vozidla, ostatní položky přepnou na odpovídající kartu evidence."
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="4" Margin="0,16,0,0" Text="{Binding SelectedTimelineDetail}" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>

            <Grid IsVisible="{Binding IsRecordTabSelected}" Margin="0,8,0,0" ColumnDefinitions="1.2*,*">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="{Binding RecordSummary}" TextWrapping="Wrap" />
                <ListBox x:Name="RecordListBox"
                         Grid.Row="1"
                         Margin="0,12,12,0"
                         ItemsSource="{Binding SelectedVehicleRecords}"
                         SelectedItem="{Binding SelectedRecord}"
                         AutomationProperties.Name="Doklady vybraného vozidla">
                  <ListBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedRecordFileCommand}" />
                  </ListBox.KeyBindings>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VehicleRecordItemViewModel">
                      <Border Padding="12"
                              Margin="0,0,0,8"
                              Background="#10203040"
                              CornerRadius="6"
                              AutomationProperties.Name="{Binding AccessibleLabel}">
                        <StackPanel Spacing="4">
                          <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                          <TextBlock Opacity="0.82" Text="{Binding RecordType}" />
                          <TextBlock Opacity="0.82" Text="{Binding Provider}" />
                          <TextBlock Opacity="0.82" Text="{Binding Validity}" />
                          <TextBlock Opacity="0.82" Text="{Binding AttachmentMode}" />
                          <TextBlock Opacity="0.72" Text="{Binding AttachmentState}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding RecordPanelHeading}" />
                  <WrapPanel Grid.Row="1" Margin="0,14,0,0" ItemWidth="138" ItemHeight="34">
                    <Button Command="{Binding CreateRecordCommand}"
                            Content="Nový doklad"
                            AutomationProperties.Name="Vytvořit nový doklad" />
                    <Button Command="{Binding EditSelectedRecordCommand}"
                            Content="Upravit"
                            AutomationProperties.Name="Upravit vybraný doklad" />
                    <Button Command="{Binding DeleteSelectedRecordCommand}"
                            Content="Odstranit"
                            AutomationProperties.Name="Odstranit vybraný doklad" />
                    <Button Command="{Binding MoveSelectedRecordToManagedCommand}"
                            Content="Přesunout do příloh"
                            AutomationProperties.Name="Převést vybraný doklad na spravovanou kopii" />
                    <Button Command="{Binding OpenSelectedRecordFileCommand}"
                            Content="Otevřít soubor"
                            IsVisible="{Binding IsRecordDetailVisible}"
                            AutomationProperties.Name="Otevřít soubor přílohy vybraného dokladu" />
                    <Button Command="{Binding OpenSelectedRecordFolderCommand}"
                            Content="Otevřít složku"
                            IsVisible="{Binding IsRecordDetailVisible}"
                            AutomationProperties.Name="Otevřít složku přílohy vybraného dokladu" />
                    <Button Command="{Binding SaveRecordCommand}"
                            Content="Uložit"
                            IsVisible="{Binding IsEditingRecord}"
                            AutomationProperties.Name="Uložit doklad" />
                    <Button Command="{Binding CancelRecordEditCommand}"
                            Content="Zrušit"
                            IsVisible="{Binding IsEditingRecord}"
                            AutomationProperties.Name="Zrušit úpravu dokladu" />
                  </WrapPanel>
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.82"
                             Text="{Binding RecordEditorStatus}"
                             TextWrapping="Wrap" />
                  <Grid Grid.Row="3"
                        Margin="0,16,0,0"
                        IsVisible="{Binding IsEditingRecord}"
                        RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <Grid ColumnDefinitions="1.1*,1.4*">
                      <StackPanel Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Typ dokladu" />
                        <TextBox Text="{Binding RecordEditorRecordType}" PlaceholderText="Například Povinné ručení" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Název" />
                        <TextBox x:Name="RecordEditorTitleBox" Text="{Binding RecordEditorTitle}" PlaceholderText="Například Allianz 2026" />
                      </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,14,0,0" ColumnDefinitions="1.2*,*,*">
                      <StackPanel Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Poskytovatel" />
                        <TextBox Text="{Binding RecordEditorProvider}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Platí od" />
                        <TextBox Text="{Binding RecordEditorValidFrom}" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Platí do" />
                        <TextBox Text="{Binding RecordEditorValidTo}" />
                      </StackPanel>
                    </Grid>
                    <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="180,*">
                      <StackPanel Margin="0,0,12,0" Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Cena" />
                        <TextBox Text="{Binding RecordEditorPrice}" />
                      </StackPanel>
                      <StackPanel Spacing="6">
                        <TextBlock FontWeight="SemiBold" Text="Režim přílohy" />
                        <ComboBox ItemsSource="{Binding RecordAttachmentModes}"
                                  SelectedItem="{Binding SelectedRecordEditorAttachmentMode}" />
                      </StackPanel>
                    </Grid>
                    <TextBlock Grid.Row="3"
                               Margin="0,14,0,0"
                               FontWeight="SemiBold"
                               Text="{Binding RecordEditorPathInputLabel}" />
                    <Grid Grid.Row="4" Margin="0,6,0,0" ColumnDefinitions="*,150">
                      <TextBox Text="{Binding RecordEditorPathInput}"
                               PlaceholderText="{Binding RecordEditorPathInputHelp}" />
                      <Button Grid.Column="1"
                              Margin="12,0,0,0"
                              Command="{Binding BrowseRecordAttachmentCommand}"
                              Content="Vybrat soubor"
                              AutomationProperties.Name="Vybrat soubor pro doklad" />
                    </Grid>
                    <TextBlock Grid.Row="5"
                               Margin="0,8,0,0"
                               Opacity="0.74"
                               Text="{Binding RecordEditorPathInputHelp}"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="6" Margin="0,14,0,0" FontWeight="SemiBold" Text="Uložená cesta" />
                    <SelectableTextBlock Grid.Row="7" Margin="0,6,0,0" Text="{Binding RecordEditorStoredPath}" />
                    <TextBlock Grid.Row="8" Margin="0,14,0,0" FontWeight="SemiBold" Text="Vyřešená cesta" />
                    <SelectableTextBlock Grid.Row="9" Margin="0,6,0,0" Text="{Binding RecordEditorResolvedPath}" />
                    <TextBlock Grid.Row="10"
                               Margin="0,14,0,0"
                               Text="{Binding RecordEditorAvailability}"
                               TextWrapping="Wrap" />
                    <StackPanel Grid.Row="11" Margin="0,14,0,0" Spacing="6">
                      <TextBlock FontWeight="SemiBold" Text="Poznámka" />
                      <TextBox Height="100"
                               AcceptsReturn="True"
                               TextWrapping="Wrap"
                               VerticalContentAlignment="Top"
                               Text="{Binding RecordEditorNote}" />
                    </StackPanel>
                  </Grid>
                  <TextBlock Grid.Row="3"
                             Margin="0,16,0,0"
                             IsVisible="{Binding IsRecordDetailVisible}"
                             Text="{Binding SelectedRecordDetail}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>

            <Grid IsVisible="{Binding IsAuditTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,*">
              <TextBlock Text="{Binding AuditSummary}" TextWrapping="Wrap" />
              <ListBox x:Name="AuditListBox"
                       Grid.Row="1"
                       Margin="0,12,0,0"
                       ItemsSource="{Binding AuditItems}"
                       SelectedItem="{Binding SelectedDashboardAuditItem}"
                       AutomationProperties.Name="Seznam auditních položek">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardAuditItemCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:AuditItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                        <TextBlock Text="{Binding VehicleName}" />
                        <TextBlock Opacity="0.8" Text="{Binding Severity}" />
                        <TextBlock Opacity="0.8" Text="{Binding Category}" />
                        <TextBlock Opacity="0.8" Text="{Binding Message}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>

            <Grid IsVisible="{Binding IsCostTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,Auto,*">
              <TextBlock Text="{Binding CostSummary}" TextWrapping="Wrap" />
              <TextBlock Grid.Row="1" Margin="0,8,0,0" Opacity="0.75" Text="{Binding CostComparison}" TextWrapping="Wrap" />
              <ListBox x:Name="CostListBox"
                       Grid.Row="2"
                       Margin="0,12,0,0"
                       ItemsSource="{Binding CostVehicles}"
                       SelectedItem="{Binding SelectedDashboardCostVehicle}"
                       AutomationProperties.Name="Seznam nákladových souhrnů vozidel">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardCostVehicleCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:CostVehicleItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*,1.5*">
                        <StackPanel>
                          <TextBlock FontWeight="SemiBold" Text="{Binding VehicleName}" />
                          <TextBlock Opacity="0.8" Text="{Binding Category}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TotalCost}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Distance}" />
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding CostPerKm}" />
                        <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding Status}" TextWrapping="Wrap" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>

            <Grid IsVisible="{Binding IsDashboardTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,*" ColumnDefinitions="1.1*,1.1*,1.2*">
              <StackPanel Grid.ColumnSpan="3" Spacing="8">
                <TextBlock Text="{Binding AuditSummary}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.82" Text="{Binding CostSummary}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.75" Text="{Binding CostComparison}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.75" Text="{Binding DashboardTimelineSummary}" TextWrapping="Wrap" />
              </StackPanel>

              <Border Grid.Row="1" Grid.Column="0" Margin="0,16,12,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Nejdůležitější audit" />
                  <Button Grid.Row="1"
                          x:Name="DashboardAuditOpenButton"
                          Margin="0,12,0,0"
                          Width="150"
                          HorizontalAlignment="Left"
                          Command="{Binding OpenSelectedDashboardAuditItemCommand}"
                          Content="Otevřít vozidlo"
                          AutomationProperties.Name="Otevřít vozidlo nebo evidenci z vybrané auditní položky" />
                  <ListBox x:Name="DashboardAuditListBox"
                           Grid.Row="2"
                           Margin="0,12,0,0"
                           ItemsSource="{Binding AuditItems}"
                           SelectedItem="{Binding SelectedDashboardAuditItem}"
                           AutomationProperties.Name="Přehled auditních položek na dashboardu">
                    <ListBox.KeyBindings>
                      <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardAuditItemCommand}" />
                    </ListBox.KeyBindings>
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:AuditItemViewModel">
                        <Border Padding="12"
                                Margin="0,0,0,8"
                                Background="#143A4A5A"
                                CornerRadius="6"
                                AutomationProperties.Name="{Binding AccessibleLabel}">
                          <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                            <TextBlock Text="{Binding VehicleName}" />
                            <TextBlock Opacity="0.8" Text="{Binding Severity}" />
                            <TextBlock Opacity="0.8" Text="{Binding Message}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>

              <Border Grid.Row="1" Grid.Column="1" Margin="0,16,12,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Náklady vozidel" />
                  <Button Grid.Row="1"
                          x:Name="DashboardCostOpenButton"
                          Margin="0,12,0,0"
                          Width="150"
                          HorizontalAlignment="Left"
                          Command="{Binding OpenSelectedDashboardCostVehicleCommand}"
                          Content="Vybrat vozidlo"
                          AutomationProperties.Name="Vybrat vozidlo z nákladového přehledu" />
                  <ListBox x:Name="DashboardCostListBox"
                           Grid.Row="2"
                           Margin="0,12,0,0"
                           ItemsSource="{Binding CostVehicles}"
                           SelectedItem="{Binding SelectedDashboardCostVehicle}"
                           AutomationProperties.Name="Přehled nákladových položek na dashboardu">
                    <ListBox.KeyBindings>
                      <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardCostVehicleCommand}" />
                    </ListBox.KeyBindings>
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:CostVehicleItemViewModel">
                        <Border Padding="12"
                                Margin="0,0,0,8"
                                Background="#143A4A5A"
                                CornerRadius="6"
                                AutomationProperties.Name="{Binding AccessibleLabel}">
                          <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding VehicleName}" />
                            <TextBlock Opacity="0.8" Text="{Binding Category}" />
                            <TextBlock Opacity="0.8" Text="{Binding TotalCost}" />
                            <TextBlock Opacity="0.8" Text="{Binding CostPerKm}" />
                            <TextBlock Opacity="0.8" Text="{Binding Status}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>

              <Border Grid.Row="1" Grid.Column="2" Margin="0,16,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Nejbližší termíny" />
                  <Button Grid.Row="1"
                          x:Name="DashboardTimelineOpenButton"
                          Margin="0,12,0,0"
                          Width="150"
                          HorizontalAlignment="Left"
                          Command="{Binding OpenSelectedDashboardTimelineItemCommand}"
                          Content="Otevřít položku"
                          AutomationProperties.Name="Otevřít vybraný termín z dashboardu" />
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.75"
                             Text="{Binding SelectedDashboardTimelineDetail}"
                             TextWrapping="Wrap" />
                  <ListBox x:Name="DashboardTimelineListBox"
                           Grid.Row="3"
                           Margin="0,12,0,0"
                           ItemsSource="{Binding DashboardUpcomingTimeline}"
                           SelectedItem="{Binding SelectedDashboardTimelineItem}"
                           AutomationProperties.Name="Nejbližší termíny napříč vozidly">
                    <ListBox.KeyBindings>
                      <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardTimelineItemCommand}" />
                    </ListBox.KeyBindings>
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:VehicleTimelineItemViewModel">
                        <Border Padding="12"
                                Margin="0,0,0,8"
                                Background="#143A4A5A"
                                CornerRadius="6"
                                AutomationProperties.Name="{Binding AccessibleLabel}">
                          <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                            <TextBlock Text="{Binding VehicleName}" />
                            <TextBlock Opacity="0.8" Text="{Binding Date}" />
                            <TextBlock Opacity="0.8" Text="{Binding KindLabel}" />
                            <TextBlock Opacity="0.8" Text="{Binding Status}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>
            </Grid>

            <Grid IsVisible="{Binding IsSearchTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.25*,*">
              <TextBlock Grid.ColumnSpan="2"
                         Text="{Binding GlobalSearchSummary}"
                         TextWrapping="Wrap" />
              <Grid Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,12,0,0"
                    ColumnDefinitions="100,*,150">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Hledat" />
                <TextBox x:Name="GlobalSearchTextBox"
                         Grid.Column="1"
                         Margin="12,0,0,0"
                         Text="{Binding GlobalSearchText}"
                         PlaceholderText="Vozidlo, SPZ, doklad, připomínka, údržba..."
                         AutomationProperties.Name="Globální hledání ve Vehimapu" />
                <Button Grid.Column="2"
                        x:Name="SearchOpenButton"
                        Margin="12,0,0,0"
                        Width="150"
                        Command="{Binding OpenSelectedSearchResultCommand}"
                        Content="Otevřít položku"
                        AutomationProperties.Name="Otevřít vybraný výsledek hledání" />
              </Grid>

              <ListBox x:Name="SearchResultsListBox"
                       Grid.Row="2"
                       Margin="0,12,12,0"
                       ItemsSource="{Binding GlobalSearchResults}"
                       SelectedItem="{Binding SelectedSearchResult}"
                       AutomationProperties.Name="Výsledky globálního hledání">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedSearchResultCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:GlobalSearchResultItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                        <TextBlock Opacity="0.82" Text="{Binding SectionLabel}" />
                        <TextBlock Opacity="0.82" Text="{Binding VehicleName}" />
                        <TextBlock Opacity="0.72" Text="{Binding Summary}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Border Grid.Row="2"
                      Grid.Column="1"
                      Margin="12,12,0,0"
                      Padding="16"
                      Background="#10203040"
                      CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail výsledku" />
                  <TextBlock Grid.Row="1"
                             Margin="0,12,0,0"
                             Opacity="0.75"
                             Text="Enter nebo tlačítko otevře rovnou správné vozidlo nebo evidenci."
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="2"
                             Margin="0,16,0,0"
                             Text="{Binding SelectedSearchResultDetail}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <TextBlock Grid.Row="4"
               Margin="0,16,0,0"
               Opacity="0.75"
               Text="C# větev už nad stejnými legacy daty jako AHK verze zobrazuje detail vozidla, historii, tankování, doklady, připomínky, údržbu, časovou osu, audit, náklady, dashboard i globální hledání. Připomínky, doklady, historii, tankování i plán údržby už lze také přímo upravovat."
               TextWrapping="Wrap" />
  </Grid>
</Window>
