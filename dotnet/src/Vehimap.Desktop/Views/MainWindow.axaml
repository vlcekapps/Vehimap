<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1400"
        Height="920"
        MinWidth="1120"
        MinHeight="760"
        Title="{Binding Title}"
        AutomationProperties.Name="Vehimap Desktop Preview"
        AutomationProperties.HelpText="Multiplatformní preview Vehimapu. Po otevření je fokus v seznamu vozidel vlevo.">
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportCalendarCommand}" />
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusTimelineSearchCommand}" />
  </Window.KeyBindings>
  <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*,Auto">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="28"
                   FontWeight="SemiBold"
                   Text="{Binding Title}" />
        <TextBlock Opacity="0.75"
                   Text="{Binding Subtitle}" />
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="10"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center">
        <Button Width="150"
                Height="34"
                Command="{Binding ExportCalendarCommand}"
                Content="Exportovat .ics"
                AutomationProperties.Name="Exportovat budoucí termíny do kalendáře" />
        <Button Width="120"
                Height="34"
                Command="{Binding ReloadCommand}"
                Content="Načíst znovu"
                AutomationProperties.Name="Znovu načíst legacy data" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1"
          Margin="0,18,0,0"
          ColumnDefinitions="180,*"
          RowDefinitions="Auto,Auto,Auto">
      <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Režim dat" />
      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DataMode}" />
      <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="Datová složka" />
      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DataPath}" TextWrapping="Wrap" />
      <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Foreground="IndianRed" Text="{Binding LoadError}" TextWrapping="Wrap" />
    </Grid>

    <Grid Grid.Row="2"
          Margin="0,18,0,0"
          ColumnDefinitions="*,*,*,*,*,*,*">
      <Border Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Vozidla" />
          <TextBlock FontSize="22" Text="{Binding VehicleCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Historie" />
          <TextBlock FontSize="22" Text="{Binding HistoryCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Tankování" />
          <TextBlock FontSize="22" Text="{Binding FuelCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="3" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Doklady" />
          <TextBlock FontSize="22" Text="{Binding RecordsCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="4" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Připomínky" />
          <TextBlock FontSize="22" Text="{Binding RemindersCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="5" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Údržba" />
          <TextBlock FontSize="22" Text="{Binding MaintenanceCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="6" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Audit" />
          <TextBlock FontSize="22" Text="{Binding AuditCount}" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.Row="3" Margin="0,18,0,0" ColumnDefinitions="420,*">
      <Border Padding="16" BorderBrush="#304050" BorderThickness="1" CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="Načtená vozidla z legacy dat" />
          <ListBox x:Name="VehicleListBox"
                   Grid.Row="1"
                   Margin="0,12,0,0"
                   ItemsSource="{Binding Vehicles}"
                   SelectedItem="{Binding SelectedVehicle}"
                   AutomationProperties.Name="Seznam načtených vozidel"
                   AutomationProperties.HelpText="Šipkami vyberte vozidlo. Detail a související evidence se zobrazí vpravo.">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:VehicleListItemViewModel">
                <Border Padding="10"
                        Margin="0,0,0,8"
                        Background="#10203040"
                        CornerRadius="6"
                        AutomationProperties.Name="{Binding AccessibleLabel}">
                  <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                    <TextBlock Opacity="0.82" Text="{Binding MakeModel}" />
                    <TextBlock Opacity="0.82" Text="{Binding Category}" />
                    <TextBlock Opacity="0.82" Text="{Binding Plate}" />
                    <TextBlock Opacity="0.72" Text="{Binding StatusSummary}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1" Margin="16,0,0,0" Padding="16" BorderBrush="#304050" BorderThickness="1" CornerRadius="10">
        <TabControl x:Name="VehicleTabControl"
                    SelectedIndex="{Binding SelectedVehicleTabIndex}"
                    AutomationProperties.Name="Hlavní pracovní karty vybraného vozidla"
                    AutomationProperties.HelpText="Karty Detail, Historie, Tankování, Připomínky, Údržba, Časová osa, Doklady, Audit, Náklady a Dashboard.">
          <TabItem Header="Detail">
            <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,Auto,*">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedVehicleHeading}" />
              <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="{Binding SelectedVehicleOverview}" TextWrapping="Wrap" />
              <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="{Binding SelectedVehicleDates}" TextWrapping="Wrap" />
              <Border Grid.Row="3" Margin="0,16,0,0" Padding="14" Background="#10203040" CornerRadius="8">
                <TextBlock Text="{Binding SelectedVehicleProfile}" TextWrapping="Wrap" />
              </Border>
            </Grid>
          </TabItem>

          <TabItem Header="Historie">
            <Grid Margin="0,8,0,0" RowDefinitions="Auto,*">
              <TextBlock Text="{Binding HistorySummary}" TextWrapping="Wrap" />
              <ListBox x:Name="HistoryListBox"
                       Grid.Row="1"
                       Margin="0,12,0,0"
                       ItemsSource="{Binding SelectedVehicleHistory}"
                       SelectedItem="{Binding SelectedHistory}"
                       AutomationProperties.Name="Historie vybraného vozidla">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:VehicleHistoryItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <Grid ColumnDefinitions="120,160,130,120,*">
                        <TextBlock Grid.Column="0" Text="{Binding Date}" />
                        <TextBlock Grid.Column="1" Text="{Binding EventType}" />
                        <TextBlock Grid.Column="2" Text="{Binding Odometer}" />
                        <TextBlock Grid.Column="3" Text="{Binding Cost}" />
                        <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </TabItem>

          <TabItem Header="Tankování">
            <Grid Margin="0,8,0,0" ColumnDefinitions="1.2*,*">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="{Binding FuelSummary}" TextWrapping="Wrap" />
                <ListBox x:Name="FuelListBox"
                         Grid.Row="1"
                         Margin="0,12,12,0"
                         ItemsSource="{Binding SelectedVehicleFuel}"
                         SelectedItem="{Binding SelectedFuel}"
                         AutomationProperties.Name="Tankování vybraného vozidla">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VehicleFuelItemViewModel">
                      <Border Padding="12"
                              Margin="0,0,0,8"
                              Background="#10203040"
                              CornerRadius="6"
                              AutomationProperties.Name="{Binding AccessibleLabel}">
                        <Grid ColumnDefinitions="110,120,110,120,140,*">
                          <TextBlock Grid.Column="0" Text="{Binding Date}" />
                          <TextBlock Grid.Column="1" Text="{Binding FuelType}" />
                          <TextBlock Grid.Column="2" Text="{Binding Liters}" />
                          <TextBlock Grid.Column="3" Text="{Binding TotalCost}" />
                          <TextBlock Grid.Column="4" Text="{Binding Odometer}" />
                          <TextBlock Grid.Column="5" Text="{Binding TankState}" TextWrapping="Wrap" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail tankování" />
                  <TextBlock Grid.Row="1" Margin="0,16,0,0" Text="{Binding SelectedFuelDetail}" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>
          </TabItem>

          <TabItem Header="Připomínky">
            <Grid Margin="0,8,0,0" ColumnDefinitions="1.2*,*">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="{Binding ReminderSummary}" TextWrapping="Wrap" />
                <ListBox x:Name="ReminderListBox"
                         Grid.Row="1"
                         Margin="0,12,12,0"
                         ItemsSource="{Binding SelectedVehicleReminders}"
                         SelectedItem="{Binding SelectedReminder}"
                         AutomationProperties.Name="Připomínky vybraného vozidla">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VehicleReminderItemViewModel">
                      <Border Padding="12"
                              Margin="0,0,0,8"
                              Background="#10203040"
                              CornerRadius="6"
                              AutomationProperties.Name="{Binding AccessibleLabel}">
                        <Grid ColumnDefinitions="2*,130,130,130,*">
                          <TextBlock Grid.Column="0" Text="{Binding Title}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="1" Text="{Binding DueDate}" />
                          <TextBlock Grid.Column="2" Text="{Binding Status}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="3" Text="{Binding RepeatMode}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail připomínky" />
                  <TextBlock Grid.Row="1" Margin="0,16,0,0" Text="{Binding SelectedReminderDetail}" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>
          </TabItem>

          <TabItem Header="Údržba">
            <Grid Margin="0,8,0,0" ColumnDefinitions="1.2*,*">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="{Binding MaintenanceSummary}" TextWrapping="Wrap" />
                <ListBox x:Name="MaintenanceListBox"
                         Grid.Row="1"
                         Margin="0,12,12,0"
                         ItemsSource="{Binding SelectedVehicleMaintenance}"
                         SelectedItem="{Binding SelectedMaintenance}"
                         AutomationProperties.Name="Plán údržby vybraného vozidla">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VehicleMaintenanceItemViewModel">
                      <Border Padding="12"
                              Margin="0,0,0,8"
                              Background="#10203040"
                              CornerRadius="6"
                              AutomationProperties.Name="{Binding AccessibleLabel}">
                        <Grid ColumnDefinitions="2*,170,170,180,*">
                          <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="1" Text="{Binding Interval}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="2" Text="{Binding LastService}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="3" Text="{Binding Status}" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail údržby" />
                  <TextBlock Grid.Row="1" Margin="0,16,0,0" Text="{Binding SelectedMaintenanceDetail}" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>
          </TabItem>

          <TabItem Header="Časová osa">
            <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.35*,*">
              <TextBlock Grid.ColumnSpan="2" Text="{Binding TimelineSummary}" TextWrapping="Wrap" />

              <Grid Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,12,0,0"
                    ColumnDefinitions="100,170,100,*">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Zobrazit" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding TimelineFilters}"
                          SelectedItem="{Binding SelectedTimelineFilter}"
                          AutomationProperties.Name="Filtr časové osy" />
                <TextBlock Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center" Text="Hledat" />
                <TextBox x:Name="TimelineSearchBox"
                         Grid.Column="3"
                         Margin="12,0,0,0"
                         Text="{Binding TimelineSearchText}"
                         PlaceholderText="Položka, stav nebo poznámka"
                         AutomationProperties.Name="Hledání v časové ose" />
              </Grid>

              <ListBox x:Name="TimelineListBox"
                       Grid.Row="2"
                       Margin="0,12,12,0"
                       ItemsSource="{Binding SelectedVehicleTimeline}"
                       SelectedItem="{Binding SelectedTimelineItem}"
                       AutomationProperties.Name="Časová osa vybraného vozidla">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedTimelineItemCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:VehicleTimelineItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <Grid ColumnDefinitions="110,150,220,*,150">
                        <TextBlock Grid.Column="0" Text="{Binding Date}" />
                        <TextBlock Grid.Column="1" Text="{Binding KindLabel}" />
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="3" Text="{Binding Detail}" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="4" Text="{Binding Status}" TextWrapping="Wrap" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Border Grid.Row="2" Grid.Column="1" Margin="12,12,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail časové osy" />
                  <Button Grid.Row="1"
                          Margin="0,12,0,0"
                          Width="150"
                          HorizontalAlignment="Left"
                          Command="{Binding OpenSelectedTimelineItemCommand}"
                          Content="Otevřít položku"
                          AutomationProperties.Name="Otevřít vybranou položku časové osy v aplikaci" />
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.78"
                             Text="{Binding ExportStatus}"
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="3"
                             Margin="0,12,0,0"
                             Opacity="0.72"
                             Text="Technická kontrola a zelená karta otevřou detail vozidla, ostatní položky přepnou na odpovídající kartu evidence."
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="4" Margin="0,16,0,0" Text="{Binding SelectedTimelineDetail}" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>
          </TabItem>

          <TabItem Header="Doklady">
            <Grid Margin="0,8,0,0" ColumnDefinitions="1.2*,*">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="{Binding RecordSummary}" TextWrapping="Wrap" />
                <ListBox x:Name="RecordListBox"
                         Grid.Row="1"
                         Margin="0,12,12,0"
                         ItemsSource="{Binding SelectedVehicleRecords}"
                         SelectedItem="{Binding SelectedRecord}"
                         AutomationProperties.Name="Doklady vybraného vozidla">
                  <ListBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedRecordFileCommand}" />
                  </ListBox.KeyBindings>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VehicleRecordItemViewModel">
                      <Border Padding="12"
                              Margin="0,0,0,8"
                              Background="#10203040"
                              CornerRadius="6"
                              AutomationProperties.Name="{Binding AccessibleLabel}">
                        <StackPanel Spacing="4">
                          <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                          <TextBlock Opacity="0.82" Text="{Binding RecordType}" />
                          <TextBlock Opacity="0.82" Text="{Binding Provider}" />
                          <TextBlock Opacity="0.82" Text="{Binding Validity}" />
                          <TextBlock Opacity="0.82" Text="{Binding AttachmentMode}" />
                          <TextBlock Opacity="0.72" Text="{Binding AttachmentState}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail dokladu" />
                  <StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal" Spacing="10">
                    <Button Width="150"
                            Command="{Binding OpenSelectedRecordFileCommand}"
                            Content="Otevřít soubor"
                            AutomationProperties.Name="Otevřít soubor přílohy vybraného dokladu" />
                    <Button Width="170"
                            Command="{Binding OpenSelectedRecordFolderCommand}"
                            Content="Otevřít složku"
                            AutomationProperties.Name="Otevřít složku přílohy vybraného dokladu" />
                  </StackPanel>
                  <TextBlock Grid.Row="2" Margin="0,16,0,0" Text="{Binding SelectedRecordDetail}" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>
          </TabItem>

          <TabItem Header="Audit">
            <Grid Margin="0,8,0,0" RowDefinitions="Auto,*">
              <TextBlock Text="{Binding AuditSummary}" TextWrapping="Wrap" />
              <ListBox x:Name="AuditListBox"
                       Grid.Row="1"
                       Margin="0,12,0,0"
                       ItemsSource="{Binding AuditItems}"
                       SelectedItem="{Binding SelectedDashboardAuditItem}"
                       AutomationProperties.Name="Seznam auditních položek">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardAuditItemCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:AuditItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                        <TextBlock Text="{Binding VehicleName}" />
                        <TextBlock Opacity="0.8" Text="{Binding Severity}" />
                        <TextBlock Opacity="0.8" Text="{Binding Category}" />
                        <TextBlock Opacity="0.8" Text="{Binding Message}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </TabItem>

          <TabItem Header="Náklady">
            <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,*">
              <TextBlock Text="{Binding CostSummary}" TextWrapping="Wrap" />
              <TextBlock Grid.Row="1" Margin="0,8,0,0" Opacity="0.75" Text="{Binding CostComparison}" TextWrapping="Wrap" />
              <ListBox x:Name="CostListBox"
                       Grid.Row="2"
                       Margin="0,12,0,0"
                       ItemsSource="{Binding CostVehicles}"
                       SelectedItem="{Binding SelectedDashboardCostVehicle}"
                       AutomationProperties.Name="Seznam nákladových souhrnů vozidel">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardCostVehicleCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:CostVehicleItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*,1.5*">
                        <StackPanel>
                          <TextBlock FontWeight="SemiBold" Text="{Binding VehicleName}" />
                          <TextBlock Opacity="0.8" Text="{Binding Category}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TotalCost}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Distance}" />
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding CostPerKm}" />
                        <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding Status}" TextWrapping="Wrap" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </TabItem>

          <TabItem Header="Dashboard">
            <Grid Margin="0,8,0,0" RowDefinitions="Auto,*" ColumnDefinitions="1.1*,1.1*,1.2*">
              <StackPanel Grid.ColumnSpan="3" Spacing="8">
                <TextBlock Text="{Binding AuditSummary}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.82" Text="{Binding CostSummary}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.75" Text="{Binding CostComparison}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.75" Text="{Binding DashboardTimelineSummary}" TextWrapping="Wrap" />
              </StackPanel>

              <Border Grid.Row="1" Grid.Column="0" Margin="0,16,12,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Nejdůležitější audit" />
                  <Button Grid.Row="1"
                          Margin="0,12,0,0"
                          Width="150"
                          HorizontalAlignment="Left"
                          Command="{Binding OpenSelectedDashboardAuditItemCommand}"
                          Content="Otevřít vozidlo"
                          AutomationProperties.Name="Otevřít vozidlo nebo evidenci z vybrané auditní položky" />
                  <ListBox x:Name="DashboardAuditListBox"
                           Grid.Row="2"
                           Margin="0,12,0,0"
                           ItemsSource="{Binding AuditItems}"
                           SelectedItem="{Binding SelectedDashboardAuditItem}"
                           AutomationProperties.Name="Přehled auditních položek na dashboardu">
                    <ListBox.KeyBindings>
                      <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardAuditItemCommand}" />
                    </ListBox.KeyBindings>
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:AuditItemViewModel">
                        <Border Padding="12"
                                Margin="0,0,0,8"
                                Background="#143A4A5A"
                                CornerRadius="6"
                                AutomationProperties.Name="{Binding AccessibleLabel}">
                          <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                            <TextBlock Text="{Binding VehicleName}" />
                            <TextBlock Opacity="0.8" Text="{Binding Severity}" />
                            <TextBlock Opacity="0.8" Text="{Binding Message}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>

              <Border Grid.Row="1" Grid.Column="1" Margin="0,16,12,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Náklady vozidel" />
                  <Button Grid.Row="1"
                          Margin="0,12,0,0"
                          Width="150"
                          HorizontalAlignment="Left"
                          Command="{Binding OpenSelectedDashboardCostVehicleCommand}"
                          Content="Vybrat vozidlo"
                          AutomationProperties.Name="Vybrat vozidlo z nákladového přehledu" />
                  <ListBox x:Name="DashboardCostListBox"
                           Grid.Row="2"
                           Margin="0,12,0,0"
                           ItemsSource="{Binding CostVehicles}"
                           SelectedItem="{Binding SelectedDashboardCostVehicle}"
                           AutomationProperties.Name="Přehled nákladových položek na dashboardu">
                    <ListBox.KeyBindings>
                      <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardCostVehicleCommand}" />
                    </ListBox.KeyBindings>
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:CostVehicleItemViewModel">
                        <Border Padding="12"
                                Margin="0,0,0,8"
                                Background="#143A4A5A"
                                CornerRadius="6"
                                AutomationProperties.Name="{Binding AccessibleLabel}">
                          <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding VehicleName}" />
                            <TextBlock Opacity="0.8" Text="{Binding Category}" />
                            <TextBlock Opacity="0.8" Text="{Binding TotalCost}" />
                            <TextBlock Opacity="0.8" Text="{Binding CostPerKm}" />
                            <TextBlock Opacity="0.8" Text="{Binding Status}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>

              <Border Grid.Row="1" Grid.Column="2" Margin="0,16,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Nejbližší termíny" />
                  <Button Grid.Row="1"
                          Margin="0,12,0,0"
                          Width="150"
                          HorizontalAlignment="Left"
                          Command="{Binding OpenSelectedDashboardTimelineItemCommand}"
                          Content="Otevřít položku"
                          AutomationProperties.Name="Otevřít vybraný termín z dashboardu" />
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.75"
                             Text="{Binding SelectedDashboardTimelineDetail}"
                             TextWrapping="Wrap" />
                  <ListBox x:Name="DashboardTimelineListBox"
                           Grid.Row="3"
                           Margin="0,12,0,0"
                           ItemsSource="{Binding DashboardUpcomingTimeline}"
                           SelectedItem="{Binding SelectedDashboardTimelineItem}"
                           AutomationProperties.Name="Nejbližší termíny napříč vozidly">
                    <ListBox.KeyBindings>
                      <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardTimelineItemCommand}" />
                    </ListBox.KeyBindings>
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:VehicleTimelineItemViewModel">
                        <Border Padding="12"
                                Margin="0,0,0,8"
                                Background="#143A4A5A"
                                CornerRadius="6"
                                AutomationProperties.Name="{Binding AccessibleLabel}">
                          <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                            <TextBlock Text="{Binding VehicleName}" />
                            <TextBlock Opacity="0.8" Text="{Binding Date}" />
                            <TextBlock Opacity="0.8" Text="{Binding KindLabel}" />
                            <TextBlock Opacity="0.8" Text="{Binding Status}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>
            </Grid>
          </TabItem>
        </TabControl>
      </Border>
    </Grid>

    <TextBlock Grid.Row="4"
               Margin="0,16,0,0"
               Opacity="0.75"
               Text="C# větev už nad stejnými legacy daty jako AHK verze zobrazuje detail vozidla, historii, tankování, doklady, připomínky, údržbu, časovou osu, audit, náklady i první dashboard."
               TextWrapping="Wrap" />
  </Grid>
</Window>
