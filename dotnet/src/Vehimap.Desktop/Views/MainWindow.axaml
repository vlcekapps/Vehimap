<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1400"
        Height="920"
        MinWidth="1120"
        MinHeight="760"
        Title="{Binding Title}"
        AutomationProperties.Name="Vehimap Desktop Preview"
        AutomationProperties.HelpText="Multiplatformní preview Vehimapu. Po otevření je fokus v seznamu vozidel vlevo.">
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportCalendarCommand}" />
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusTimelineSearchCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+F" Command="{Binding FocusGlobalSearchCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+T" Command="{Binding FocusUpcomingOverviewCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+D" Command="{Binding FocusOverdueOverviewCommand}" />
  </Window.KeyBindings>
  <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*,Auto">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="28"
                   FontWeight="SemiBold"
                   Text="{Binding Title}" />
        <TextBlock Opacity="0.75"
                   Text="{Binding Subtitle}" />
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="10"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center">
        <Button Width="135"
                Height="34"
                Click="OnBackupExportClick"
                Content="Export dat"
                AutomationProperties.Name="Exportovat data aplikace do zálohy" />
        <Button Width="135"
                Height="34"
                Click="OnBackupImportClick"
                Content="Obnovit data"
                AutomationProperties.Name="Obnovit data aplikace ze zálohy" />
        <Button Width="110"
                Height="34"
                Click="OnSettingsClick"
                Content="Nastavení"
                AutomationProperties.Name="Otevřít nastavení aplikace" />
        <Button Width="120"
                Height="34"
                Click="OnAboutClick"
                Content="O programu"
                AutomationProperties.Name="Otevřít dialog O programu" />
        <Button Width="140"
                Height="34"
                Click="OnUpdateCheckClick"
                Content="Aktualizace"
                AutomationProperties.Name="Zkontrolovat aktualizace aplikace" />
        <Button Width="150"
                Height="34"
                Command="{Binding ExportCalendarCommand}"
                Content="Exportovat .ics"
                AutomationProperties.Name="Exportovat budoucí termíny do kalendáře" />
        <Button Width="120"
                Height="34"
                Command="{Binding ReloadCommand}"
                Content="Načíst znovu"
                AutomationProperties.Name="Znovu načíst legacy data" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1"
          Margin="0,18,0,0"
          ColumnDefinitions="180,*"
          RowDefinitions="Auto,Auto,Auto,Auto">
      <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Režim dat" />
      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DataMode}" />
      <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="Datová složka" />
      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DataPath}" TextWrapping="Wrap" />
      <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Foreground="IndianRed" Text="{Binding LoadError}" TextWrapping="Wrap" />
      <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8,0,0" Text="{Binding ShellStatus}" TextWrapping="Wrap" />
    </Grid>

    <Grid Grid.Row="2"
          Margin="0,18,0,0"
          ColumnDefinitions="*,*,*,*,*,*,*">
      <Border Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Vozidla" />
          <TextBlock FontSize="22" Text="{Binding VehicleCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Historie" />
          <TextBlock FontSize="22" Text="{Binding HistoryCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Tankování" />
          <TextBlock FontSize="22" Text="{Binding FuelCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="3" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Doklady" />
          <TextBlock FontSize="22" Text="{Binding RecordsCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="4" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Připomínky" />
          <TextBlock FontSize="22" Text="{Binding RemindersCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="5" Margin="0,0,8,0" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Údržba" />
          <TextBlock FontSize="22" Text="{Binding MaintenanceCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="6" Padding="12" Background="#143A4A5A" CornerRadius="8">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Audit" />
          <TextBlock FontSize="22" Text="{Binding AuditCount}" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.Row="3" Margin="0,18,0,0" ColumnDefinitions="420,*">
      <Border Padding="16" BorderBrush="#304050" BorderThickness="1" CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="Načtená vozidla z legacy dat" />
          <ListBox x:Name="VehicleListBox"
                   Grid.Row="1"
                   Margin="0,12,0,0"
                   ItemsSource="{Binding Vehicles}"
                   SelectedItem="{Binding SelectedVehicle}"
                   AutomationProperties.Name="Seznam načtených vozidel"
                   AutomationProperties.HelpText="Šipkami vyberte vozidlo. Detail a související evidence se zobrazí vpravo.">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:VehicleListItemViewModel">
                <Border Padding="10"
                        Margin="0,0,0,8"
                        Background="#10203040"
                        CornerRadius="6"
                        AutomationProperties.Name="{Binding AccessibleLabel}">
                  <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                    <TextBlock Opacity="0.82" Text="{Binding MakeModel}" />
                    <TextBlock Opacity="0.82" Text="{Binding Category}" />
                    <TextBlock Opacity="0.82" Text="{Binding Plate}" />
                    <TextBlock Opacity="0.72" Text="{Binding StatusSummary}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1" Margin="16,0,0,0" Padding="16" BorderBrush="#304050" BorderThickness="1" CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <Grid RowDefinitions="Auto,Auto">
            <TextBlock FontWeight="SemiBold"
                       Text="Hlavní pracovní karty vybraného vozidla" />
            <WrapPanel Grid.Row="1"
                       Margin="0,12,0,0"
                       AutomationProperties.Name="Hlavní pracovní karty vybraného vozidla"
                       AutomationProperties.HelpText="Tabem přejdete na právě vybranou kartu. Šipkami vlevo a vpravo můžete změnit kartu.">
              <RadioButton x:Name="DetailTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsDetailTabSelected}"
                      IsTabStop="{Binding IsDetailTabSelected}"
                      Tag="0"
                      Click="OnTabHeaderClick"
                      Content="Detail"
                      AutomationProperties.Name="Karta Detail" />
              <RadioButton x:Name="HistoryTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsHistoryTabSelected}"
                      IsTabStop="{Binding IsHistoryTabSelected}"
                      Tag="1"
                      Click="OnTabHeaderClick"
                      Content="Historie"
                      AutomationProperties.Name="Karta Historie" />
              <RadioButton x:Name="FuelTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsFuelTabSelected}"
                      IsTabStop="{Binding IsFuelTabSelected}"
                      Tag="2"
                      Click="OnTabHeaderClick"
                      Content="Tankování"
                      AutomationProperties.Name="Karta Tankování" />
              <RadioButton x:Name="ReminderTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsReminderTabSelected}"
                      IsTabStop="{Binding IsReminderTabSelected}"
                      Tag="3"
                      Click="OnTabHeaderClick"
                      Content="Připomínky"
                      AutomationProperties.Name="Karta Připomínky" />
              <RadioButton x:Name="MaintenanceTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsMaintenanceTabSelected}"
                      IsTabStop="{Binding IsMaintenanceTabSelected}"
                      Tag="4"
                      Click="OnTabHeaderClick"
                      Content="Údržba"
                      AutomationProperties.Name="Karta Údržba" />
              <RadioButton x:Name="TimelineTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsTimelineTabSelected}"
                      IsTabStop="{Binding IsTimelineTabSelected}"
                      Tag="5"
                      Click="OnTabHeaderClick"
                      Content="Časová osa"
                      AutomationProperties.Name="Karta Časová osa" />
              <RadioButton x:Name="RecordTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsRecordTabSelected}"
                      IsTabStop="{Binding IsRecordTabSelected}"
                      Tag="6"
                      Click="OnTabHeaderClick"
                      Content="Doklady"
                      AutomationProperties.Name="Karta Doklady" />
              <RadioButton x:Name="AuditTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsAuditTabSelected}"
                      IsTabStop="{Binding IsAuditTabSelected}"
                      Tag="7"
                      Click="OnTabHeaderClick"
                      Content="Audit"
                      AutomationProperties.Name="Karta Audit" />
              <RadioButton x:Name="CostTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsCostTabSelected}"
                      IsTabStop="{Binding IsCostTabSelected}"
                      Tag="8"
                      Click="OnTabHeaderClick"
                      Content="Náklady"
                      AutomationProperties.Name="Karta Náklady" />
              <RadioButton x:Name="DashboardTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsDashboardTabSelected}"
                      IsTabStop="{Binding IsDashboardTabSelected}"
                      Tag="9"
                      Click="OnTabHeaderClick"
                      Content="Dashboard"
                      AutomationProperties.Name="Karta Dashboard" />
              <RadioButton x:Name="SearchTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsSearchTabSelected}"
                      IsTabStop="{Binding IsSearchTabSelected}"
                      Tag="10"
                      Click="OnTabHeaderClick"
                      Content="Hledání"
                      AutomationProperties.Name="Karta Hledání" />
              <RadioButton x:Name="UpcomingOverviewTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsUpcomingOverviewTabSelected}"
                      IsTabStop="{Binding IsUpcomingOverviewTabSelected}"
                      Tag="11"
                      Click="OnTabHeaderClick"
                      Content="Termíny"
                      AutomationProperties.Name="Karta Termíny" />
              <RadioButton x:Name="OverdueOverviewTabButton"
                      Classes="tab-header"
                      GroupName="VehicleTabs"
                      IsChecked="{Binding IsOverdueOverviewTabSelected}"
                      IsTabStop="{Binding IsOverdueOverviewTabSelected}"
                      Tag="12"
                      Click="OnTabHeaderClick"
                      Content="Propadlé"
                      AutomationProperties.Name="Karta Propadlé termíny" />
            </WrapPanel>
          </Grid>

          <Grid Grid.Row="1"
                Margin="0,16,0,0"
                AutomationProperties.Name="Obsah vybrané hlavní pracovní karty"
                AutomationProperties.HelpText="Obsah se mění podle zvolené karty nahoře.">
            <Grid IsVisible="{Binding IsDetailTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,*">
              <Button Width="128"
                      HorizontalAlignment="Left"
                      Click="OnOpenVehicleDetailWindowClick"
                      IsEnabled="{Binding CanOpenVehicleDetailWindow}"
                      Content="V okně"
                      AutomationProperties.Name="Otevřít detail vozidla v samostatném okně" />
              <workspaces:VehicleDetailWorkspaceView Grid.Row="1"
                                                    Margin="0,16,0,0"
                                                    DataContext="{Binding VehicleDetailWorkspace}" />
            </Grid>

            <Grid IsVisible="{Binding IsHistoryTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,*">
              <Button Width="128"
                      HorizontalAlignment="Left"
                      Click="OnOpenHistoryWindowClick"
                      IsEnabled="{Binding CanOpenHistoryWindow}"
                      Content="V okně"
                      AutomationProperties.Name="Otevřít historii v samostatném okně" />
              <workspaces:HistoryWorkspaceView Grid.Row="1"
                                              Margin="0,16,0,0"
                                              DataContext="{Binding HistoryWorkspace}" />
            </Grid>

            <Grid IsVisible="{Binding IsFuelTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,*">
              <Button Width="128"
                      HorizontalAlignment="Left"
                      Click="OnOpenFuelWindowClick"
                      IsEnabled="{Binding CanOpenFuelWindow}"
                      Content="V okně"
                      AutomationProperties.Name="Otevřít tankování v samostatném okně" />
              <workspaces:FuelWorkspaceView Grid.Row="1"
                                           Margin="0,16,0,0"
                                           DataContext="{Binding FuelWorkspace}" />
            </Grid>

            <Grid IsVisible="{Binding IsReminderTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,*">
              <Button Width="128"
                      HorizontalAlignment="Left"
                      Click="OnOpenRemindersWindowClick"
                      IsEnabled="{Binding CanOpenReminderWindow}"
                      Content="V okně"
                      AutomationProperties.Name="Otevřít připomínky v samostatném okně" />
              <workspaces:ReminderWorkspaceView Grid.Row="1"
                                               Margin="0,16,0,0"
                                               DataContext="{Binding ReminderWorkspace}" />
            </Grid>

            <Grid IsVisible="{Binding IsMaintenanceTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,*">
              <Button Width="128"
                      HorizontalAlignment="Left"
                      Click="OnOpenMaintenanceWindowClick"
                      IsEnabled="{Binding CanOpenMaintenanceWindow}"
                      Content="V okně"
                      AutomationProperties.Name="Otevřít plán údržby v samostatném okně" />
              <workspaces:MaintenanceWorkspaceView Grid.Row="1"
                                                  Margin="0,16,0,0"
                                                  DataContext="{Binding MaintenanceWorkspace}" />
            </Grid>

            <Grid IsVisible="{Binding IsTimelineTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.35*,*">
              <TextBlock Grid.ColumnSpan="2" Text="{Binding TimelineSummary}" TextWrapping="Wrap" />

              <Grid Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,12,0,0"
                    ColumnDefinitions="100,170,100,*">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Zobrazit" />
                <ComboBox x:Name="TimelineFilterComboBox"
                          Grid.Column="1"
                          ItemsSource="{Binding TimelineFilters}"
                          SelectedItem="{Binding SelectedTimelineFilter}"
                          AutomationProperties.Name="Filtr časové osy" />
                <TextBlock Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center" Text="Hledat" />
                <TextBox x:Name="TimelineSearchBox"
                         Grid.Column="3"
                         Margin="12,0,0,0"
                         Text="{Binding TimelineSearchText}"
                         PlaceholderText="Položka, stav nebo poznámka"
                         AutomationProperties.Name="Hledání v časové ose" />
              </Grid>

              <ListBox x:Name="TimelineListBox"
                       Grid.Row="2"
                       Margin="0,12,12,0"
                       ItemsSource="{Binding SelectedVehicleTimeline}"
                       SelectedItem="{Binding SelectedTimelineItem}"
                       AutomationProperties.Name="Časová osa vybraného vozidla">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedTimelineItemCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:VehicleTimelineItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <Grid ColumnDefinitions="110,150,220,*,150">
                        <TextBlock Grid.Column="0" Text="{Binding Date}" />
                        <TextBlock Grid.Column="1" Text="{Binding KindLabel}" />
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="3" Text="{Binding Detail}" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="4" Text="{Binding Status}" TextWrapping="Wrap" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Border Grid.Row="2" Grid.Column="1" Margin="12,12,0,0" Padding="16" Background="#10203040" CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail časové osy" />
                  <Button Grid.Row="1"
                          x:Name="TimelineOpenButton"
                          Margin="0,12,0,0"
                          Width="150"
                          HorizontalAlignment="Left"
                          Command="{Binding OpenSelectedTimelineItemCommand}"
                          Content="Otevřít položku"
                          AutomationProperties.Name="Otevřít vybranou položku časové osy v aplikaci" />
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.78"
                             Text="{Binding ExportStatus}"
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="3"
                             Margin="0,12,0,0"
                             Opacity="0.72"
                             Text="Technická kontrola a zelená karta otevřou detail vozidla, ostatní položky přepnou na odpovídající kartu evidence."
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="4" Margin="0,16,0,0" Text="{Binding SelectedTimelineDetail}" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>

            <Grid IsVisible="{Binding IsRecordTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,*">
              <Button Width="128"
                      HorizontalAlignment="Left"
                      Click="OnOpenRecordsWindowClick"
                      IsEnabled="{Binding CanOpenRecordWindow}"
                      Content="V okně"
                      AutomationProperties.Name="Otevřít doklady v samostatném okně" />
              <workspaces:RecordWorkspaceView Grid.Row="1"
                                             Margin="0,16,0,0"
                                             DataContext="{Binding RecordWorkspace}" />
            </Grid>

            <Grid IsVisible="{Binding IsAuditTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,*">
              <Button Width="128"
                      HorizontalAlignment="Left"
                      Click="OnOpenAuditWindowClick"
                      Content="V okně"
                      AutomationProperties.Name="Otevřít audit v samostatném okně" />
              <workspaces:AuditWorkspaceView Grid.Row="1"
                                            Margin="0,16,0,0"
                                            DataContext="{Binding AuditWorkspace}" />
            </Grid>

            <Grid IsVisible="{Binding IsCostTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,Auto,*">
              <TextBlock Text="{Binding CostSummary}" TextWrapping="Wrap" />
              <TextBlock Grid.Row="1" Margin="0,8,0,0" Opacity="0.75" Text="{Binding CostComparison}" TextWrapping="Wrap" />
              <ListBox x:Name="CostListBox"
                       Grid.Row="2"
                       Margin="0,12,0,0"
                       ItemsSource="{Binding CostVehicles}"
                       SelectedItem="{Binding SelectedDashboardCostVehicle}"
                       AutomationProperties.Name="Seznam nákladových souhrnů vozidel">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardCostVehicleCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:CostVehicleItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*,1.5*">
                        <StackPanel>
                          <TextBlock FontWeight="SemiBold" Text="{Binding VehicleName}" />
                          <TextBlock Opacity="0.8" Text="{Binding Category}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TotalCost}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Distance}" />
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding CostPerKm}" />
                        <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding Status}" TextWrapping="Wrap" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>

            <Grid IsVisible="{Binding IsDashboardTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,*">
              <Button Width="128"
                      HorizontalAlignment="Left"
                      Click="OnOpenDashboardWindowClick"
                      Content="V okně"
                      AutomationProperties.Name="Otevřít dashboard v samostatném okně" />
              <workspaces:DashboardWorkspaceView Grid.Row="1"
                                                Margin="0,16,0,0"
                                                DataContext="{Binding DashboardWorkspace}" />
            </Grid>

            <Grid IsVisible="{Binding IsSearchTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.25*,*">
              <TextBlock Grid.ColumnSpan="2"
                         Text="{Binding GlobalSearchSummary}"
                         TextWrapping="Wrap" />
              <Grid Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,12,0,0"
                    ColumnDefinitions="100,*,150">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Hledat" />
                <TextBox x:Name="GlobalSearchTextBox"
                         Grid.Column="1"
                         Margin="12,0,0,0"
                         Text="{Binding GlobalSearchText}"
                         PlaceholderText="Vozidlo, SPZ, doklad, připomínka, údržba..."
                         AutomationProperties.Name="Globální hledání ve Vehimapu" />
                <Button Grid.Column="2"
                        x:Name="SearchOpenButton"
                        Margin="12,0,0,0"
                        Width="150"
                        Command="{Binding OpenSelectedSearchResultCommand}"
                        Content="Otevřít položku"
                        AutomationProperties.Name="Otevřít vybraný výsledek hledání" />
              </Grid>

              <ListBox x:Name="SearchResultsListBox"
                       Grid.Row="2"
                       Margin="0,12,12,0"
                       ItemsSource="{Binding GlobalSearchResults}"
                       SelectedItem="{Binding SelectedSearchResult}"
                       AutomationProperties.Name="Výsledky globálního hledání">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedSearchResultCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:GlobalSearchResultItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                        <TextBlock Opacity="0.82" Text="{Binding SectionLabel}" />
                        <TextBlock Opacity="0.82" Text="{Binding VehicleName}" />
                        <TextBlock Opacity="0.72" Text="{Binding Summary}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Border Grid.Row="2"
                      Grid.Column="1"
                      Margin="12,12,0,0"
                      Padding="16"
                      Background="#10203040"
                      CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail výsledku" />
                  <TextBlock Grid.Row="1"
                             Margin="0,12,0,0"
                             Opacity="0.75"
                             Text="Enter nebo tlačítko otevře rovnou správné vozidlo nebo evidenci."
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="2"
                             Margin="0,16,0,0"
                             Text="{Binding SelectedSearchResultDetail}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>

            <Grid IsVisible="{Binding IsUpcomingOverviewTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.25*,*">
              <TextBlock Grid.ColumnSpan="2"
                         Text="{Binding UpcomingOverviewSummary}"
                         TextWrapping="Wrap" />
              <Grid Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,12,0,0"
                    ColumnDefinitions="100,*,130,170,150">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Hledat" />
                <TextBox x:Name="UpcomingOverviewSearchBox"
                         Grid.Column="1"
                         Margin="12,0,0,0"
                         Text="{Binding UpcomingOverviewSearchText}"
                         PlaceholderText="Vozidlo, SPZ, termín nebo položka..."
                         AutomationProperties.Name="Hledání v přehledu blížících se termínů" />
                <TextBlock Grid.Column="2"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Text="Filtrovat" />
                <ComboBox x:Name="UpcomingOverviewFilterComboBox"
                          Grid.Column="3"
                          Margin="12,0,0,0"
                          ItemsSource="{Binding OverviewFilters}"
                          SelectedItem="{Binding SelectedUpcomingOverviewFilter}"
                          AutomationProperties.Name="Filtr přehledu blížících se termínů" />
                <Button Grid.Column="4"
                        x:Name="UpcomingOverviewOpenButton"
                        Margin="12,0,0,0"
                        Width="150"
                        Command="{Binding OpenSelectedUpcomingOverviewItemCommand}"
                        Content="Otevřít položku"
                        AutomationProperties.Name="Otevřít vybraný blížící se termín" />
              </Grid>

              <ListBox x:Name="UpcomingOverviewListBox"
                       Grid.Row="2"
                       Margin="0,12,12,0"
                       ItemsSource="{Binding UpcomingOverviewItems}"
                       SelectedItem="{Binding SelectedUpcomingOverviewItem}"
                       AutomationProperties.Name="Přehled blížících se termínů napříč vozidly">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedUpcomingOverviewItemCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:VehicleTimelineItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <Grid ColumnDefinitions="110,140,150,*">
                        <TextBlock Grid.Column="0" Text="{Binding Date}" />
                        <TextBlock Grid.Column="1" Text="{Binding KindLabel}" />
                        <TextBlock Grid.Column="2" Text="{Binding VehicleName}" />
                        <StackPanel Grid.Column="3" Spacing="4">
                          <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                          <TextBlock Opacity="0.82" Text="{Binding Detail}" TextWrapping="Wrap" />
                          <TextBlock Opacity="0.72" Text="{Binding Status}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Border Grid.Row="2"
                      Grid.Column="1"
                      Margin="12,12,0,0"
                      Padding="16"
                      Background="#10203040"
                      CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail termínu" />
                  <WrapPanel Grid.Row="1" Margin="0,12,0,0" ItemWidth="150" ItemHeight="34">
                    <Button Command="{Binding OpenSelectedUpcomingOverviewVehicleCommand}"
                            Content="Zobrazit vozidlo"
                            AutomationProperties.Name="Zobrazit vozidlo k vybranému blížícímu se termínu" />
                    <Button Command="{Binding OpenSelectedUpcomingOverviewItemCommand}"
                            Content="Otevřít položku"
                            AutomationProperties.Name="Otevřít evidenci vybraného blížícího se termínu" />
                  </WrapPanel>
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.75"
                             Text="Přehled termínů ukazuje všechny blížící se technické kontroly, zelené karty, připomínky, doklady a servisní úkoly s datem."
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="3"
                             Margin="0,16,0,0"
                             Text="{Binding SelectedUpcomingOverviewDetail}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>

            <Grid IsVisible="{Binding IsOverdueOverviewTabSelected}" Margin="0,8,0,0" RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.25*,*">
              <TextBlock Grid.ColumnSpan="2"
                         Text="{Binding OverdueOverviewSummary}"
                         TextWrapping="Wrap" />
              <Grid Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,12,0,0"
                    ColumnDefinitions="100,*,130,170,150">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Hledat" />
                <TextBox x:Name="OverdueOverviewSearchBox"
                         Grid.Column="1"
                         Margin="12,0,0,0"
                         Text="{Binding OverdueOverviewSearchText}"
                         PlaceholderText="Vozidlo, SPZ, termín nebo položka..."
                         AutomationProperties.Name="Hledání v přehledu propadlých termínů" />
                <TextBlock Grid.Column="2"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Text="Filtrovat" />
                <ComboBox x:Name="OverdueOverviewFilterComboBox"
                          Grid.Column="3"
                          Margin="12,0,0,0"
                          ItemsSource="{Binding OverviewFilters}"
                          SelectedItem="{Binding SelectedOverdueOverviewFilter}"
                          AutomationProperties.Name="Filtr přehledu propadlých termínů" />
                <Button Grid.Column="4"
                        x:Name="OverdueOverviewOpenButton"
                        Margin="12,0,0,0"
                        Width="150"
                        Command="{Binding OpenSelectedOverdueOverviewItemCommand}"
                        Content="Otevřít položku"
                        AutomationProperties.Name="Otevřít vybraný propadlý termín" />
              </Grid>

              <ListBox x:Name="OverdueOverviewListBox"
                       Grid.Row="2"
                       Margin="0,12,12,0"
                       ItemsSource="{Binding OverdueOverviewItems}"
                       SelectedItem="{Binding SelectedOverdueOverviewItem}"
                       AutomationProperties.Name="Přehled propadlých termínů napříč vozidly">
                <ListBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedOverdueOverviewItemCommand}" />
                </ListBox.KeyBindings>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:VehicleTimelineItemViewModel">
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#10203040"
                            CornerRadius="6"
                            AutomationProperties.Name="{Binding AccessibleLabel}">
                      <Grid ColumnDefinitions="110,140,150,*">
                        <TextBlock Grid.Column="0" Text="{Binding Date}" />
                        <TextBlock Grid.Column="1" Text="{Binding KindLabel}" />
                        <TextBlock Grid.Column="2" Text="{Binding VehicleName}" />
                        <StackPanel Grid.Column="3" Spacing="4">
                          <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                          <TextBlock Opacity="0.82" Text="{Binding Detail}" TextWrapping="Wrap" />
                          <TextBlock Opacity="0.72" Text="{Binding Status}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Border Grid.Row="2"
                      Grid.Column="1"
                      Margin="12,12,0,0"
                      Padding="16"
                      Background="#10203040"
                      CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail propadlého termínu" />
                  <WrapPanel Grid.Row="1" Margin="0,12,0,0" ItemWidth="150" ItemHeight="34">
                    <Button Command="{Binding OpenSelectedOverdueOverviewVehicleCommand}"
                            Content="Zobrazit vozidlo"
                            AutomationProperties.Name="Zobrazit vozidlo k vybranému propadlému termínu" />
                    <Button Command="{Binding OpenSelectedOverdueOverviewItemCommand}"
                            Content="Otevřít položku"
                            AutomationProperties.Name="Otevřít evidenci vybraného propadlého termínu" />
                  </WrapPanel>
                  <TextBlock Grid.Row="2"
                             Margin="0,12,0,0"
                             Opacity="0.75"
                             Text="Propadlé termíny vám pomohou rychle projít všechny záznamy, které už jsou po termínu a vyžadují zásah."
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="3"
                             Margin="0,16,0,0"
                             Text="{Binding SelectedOverdueOverviewDetail}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <TextBlock Grid.Row="4"
               Margin="0,16,0,0"
               Opacity="0.75"
               Text="C# větev už nad stejnými legacy daty jako AHK verze zobrazuje detail vozidla, historii, tankování, doklady, připomínky, údržbu, časovou osu, audit, náklady, dashboard, globální hledání i přehled termínů. Připomínky, doklady, historii, tankování i plán údržby už lze také přímo upravovat."
               TextWrapping="Wrap" />
  </Grid>
</Window>
