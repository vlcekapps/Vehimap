<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.FuelWindow"
        x:DataType="vm:FuelWorkspaceViewModel"
        Width="1360"
        Height="820"
        MinWidth="1100"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="Tankování vozidla"
        AutomationProperties.AutomationId="FuelWindow"
        AutomationProperties.HelpText="Samostatné okno pro práci s tankováním vybraného vozidla.">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}" />
        <TextBlock Opacity="0.78"
                   Text="{Binding FuelSummary}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              x:Name="CloseFuelWindowButton"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="Zavřít"
              AutomationProperties.Name="Zavřít okno tankování"
              AutomationProperties.AutomationId="CloseFuelWindowButton" />
    </Grid>

    <workspaces:FuelWorkspaceView x:Name="FuelWorkspaceHost"
                                  Grid.Row="1"
                                  Margin="0,18,0,0" />
  </Grid>
</Window>
