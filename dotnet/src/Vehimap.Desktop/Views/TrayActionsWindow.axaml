<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.TrayActionsWindow"
        x:DataType="vm:TrayActionsDialogViewModel"
        Width="520"
        Height="560"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Title="{Binding Title}"
        AutomationProperties.Name="Akce Vehimapu na liště"
        AutomationProperties.AutomationId="TrayActionsWindow"
        AutomationProperties.HelpText="Vyberte akci pro běžící Vehimap. První tlačítko po otevření zobrazí hlavní okno aplikace; další tlačítka otevřou přehledy, nejbližší termíny, filtrované kontroly nebo souborové akce. Escape okno zavře bez akce.">
  <Border Margin="16" Padding="20" Background="#1C2B38" CornerRadius="10">
    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
      <TextBlock FontSize="22"
                 FontWeight="SemiBold"
                 Text="{Binding Title}"
                 TextWrapping="Wrap" />
      <TextBlock Grid.Row="1"
                 Opacity="0.82"
                 Text="{Binding Description}"
                 TextWrapping="Wrap" />
      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10">
          <TextBlock FontWeight="SemiBold" Text="Aplikace a přehledy" />
          <Button x:Name="ShowMainWindowTrayActionButton"
                  Click="OnShowMainWindowClick"
                  Content="{Binding ShowMainWindowLabel}"
                  IsEnabled="{Binding CanShowMainWindow}"
                  AutomationProperties.Name="Zobrazit hlavní okno Vehimapu"
                  AutomationProperties.AutomationId="ShowMainWindowTrayActionButton" />
          <Button x:Name="ShowDashboardTrayActionButton"
                  Click="OnShowDashboardClick"
                  Content="{Binding ShowDashboardLabel}"
                  IsEnabled="{Binding CanShowDashboard}"
                  AutomationProperties.Name="Otevřít dashboard Vehimapu"
                  AutomationProperties.AutomationId="ShowDashboardTrayActionButton" />
          <Button x:Name="ShowUpcomingOverviewTrayActionButton"
                  Click="OnShowUpcomingOverviewClick"
                  Content="{Binding ShowUpcomingOverviewLabel}"
                  IsEnabled="{Binding CanShowUpcomingOverview}"
                  AutomationProperties.Name="Otevřít přehled blížících se termínů"
                  AutomationProperties.AutomationId="ShowUpcomingOverviewTrayActionButton" />
          <Button x:Name="ShowOverdueOverviewTrayActionButton"
                  Click="OnShowOverdueOverviewClick"
                  Content="{Binding ShowOverdueOverviewLabel}"
                  IsEnabled="{Binding CanShowOverdueOverview}"
                  AutomationProperties.Name="Otevřít přehled propadlých termínů"
                  AutomationProperties.AutomationId="ShowOverdueOverviewTrayActionButton" />
          <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Nejbližší položky" />
          <Button x:Name="OpenNearestTechnicalTrayActionButton"
                  Click="OnOpenNearestTechnicalClick"
                  Content="{Binding OpenNearestTechnicalLabel}"
                  IsEnabled="{Binding CanOpenNearestTechnical}"
                  AutomationProperties.Name="Otevřít nejbližší technickou kontrolu"
                  AutomationProperties.AutomationId="OpenNearestTechnicalTrayActionButton" />
          <Button x:Name="OpenNearestGreenCardTrayActionButton"
                  Click="OnOpenNearestGreenCardClick"
                  Content="{Binding OpenNearestGreenCardLabel}"
                  IsEnabled="{Binding CanOpenNearestGreenCard}"
                  AutomationProperties.Name="Otevřít nejbližší zelenou kartu"
                  AutomationProperties.AutomationId="OpenNearestGreenCardTrayActionButton" />
          <Button x:Name="OpenNearestReminderTrayActionButton"
                  Click="OnOpenNearestReminderClick"
                  Content="{Binding OpenNearestReminderLabel}"
                  IsEnabled="{Binding CanOpenNearestReminder}"
                  AutomationProperties.Name="Otevřít nejbližší vlastní připomínku"
                  AutomationProperties.AutomationId="OpenNearestReminderTrayActionButton" />
          <Button x:Name="OpenNearestMaintenanceTrayActionButton"
                  Click="OnOpenNearestMaintenanceClick"
                  Content="{Binding OpenNearestMaintenanceLabel}"
                  IsEnabled="{Binding CanOpenNearestMaintenance}"
                  AutomationProperties.Name="Otevřít nejbližší servisní úkon"
                  AutomationProperties.AutomationId="OpenNearestMaintenanceTrayActionButton" />
          <Button x:Name="OpenNearestRecordTrayActionButton"
                  Click="OnOpenNearestRecordClick"
                  Content="{Binding OpenNearestRecordLabel}"
                  IsEnabled="{Binding CanOpenNearestRecord}"
                  AutomationProperties.Name="Otevřít nejbližší doklad"
                  AutomationProperties.AutomationId="OpenNearestRecordTrayActionButton" />
          <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Filtrované kontroly" />
          <Button x:Name="ReviewTechnicalTrayActionButton"
                  Click="OnReviewTechnicalClick"
                  Content="{Binding ReviewTechnicalLabel}"
                  IsEnabled="{Binding CanReviewTechnical}"
                  AutomationProperties.Name="Zkontrolovat technické kontroly"
                  AutomationProperties.AutomationId="ReviewTechnicalTrayActionButton" />
          <Button x:Name="ReviewGreenCardsTrayActionButton"
                  Click="OnReviewGreenCardsClick"
                  Content="{Binding ReviewGreenCardsLabel}"
                  IsEnabled="{Binding CanReviewGreenCards}"
                  AutomationProperties.Name="Zkontrolovat zelené karty"
                  AutomationProperties.AutomationId="ReviewGreenCardsTrayActionButton" />
          <Button x:Name="ReviewRemindersTrayActionButton"
                  Click="OnReviewRemindersClick"
                  Content="{Binding ReviewRemindersLabel}"
                  IsEnabled="{Binding CanReviewReminders}"
                  AutomationProperties.Name="Zkontrolovat vlastní připomínky"
                  AutomationProperties.AutomationId="ReviewRemindersTrayActionButton" />
          <Button x:Name="ReviewMaintenanceTrayActionButton"
                  Click="OnReviewMaintenanceClick"
                  Content="{Binding ReviewMaintenanceLabel}"
                  IsEnabled="{Binding CanReviewMaintenance}"
                  AutomationProperties.Name="Zkontrolovat plán údržby"
                  AutomationProperties.AutomationId="ReviewMaintenanceTrayActionButton" />
          <Button x:Name="ReviewRecordsTrayActionButton"
                  Click="OnReviewRecordsClick"
                  Content="{Binding ReviewRecordsLabel}"
                  IsEnabled="{Binding CanReviewRecords}"
                  AutomationProperties.Name="Zkontrolovat doklady"
                  AutomationProperties.AutomationId="ReviewRecordsTrayActionButton" />
          <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Soubor a nastavení" />
          <Button x:Name="OpenPrintableReportTrayActionButton"
                  Click="OnOpenPrintableReportClick"
                  Content="{Binding OpenPrintableReportLabel}"
                  IsEnabled="{Binding CanOpenPrintableReport}"
                  AutomationProperties.Name="Otevřít tiskový přehled vozidel"
                  AutomationProperties.AutomationId="OpenPrintableReportTrayActionButton" />
          <Button x:Name="ExportBackupTrayActionButton"
                  Click="OnExportBackupClick"
                  Content="{Binding ExportBackupLabel}"
                  IsEnabled="{Binding CanExportBackup}"
                  AutomationProperties.Name="Exportovat data aplikace do zálohy"
                  AutomationProperties.AutomationId="ExportBackupTrayActionButton" />
          <Button x:Name="ImportBackupTrayActionButton"
                  Click="OnImportBackupClick"
                  Content="{Binding ImportBackupLabel}"
                  IsEnabled="{Binding CanImportBackup}"
                  AutomationProperties.Name="Obnovit data aplikace ze zálohy"
                  AutomationProperties.AutomationId="ImportBackupTrayActionButton" />
          <Button x:Name="CreateAutomaticBackupNowTrayActionButton"
                  Click="OnCreateAutomaticBackupNowClick"
                  Content="{Binding CreateAutomaticBackupNowLabel}"
                  IsEnabled="{Binding CanCreateAutomaticBackupNow}"
                  AutomationProperties.Name="Vytvořit automatickou zálohu ihned"
                  AutomationProperties.AutomationId="CreateAutomaticBackupNowTrayActionButton" />
          <Button x:Name="OpenAutomaticBackupFolderTrayActionButton"
                  Click="OnOpenAutomaticBackupFolderClick"
                  Content="{Binding OpenAutomaticBackupFolderLabel}"
                  IsEnabled="{Binding CanOpenAutomaticBackupFolder}"
                  AutomationProperties.Name="Otevřít složku automatických záloh"
                  AutomationProperties.AutomationId="OpenAutomaticBackupFolderTrayActionButton" />
          <Button x:Name="OpenSettingsTrayActionButton"
                  Click="OnOpenSettingsClick"
                  Content="{Binding OpenSettingsLabel}"
                  IsEnabled="{Binding CanOpenSettings}"
                  AutomationProperties.Name="Otevřít nastavení aplikace"
                  AutomationProperties.AutomationId="OpenSettingsTrayActionButton" />
          <Button x:Name="ExportCalendarTrayActionButton"
                  Click="OnExportCalendarClick"
                  Content="{Binding ExportCalendarLabel}"
                  IsEnabled="{Binding CanExportCalendar}"
                  AutomationProperties.Name="Exportovat budoucí termíny do kalendáře"
                  AutomationProperties.AutomationId="ExportCalendarTrayActionButton" />
          <Button x:Name="ReloadDataTrayActionButton"
                  Click="OnReloadDataClick"
                  Content="{Binding ReloadDataLabel}"
                  IsEnabled="{Binding CanReloadData}"
                  AutomationProperties.Name="Znovu načíst data"
                  AutomationProperties.AutomationId="ReloadDataTrayActionButton" />
          <Button x:Name="OpenDataFolderTrayActionButton"
                  Click="OnOpenDataFolderClick"
                  Content="{Binding OpenDataFolderLabel}"
                  IsEnabled="{Binding CanOpenDataFolder}"
                  AutomationProperties.Name="Otevřít datovou složku Vehimapu"
                  AutomationProperties.AutomationId="OpenDataFolderTrayActionButton" />
          <Button x:Name="OpenAboutTrayActionButton"
                  Click="OnOpenAboutClick"
                  Content="{Binding OpenAboutLabel}"
                  IsEnabled="{Binding CanOpenAbout}"
                  AutomationProperties.Name="Otevřít dialog O programu"
                  AutomationProperties.AutomationId="OpenAboutTrayActionButton" />
          <Button x:Name="CheckForUpdatesTrayActionButton"
                  Click="OnCheckForUpdatesClick"
                  Content="{Binding CheckForUpdatesLabel}"
                  IsEnabled="{Binding CanCheckForUpdates}"
                  AutomationProperties.Name="Zkontrolovat aktualizace aplikace"
                  AutomationProperties.AutomationId="CheckForUpdatesTrayActionButton" />
          <Button x:Name="ExitTrayActionButton"
                  Margin="0,8,0,0"
                  Click="OnExitClick"
                  Content="{Binding ExitLabel}"
                  IsEnabled="{Binding CanExit}"
                  AutomationProperties.Name="Ukončit Vehimap"
                  AutomationProperties.AutomationId="ExitTrayActionButton" />
        </StackPanel>
      </ScrollViewer>
      <Button Grid.Row="3"
              x:Name="CloseTrayActionsButton"
              HorizontalAlignment="Right"
              MinWidth="120"
              Click="OnCloseClick"
              Content="{Binding CancelLabel}"
              AutomationProperties.Name="Zavřít akce lišty bez provedení změny"
              AutomationProperties.AutomationId="CloseTrayActionsButton" />
    </Grid>
  </Border>
</Window>
