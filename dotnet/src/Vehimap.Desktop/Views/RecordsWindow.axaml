<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.RecordsWindow"
        x:DataType="vm:RecordWorkspaceViewModel"
        Width="1380"
        Height="840"
        MinWidth="1120"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="Doklady vozidla"
        AutomationProperties.HelpText="Samostatné okno pro práci s doklady a přílohami vybraného vozidla.">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}" />
        <TextBlock Opacity="0.78"
                   Text="{Binding RecordSummary}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              x:Name="CloseRecordsWindowButton"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="Zavřít"
              AutomationProperties.Name="Zavřít okno dokladů"
              AutomationProperties.AutomationId="CloseRecordsWindowButton" />
    </Grid>

    <workspaces:RecordWorkspaceView x:Name="RecordWorkspaceHost"
                                    Grid.Row="1"
                                    Margin="0,18,0,0" />
  </Grid>
</Window>
