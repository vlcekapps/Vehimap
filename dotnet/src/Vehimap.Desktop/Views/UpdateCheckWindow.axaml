<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.UpdateCheckWindow"
        x:DataType="vm:UpdateDialogViewModel"
        Width="620"
        Height="420"
        MinWidth="560"
        MinHeight="360"
        CanResize="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="{i18n:Loc UpdateCheck.Title}"
        AutomationProperties.Name="{i18n:Loc UpdateCheck.Title}"
        AutomationProperties.AutomationId="UpdateCheckWindow"
        AutomationProperties.HelpText="{i18n:Loc UpdateCheck.HelpText}">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto,Auto">
    <TextBlock FontSize="22"
               FontWeight="SemiBold"
               Text="{Binding Heading}"
               AutomationProperties.Name="{Binding Heading}"
               AutomationProperties.AutomationId="UpdateHeadingText"
               AutomationProperties.HeadingLevel="1" />
    <TextBlock Grid.Row="1"
               Margin="0,10,0,0"
               Text="{Binding Summary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding Summary}"
               AutomationProperties.AutomationId="UpdateSummaryText" />
    <Border Grid.Row="2"
            Margin="0,18,0,0"
            Padding="12"
            Background="#143A4A5A"
            CornerRadius="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    AutomationProperties.Name="{i18n:Loc UpdateCheck.DetailsName}"
                    AutomationProperties.AutomationId="UpdateDetailsScrollViewer">
        <TextBlock Text="{Binding Details}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding Details}"
                   AutomationProperties.AutomationId="UpdateDetailsText" />
      </ScrollViewer>
    </Border>
    <Border Grid.Row="3"
            Margin="0,18,0,0"
            Padding="12"
            Background="#143A4A5A"
            CornerRadius="8">
      <TextBlock Text="{Binding StatusMessage}"
                 TextWrapping="Wrap"
                 AutomationProperties.Name="{Binding StatusMessage}"
                 AutomationProperties.AutomationId="UpdateStatusText"
                 AutomationProperties.LiveSetting="Polite" />
    </Border>

    <StackPanel Grid.Row="4"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10">
      <Button x:Name="PrimaryActionButton"
              MinWidth="170"
              IsVisible="{Binding ShowPrimaryAction}"
              Click="OnPrimaryActionClick"
              Content="{Binding PrimaryActionLabel}"
              AutomationProperties.Name="{Binding PrimaryActionLabel}"
              AutomationProperties.AutomationId="PrimaryActionButton" />
      <Button x:Name="AssetActionButton"
              MinWidth="170"
              IsVisible="{Binding ShowSecondaryAssetAction}"
              Click="OnAssetActionClick"
              Content="{i18n:Loc UpdateCheck.AssetAction}"
              AutomationProperties.Name="{i18n:Loc UpdateCheck.AssetActionName}"
              AutomationProperties.AutomationId="AssetActionButton" />
      <Button x:Name="CopyDetailsButton"
              MinWidth="150"
              Click="OnCopyDetailsClick"
              Content="{i18n:Loc UpdateCheck.CopyDetails}"
              AutomationProperties.Name="{i18n:Loc UpdateCheck.CopyDetailsName}"
              AutomationProperties.AutomationId="CopyUpdateDetailsButton" />
      <Button x:Name="CloseButton"
              MinWidth="110"
              Click="OnCloseClick"
              Content="{i18n:Loc Common.Close}"
              AutomationProperties.Name="{i18n:Loc UpdateCheck.CloseName}"
              AutomationProperties.AutomationId="UpdateCloseButton" />
    </StackPanel>
  </Grid>
</Window>
