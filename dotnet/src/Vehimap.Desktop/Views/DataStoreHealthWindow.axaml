<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.DataStoreHealthWindow"
        x:DataType="vm:DataStoreHealthDialogViewModel"
        Width="680"
        Height="520"
        MinWidth="600"
        MinHeight="420"
        CanResize="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="{i18n:Loc DataStoreHealth.Title}"
        AutomationProperties.Name="{i18n:Loc DataStoreHealth.Title}"
        AutomationProperties.AutomationId="DataStoreHealthWindow"
        AutomationProperties.HelpText="{i18n:Loc DataStoreHealth.HelpText}">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto,Auto">
    <TextBlock FontSize="22"
               FontWeight="SemiBold"
               Text="{Binding Heading}"
               AutomationProperties.Name="{Binding Heading}"
               AutomationProperties.AutomationId="DataStoreHealthHeadingText"
               AutomationProperties.HeadingLevel="1" />
    <TextBlock Grid.Row="1"
               Margin="0,10,0,0"
               Text="{Binding Summary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding Summary}"
               AutomationProperties.AutomationId="DataStoreHealthSummaryText" />
    <Border Grid.Row="2"
            Margin="0,18,0,0"
            Padding="12"
            Background="#143A4A5A"
            CornerRadius="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    AutomationProperties.Name="{i18n:Loc DataStoreHealth.DetailsName}"
                    AutomationProperties.AutomationId="DataStoreHealthDetailsScrollViewer">
        <TextBlock Text="{Binding Details}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding Details}"
                   AutomationProperties.AutomationId="DataStoreHealthDetailsText" />
      </ScrollViewer>
    </Border>
    <Border Grid.Row="3"
            Margin="0,18,0,0"
            Padding="12"
            Background="#143A4A5A"
            CornerRadius="8">
      <TextBlock Text="{Binding StatusMessage}"
                 TextWrapping="Wrap"
                 AutomationProperties.Name="{Binding StatusMessage}"
                 AutomationProperties.AutomationId="DataStoreHealthStatusText"
                 AutomationProperties.LiveSetting="Polite" />
    </Border>

    <StackPanel Grid.Row="4"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10">
      <Button x:Name="CopyHealthDetailsButton"
              MinWidth="170"
              Click="OnCopyDetailsClick"
              Content="{i18n:Loc DataStoreHealth.CopyDiagnostics}"
              AutomationProperties.Name="{i18n:Loc DataStoreHealth.CopyDiagnosticsName}"
              AutomationProperties.AutomationId="CopyDataStoreHealthDetailsButton" />
      <Button x:Name="OpenHealthDataFolderButton"
              MinWidth="150"
              IsEnabled="{Binding CanOpenDataFolder}"
              Click="OnOpenDataFolderClick"
              Content="{i18n:Loc DataStoreHealth.OpenDataFolder}"
              AutomationProperties.Name="{i18n:Loc DataStoreHealth.OpenDataFolderName}"
              AutomationProperties.AutomationId="OpenHealthDataFolderButton" />
      <Button x:Name="OpenHealthPreMigrationBackupButton"
              MinWidth="210"
              IsEnabled="{Binding CanOpenPreMigrationBackupFolder}"
              Click="OnOpenPreMigrationBackupFolderClick"
              Content="{i18n:Loc DataStoreHealth.OpenPreMigrationBackup}"
              AutomationProperties.Name="{i18n:Loc DataStoreHealth.OpenPreMigrationBackupName}"
              AutomationProperties.AutomationId="OpenHealthPreMigrationBackupButton" />
      <Button x:Name="CloseHealthButton"
              MinWidth="110"
              Click="OnCloseClick"
              Content="{i18n:Loc Common.Close}"
              AutomationProperties.Name="{i18n:Loc DataStoreHealth.CloseName}"
              AutomationProperties.AutomationId="CloseDataStoreHealthButton" />
    </StackPanel>
  </Grid>
</Window>
