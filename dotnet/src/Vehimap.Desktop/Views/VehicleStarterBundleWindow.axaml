<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.VehicleStarterBundleWindow"
        x:DataType="vm:VehicleStarterBundleDialogViewModel"
        Width="1040"
        Height="720"
        MinWidth="920"
        MinHeight="620"
        CanResize="True"
        Title="{Binding DialogTitle}"
        AutomationProperties.Name="{Binding DialogTitle}"
        AutomationProperties.AutomationId="VehicleStarterBundleWindow"
        AutomationProperties.HelpText="{Binding DialogHelpText}">
  <Grid Margin="18" RowDefinitions="Auto,Auto,*,Auto">
    <StackPanel Spacing="4">
      <TextBlock FontSize="24"
                 FontWeight="SemiBold"
                 Text="{Binding DialogTitle}"
                 AutomationProperties.Name="{Binding DialogTitle}"
                 AutomationProperties.AutomationId="VehicleStarterBundleHeadingText"
                 AutomationProperties.HeadingLevel="1" />
      <TextBlock Text="{Binding VehicleName}" />
      <TextBlock Opacity="0.8" Text="{Binding ProfileLabel}" />
    </StackPanel>

    <TextBlock Grid.Row="1"
               Margin="0,14,0,0"
               Text="{Binding SummaryText}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding SummaryText}"
               AutomationProperties.AutomationId="BundleSummaryText" />

    <Grid Grid.Row="2" Margin="0,18,0,0" ColumnDefinitions="360,*">
      <Border Padding="12" BorderBrush="#304050" BorderThickness="1" CornerRadius="8">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock FontWeight="SemiBold" Text="{Binding ItemsHeading}" />
          <ListBox x:Name="BundleItemsListBox"
                   Grid.Row="1"
                   Margin="0,12,0,0"
                   ItemsSource="{Binding Items}"
                   SelectedItem="{Binding SelectedItem}"
                   AutomationProperties.Name="{Binding ItemsListName}"
                   AutomationProperties.AutomationId="BundleItemsListBox"
                   AutomationProperties.HelpText="{i18n:Loc VehicleStarterBundle.ItemsHelpText}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:VehicleStarterBundleItemEditorViewModel">
                <Border Padding="10"
                        Margin="0,0,0,8"
                        Background="#10203040"
                        CornerRadius="6"
                        AutomationProperties.Name="{Binding AccessibleLabel}"
                        AutomationProperties.ItemType="{i18n:Loc VehicleStarterBundle.ItemType}">
                  <Grid ColumnDefinitions="Auto,*">
                    <CheckBox IsChecked="{Binding IsSelected}"
                              VerticalAlignment="Top"
                              AutomationProperties.Name="{Binding AccessibleLabel}"
                              AutomationProperties.AutomationId="BundleItemSelectedCheckBox" />
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="4">
                      <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                      <TextBlock Opacity="0.8" Text="{Binding SectionLabel}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <StackPanel Grid.Row="2" Margin="0,12,0,0" Orientation="Horizontal" Spacing="10">
            <Button Command="{Binding SelectAllCommand}"
                    Content="{i18n:Loc VehicleStarterBundle.SelectAll}"
                    AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.SelectAllName}"
                    AutomationProperties.AutomationId="BundleSelectAllButton" />
            <Button Command="{Binding ClearSelectionCommand}"
                    Content="{i18n:Loc VehicleStarterBundle.ClearSelection}"
                    AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.ClearSelectionName}"
                    AutomationProperties.AutomationId="BundleClearSelectionButton" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Column="1" Margin="16,0,0,0" Padding="14" BorderBrush="#304050" BorderThickness="1" CornerRadius="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.DetailScrollName}"
                      AutomationProperties.AutomationId="BundleDetailScrollViewer">
          <StackPanel Spacing="12">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="{i18n:Loc VehicleStarterBundle.DetailHeading}"
                       AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.DetailHeadingName}"
                       AutomationProperties.AutomationId="BundleDetailHeadingText"
                       AutomationProperties.HeadingLevel="2" />
            <TextBlock Opacity="0.78"
                       Text="{Binding DetailHint}"
                       AutomationProperties.Name="{Binding DetailHint}"
                       AutomationProperties.AutomationId="BundleDetailHintText" />

            <StackPanel IsVisible="{Binding SelectedItem.IsMaintenance}">
              <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.MaintenanceTitleLabel}" />
              <TextBox Text="{Binding SelectedItem.Title}"
                       AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.MaintenanceTitleName}"
                       AutomationProperties.AutomationId="BundleMaintenanceTitleBox" />
              <Grid Margin="0,12,0,0" ColumnDefinitions="*,*">
                <StackPanel Margin="0,0,10,0" Spacing="6">
                  <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.MaintenanceIntervalKmLabel}" />
                  <TextBox Text="{Binding SelectedItem.IntervalKm}"
                           AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.MaintenanceIntervalKmName}"
                           AutomationProperties.AutomationId="BundleMaintenanceIntervalKmBox" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="6">
                  <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.MaintenanceIntervalMonthsLabel}" />
                  <TextBox Text="{Binding SelectedItem.IntervalMonths}"
                           AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.MaintenanceIntervalMonthsName}"
                           AutomationProperties.AutomationId="BundleMaintenanceIntervalMonthsBox" />
                </StackPanel>
              </Grid>
            </StackPanel>

            <StackPanel IsVisible="{Binding SelectedItem.IsRecord}">
              <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.RecordTypeLabel}" />
              <ComboBox ItemsSource="{Binding RecordTypeOptions}"
                        SelectedItem="{Binding SelectedItem.RecordType}"
                        AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.RecordTypeName}"
                        AutomationProperties.AutomationId="BundleRecordTypeBox" />
              <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.RecordTitleLabel}" />
              <TextBox Text="{Binding SelectedItem.Title}"
                       AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.RecordTitleName}"
                       AutomationProperties.AutomationId="BundleRecordTitleBox" />
              <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.RecordProviderLabel}" />
              <TextBox Text="{Binding SelectedItem.Provider}"
                       AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.RecordProviderName}"
                       AutomationProperties.AutomationId="BundleRecordProviderBox" />
              <Grid Margin="0,12,0,0" ColumnDefinitions="*,*,*">
                <StackPanel Margin="0,0,10,0" Spacing="6">
                  <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.RecordValidFromLabel}" />
                  <TextBox Text="{Binding SelectedItem.ValidFrom}"
                           AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.RecordValidFromName}"
                           AutomationProperties.AutomationId="BundleRecordValidFromBox" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,10,0" Spacing="6">
                  <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.RecordValidToLabel}" />
                  <TextBox Text="{Binding SelectedItem.ValidTo}"
                           AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.RecordValidToName}"
                           AutomationProperties.AutomationId="BundleRecordValidToBox" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="6">
                  <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.RecordPriceLabel}" />
                  <TextBox Text="{Binding SelectedItem.Price}"
                           AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.RecordPriceName}"
                           AutomationProperties.AutomationId="BundleRecordPriceBox" />
                </StackPanel>
              </Grid>
            </StackPanel>

            <StackPanel IsVisible="{Binding SelectedItem.IsReminder}">
              <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.ReminderTitleLabel}" />
              <TextBox Text="{Binding SelectedItem.Title}"
                       AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.ReminderTitleName}"
                       AutomationProperties.AutomationId="BundleReminderTitleBox" />
              <Grid Margin="0,12,0,0" ColumnDefinitions="*,*,*">
                <StackPanel Margin="0,0,10,0" Spacing="6">
                  <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.ReminderDueDateLabel}" />
                  <TextBox Text="{Binding SelectedItem.DueDate}"
                           AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.ReminderDueDateName}"
                           AutomationProperties.AutomationId="BundleReminderDueDateBox" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,10,0" Spacing="6">
                  <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.ReminderDaysLabel}" />
                  <TextBox Text="{Binding SelectedItem.ReminderDays}"
                           AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.ReminderDaysName}"
                           AutomationProperties.AutomationId="BundleReminderDaysBox" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="6">
                  <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.ReminderRepeatLabel}" />
                  <ComboBox ItemsSource="{Binding ReminderRepeatModeOptions}"
                            SelectedItem="{Binding SelectedItem.RepeatMode}"
                            AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.ReminderRepeatName}"
                            AutomationProperties.AutomationId="BundleReminderRepeatModeBox" />
                </StackPanel>
              </Grid>
            </StackPanel>

            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleStarterBundle.NoteLabel}" />
            <TextBox Height="120"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"
                     Text="{Binding SelectedItem.Note}"
                     AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.NoteName}"
                     AutomationProperties.AutomationId="BundleItemNoteBox" />
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <StackPanel Grid.Row="3" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button x:Name="ApplyBundleButton"
              Click="OnApplyClick"
              Content="{i18n:Loc VehicleStarterBundle.Apply}"
              IsEnabled="{Binding CanApply}"
              AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.ApplyName}"
              AutomationProperties.AutomationId="ApplyBundleButton" />
      <Button x:Name="CancelBundleButton"
              Click="OnCancelClick"
              Content="{i18n:Loc Common.Close}"
              AutomationProperties.Name="{i18n:Loc VehicleStarterBundle.CloseName}"
              AutomationProperties.AutomationId="CancelBundleButton" />
    </StackPanel>
  </Grid>
</Window>
