<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="using:Vehimap.Desktop.Localization"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.RecordWorkspaceView"
             x:DataType="vm:RecordWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+N" Command="{Binding CreateRecordCommand}" />
    <KeyBinding Gesture="Ctrl+U" Command="{Binding EditSelectedRecordCommand}" />
    <KeyBinding Gesture="F2" Command="{Binding EditSelectedRecordCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenSelectedRecordFileCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding OpenSelectedRecordFolderCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding CopySelectedRecordPathCommand}" />
  </UserControl.KeyBindings>
  <Grid ColumnDefinitions="1.1*,*" RowDefinitions="Auto,*">
    <TextBlock Grid.ColumnSpan="2" Text="{Binding RecordSummary}" TextWrapping="Wrap" AutomationProperties.Name="{Binding RecordSummary}" AutomationProperties.AutomationId="RecordSummaryText" />
    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="0,16,0,0">
      <TextBlock FontWeight="SemiBold" Text="{i18n:Loc RecordWorkspace.Title}" />
      <Grid Grid.Row="1" Margin="0,10,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="{i18n:Loc Common.Search}" />
        <TextBox x:Name="RecordSearchBox"
                 Grid.Column="1"
                 Text="{Binding RecordSearchText}"
                 PlaceholderText="{i18n:Loc RecordWorkspace.SearchPlaceholder}"
                 AutomationProperties.Name="{i18n:Loc RecordWorkspace.SearchName}"
                 AutomationProperties.HelpText="{i18n:Loc RecordWorkspace.SearchHelp}"
                 AutomationProperties.AutomationId="RecordSearchBox" />
        <Button Grid.Column="2"
                Margin="12,0,0,0"
                Command="{Binding ClearRecordSearchCommand}"
                Content="{i18n:Loc Common.Clear}"
                AutomationProperties.Name="{i18n:Loc RecordWorkspace.ClearSearchName}"
                AutomationProperties.AutomationId="ClearRecordSearchButton" />
      </Grid>
      <Grid Grid.Row="2" Margin="0,8,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="{i18n:Loc Common.Sort}" />
        <ComboBox Grid.Column="1" ItemsSource="{Binding RecordSortOptions}" SelectedItem="{Binding SelectedRecordSortOption}" AutomationProperties.Name="{i18n:Loc RecordWorkspace.SortName}" AutomationProperties.AutomationId="RecordSortComboBox" />
        <CheckBox Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" Content="{i18n:Loc Common.SortDescending}" IsChecked="{Binding RecordSortDescending}" AutomationProperties.Name="{i18n:Loc RecordWorkspace.SortDescendingName}" AutomationProperties.AutomationId="RecordSortDescendingCheckBox" />
      </Grid>
      <TextBlock Grid.Row="3" Margin="0,8,12,0" Opacity="0.72" Text="{Binding RecordSearchSummary}" TextWrapping="Wrap" AutomationProperties.Name="{Binding RecordSearchSummary}" AutomationProperties.AutomationId="RecordSearchSummaryText" />
      <ListBox x:Name="RecordListBox"
               Grid.Row="4"
               Margin="0,12,12,0"
               ItemsSource="{Binding VisibleRecordItems}"
               SelectedItem="{Binding SelectedRecord}"
               AutomationProperties.Name="{i18n:Loc RecordWorkspace.ListName}"
               AutomationProperties.AutomationId="RecordListBox">
        <ListBox.KeyBindings>
          <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedRecordFileCommand}" />
        </ListBox.KeyBindings>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="itemvm:VehicleRecordItemViewModel">
            <Border Padding="12" Margin="0,0,0,8" Background="#10203040" CornerRadius="6" AutomationProperties.Name="{Binding AccessibleLabel}" AutomationProperties.ItemType="{i18n:Loc RecordWorkspace.ItemType}" AutomationProperties.ItemStatus="{Binding AttachmentState}">
              <StackPanel Spacing="4">
                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                <TextBlock Opacity="0.82" Text="{Binding RecordType}" />
                <TextBlock Opacity="0.82" Text="{Binding Provider}" />
                <TextBlock Opacity="0.82" Text="{Binding Validity}" />
                <TextBlock Opacity="0.82" Text="{Binding AttachmentMode}" />
                <TextBlock Opacity="0.72" Text="{Binding AttachmentState}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <Border Grid.Row="1" Grid.Column="1" Margin="12,16,0,0" Padding="16" Background="#10203040" CornerRadius="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    AutomationProperties.Name="{i18n:Loc RecordWorkspace.DetailName}"
                    AutomationProperties.AutomationId="RecordDetailScrollViewer">
        <Grid RowDefinitions="Auto,Auto,Auto,*">
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="{Binding RecordPanelHeading}"
                     AutomationProperties.Name="{Binding RecordPanelHeading}"
                     AutomationProperties.AutomationId="RecordPanelHeadingText"
                     AutomationProperties.HeadingLevel="2" />
          <StackPanel Grid.Row="1" Margin="0,14,0,0" Spacing="8">
            <WrapPanel x:Name="RecordEditActionPanel" ItemWidth="138" ItemHeight="34">
              <Button Command="{Binding CreateRecordCommand}" Content="{i18n:Loc RecordWorkspace.Create}" AutomationProperties.Name="{i18n:Loc RecordWorkspace.CreateName}" AutomationProperties.AutomationId="CreateRecordButton" />
              <Button Command="{Binding EditSelectedRecordCommand}" Content="{i18n:Loc Common.Edit}" AutomationProperties.Name="{i18n:Loc RecordWorkspace.EditName}" AutomationProperties.AutomationId="EditRecordButton" />
              <Button Command="{Binding DeleteSelectedRecordCommand}" Content="{i18n:Loc Common.Delete}" AutomationProperties.Name="{i18n:Loc RecordWorkspace.DeleteName}" AutomationProperties.HelpText="{i18n:Loc RecordWorkspace.DeleteHelp}" AutomationProperties.AutomationId="DeleteRecordButton" />
              <Button Command="{Binding MoveSelectedRecordToManagedCommand}" Content="{i18n:Loc RecordWorkspace.MoveToManaged}" AutomationProperties.Name="{i18n:Loc RecordWorkspace.MoveToManagedName}" AutomationProperties.AutomationId="MoveRecordToManagedButton" />
            </WrapPanel>
            <WrapPanel x:Name="RecordFileActionPanel" ItemWidth="138" ItemHeight="34">
              <Button Command="{Binding OpenSelectedRecordFileCommand}" Content="{i18n:Loc RecordWorkspace.OpenFile}" AutomationProperties.Name="{i18n:Loc RecordWorkspace.OpenFileName}" AutomationProperties.AutomationId="OpenRecordFileButton" />
              <Button Command="{Binding OpenSelectedRecordFolderCommand}" Content="{i18n:Loc RecordWorkspace.OpenFolder}" AutomationProperties.Name="{i18n:Loc RecordWorkspace.OpenFolderName}" AutomationProperties.AutomationId="OpenRecordFolderButton" />
              <Button Command="{Binding CopySelectedRecordPathCommand}" Content="{i18n:Loc RecordWorkspace.CopyPath}" AutomationProperties.Name="{i18n:Loc RecordWorkspace.CopyPathName}" AutomationProperties.AutomationId="CopyRecordPathButton" />
            </WrapPanel>
          </StackPanel>
          <TextBlock Grid.Row="2" Margin="0,12,0,0" Opacity="0.82" Text="{Binding RecordEditorStatus}" TextWrapping="Wrap" AutomationProperties.Name="{Binding RecordEditorStatus}" AutomationProperties.AutomationId="RecordStatusText" AutomationProperties.LiveSetting="Polite" />
          <TextBlock Grid.Row="3" Margin="0,16,0,0" Text="{Binding SelectedRecordDetail}" TextWrapping="Wrap" AutomationProperties.Name="{Binding SelectedRecordDetail}" AutomationProperties.AutomationId="SelectedRecordDetailText" />
        </Grid>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
