<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.RecordWorkspaceView"
             x:DataType="vm:RecordWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+N" Command="{Binding CreateRecordCommand}" />
    <KeyBinding Gesture="Ctrl+U" Command="{Binding EditSelectedRecordCommand}" />
    <KeyBinding Gesture="F2" Command="{Binding EditSelectedRecordCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveRecordCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenSelectedRecordFileCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding OpenSelectedRecordFolderCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding CopySelectedRecordPathCommand}" />
  </UserControl.KeyBindings>
  <Grid ColumnDefinitions="1.1*,*" RowDefinitions="Auto,*">
    <TextBlock Grid.ColumnSpan="2" Text="{Binding RecordSummary}" TextWrapping="Wrap" AutomationProperties.Name="{Binding RecordSummary}" AutomationProperties.AutomationId="RecordSummaryText" />
    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="0,16,0,0">
      <TextBlock FontWeight="SemiBold" Text="Seznam dokladů a příloh vybraného vozidla" />
      <Grid Grid.Row="1" Margin="0,10,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="Hledat" />
        <TextBox x:Name="RecordSearchBox"
                 Grid.Column="1"
                 Text="{Binding RecordSearchText}"
                 PlaceholderText="Typ, název, poskytovatel, platnost, příloha nebo poznámka..."
                 AutomationProperties.Name="Hledání v dokladech vozidla"
                 AutomationProperties.AutomationId="RecordSearchBox" />
        <Button Grid.Column="2"
                Margin="12,0,0,0"
                Command="{Binding ClearRecordSearchCommand}"
                Content="Vymazat"
                AutomationProperties.Name="Vymazat hledání v dokladech vozidla"
                AutomationProperties.AutomationId="ClearRecordSearchButton" />
      </Grid>
      <Grid Grid.Row="2" Margin="0,8,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="Řadit" />
        <ComboBox Grid.Column="1" ItemsSource="{Binding RecordSortOptions}" SelectedItem="{Binding SelectedRecordSortOption}" AutomationProperties.Name="Řazení dokladů vozidla" AutomationProperties.AutomationId="RecordSortComboBox" />
        <CheckBox Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" Content="Sestupně" IsChecked="{Binding RecordSortDescending}" AutomationProperties.Name="Řadit doklady sestupně" AutomationProperties.AutomationId="RecordSortDescendingCheckBox" />
      </Grid>
      <TextBlock Grid.Row="3" Margin="0,8,12,0" Opacity="0.72" Text="{Binding RecordSearchSummary}" TextWrapping="Wrap" AutomationProperties.Name="{Binding RecordSearchSummary}" AutomationProperties.AutomationId="RecordSearchSummaryText" />
      <ListBox x:Name="RecordListBox"
               Grid.Row="4"
               Margin="0,12,12,0"
               ItemsSource="{Binding VisibleRecordItems}"
               SelectedItem="{Binding SelectedRecord}"
               AutomationProperties.Name="Doklady vybraného vozidla"
               AutomationProperties.AutomationId="RecordListBox">
        <ListBox.KeyBindings>
          <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedRecordFileCommand}" />
        </ListBox.KeyBindings>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="itemvm:VehicleRecordItemViewModel">
            <Border Padding="12" Margin="0,0,0,8" Background="#10203040" CornerRadius="6" AutomationProperties.Name="{Binding AccessibleLabel}">
              <StackPanel Spacing="4">
                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                <TextBlock Opacity="0.82" Text="{Binding RecordType}" />
                <TextBlock Opacity="0.82" Text="{Binding Provider}" />
                <TextBlock Opacity="0.82" Text="{Binding Validity}" />
                <TextBlock Opacity="0.82" Text="{Binding AttachmentMode}" />
                <TextBlock Opacity="0.72" Text="{Binding AttachmentState}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <Border Grid.Row="1" Grid.Column="1" Margin="12,16,0,0" Padding="16" Background="#10203040" CornerRadius="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    AutomationProperties.Name="Panel dokladů vozidla"
                    AutomationProperties.AutomationId="RecordEditorScrollViewer">
      <Grid RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding RecordPanelHeading}"
                   AutomationProperties.Name="{Binding RecordPanelHeading}"
                   AutomationProperties.AutomationId="RecordPanelHeadingText"
                   AutomationProperties.HeadingLevel="2" />
        <StackPanel Grid.Row="1" Margin="0,14,0,0" Spacing="8">
          <WrapPanel x:Name="RecordEditActionPanel" ItemWidth="138" ItemHeight="34">
            <Button Command="{Binding CreateRecordCommand}" Content="Nový doklad" AutomationProperties.Name="Vytvořit nový doklad" AutomationProperties.AutomationId="CreateRecordButton" />
            <Button Command="{Binding EditSelectedRecordCommand}" Content="Upravit" AutomationProperties.Name="Upravit vybraný doklad" AutomationProperties.AutomationId="EditRecordButton" />
            <Button Command="{Binding DeleteSelectedRecordCommand}" Content="Odstranit" AutomationProperties.Name="Odstranit vybraný doklad" AutomationProperties.AutomationId="DeleteRecordButton" />
            <Button Command="{Binding MoveSelectedRecordToManagedCommand}" Content="Přesunout do příloh" AutomationProperties.Name="Převést vybraný doklad na spravovanou kopii" AutomationProperties.AutomationId="MoveRecordToManagedButton" />
            <Button Command="{Binding SaveRecordCommand}" Content="Uložit" IsVisible="{Binding IsEditingRecord}" AutomationProperties.Name="Uložit doklad" AutomationProperties.AutomationId="SaveRecordButton" />
            <Button Command="{Binding CancelRecordEditCommand}" Content="Zrušit" IsVisible="{Binding IsEditingRecord}" AutomationProperties.Name="Zrušit úpravu dokladu" AutomationProperties.AutomationId="CancelRecordButton" />
          </WrapPanel>
          <WrapPanel x:Name="RecordFileActionPanel" ItemWidth="138" ItemHeight="34">
            <Button Command="{Binding OpenSelectedRecordFileCommand}" Content="Otevřít soubor" IsVisible="{Binding IsRecordDetailVisible}" AutomationProperties.Name="Otevřít soubor přílohy vybraného dokladu" AutomationProperties.AutomationId="OpenRecordFileButton" />
            <Button Command="{Binding OpenSelectedRecordFolderCommand}" Content="Otevřít složku" IsVisible="{Binding IsRecordDetailVisible}" AutomationProperties.Name="Otevřít složku přílohy vybraného dokladu" AutomationProperties.AutomationId="OpenRecordFolderButton" />
            <Button Command="{Binding CopySelectedRecordPathCommand}" Content="Kopírovat cestu" IsVisible="{Binding IsRecordDetailVisible}" AutomationProperties.Name="Kopírovat vyřešenou cestu přílohy dokladu" AutomationProperties.AutomationId="CopyRecordPathButton" />
          </WrapPanel>
        </StackPanel>
        <TextBlock Grid.Row="2" Margin="0,12,0,0" Opacity="0.82" Text="{Binding RecordEditorStatus}" TextWrapping="Wrap" AutomationProperties.Name="{Binding RecordEditorStatus}" AutomationProperties.AutomationId="RecordEditorStatusText" AutomationProperties.LiveSetting="Polite" />
        <Border x:Name="RecordEditorHost" Grid.Row="3" Margin="0,16,0,0">
          <Grid IsVisible="{Binding IsEditingRecord}" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            <Grid ColumnDefinitions="1.1*,1.4*">
              <StackPanel Margin="0,0,12,0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Typ dokladu" />
                <ComboBox x:Name="RecordEditorTypeBox" ItemsSource="{Binding RecordTypeOptions}" SelectedItem="{Binding RecordEditorRecordType}" AutomationProperties.Name="Typ dokladu" AutomationProperties.AutomationId="RecordEditorTypeBox" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Název" />
                <TextBox x:Name="RecordEditorTitleBox" Text="{Binding RecordEditorTitle}" PlaceholderText="Například Allianz 2026" AutomationProperties.Name="Název dokladu" AutomationProperties.AutomationId="RecordEditorTitleBox" />
              </StackPanel>
            </Grid>
            <Grid Grid.Row="1" Margin="0,14,0,0" ColumnDefinitions="1.2*,*,*">
              <StackPanel Margin="0,0,12,0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Poskytovatel" />
                <TextBox Text="{Binding RecordEditorProvider}" AutomationProperties.Name="Poskytovatel dokladu" AutomationProperties.AutomationId="RecordEditorProviderBox" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Platí od" />
                <TextBox x:Name="RecordEditorValidFromBox" Text="{Binding RecordEditorValidFrom}" AutomationProperties.Name="Platnost dokladu od" AutomationProperties.AutomationId="RecordEditorValidFromBox" />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Platí do" />
                <TextBox x:Name="RecordEditorValidToBox" Text="{Binding RecordEditorValidTo}" AutomationProperties.Name="Platnost dokladu do" AutomationProperties.AutomationId="RecordEditorValidToBox" />
              </StackPanel>
            </Grid>
            <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="180,*">
              <StackPanel Margin="0,0,12,0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Cena" />
                <TextBox x:Name="RecordEditorPriceBox" Text="{Binding RecordEditorPrice}" AutomationProperties.Name="Cena dokladu" AutomationProperties.AutomationId="RecordEditorPriceBox" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Režim přílohy" />
                <ComboBox ItemsSource="{Binding RecordAttachmentModes}" SelectedItem="{Binding SelectedRecordEditorAttachmentMode}" AutomationProperties.Name="Režim přílohy dokladu" AutomationProperties.AutomationId="RecordAttachmentModeComboBox" />
              </StackPanel>
            </Grid>
            <TextBlock Grid.Row="3" Margin="0,14,0,0" FontWeight="SemiBold" Text="{Binding RecordEditorPathInputLabel}" />
            <Grid Grid.Row="4" Margin="0,6,0,0" ColumnDefinitions="*,150">
              <TextBox x:Name="RecordEditorPathInputBox" IsReadOnly="{Binding IsRecordEditorManaged}" Text="{Binding RecordEditorPathInput}" PlaceholderText="{Binding RecordEditorPathInputHelp}" AutomationProperties.Name="{Binding RecordEditorPathInputLabel}" AutomationProperties.AutomationId="RecordEditorPathInputBox" />
              <Button Grid.Column="1" Margin="12,0,0,0" Command="{Binding BrowseRecordAttachmentCommand}" Content="Vybrat soubor" AutomationProperties.Name="Vybrat soubor pro doklad" AutomationProperties.AutomationId="BrowseRecordAttachmentButton" />
            </Grid>
            <TextBlock Grid.Row="5" Margin="0,8,0,0" Opacity="0.74" Text="{Binding RecordEditorPathInputHelp}" TextWrapping="Wrap" AutomationProperties.Name="{Binding RecordEditorPathInputHelp}" AutomationProperties.AutomationId="RecordEditorPathInputHelpText" />
            <TextBlock Grid.Row="6" Margin="0,14,0,0" FontWeight="SemiBold" Text="Uložená cesta" />
            <SelectableTextBlock Grid.Row="7" Margin="0,6,0,0" Text="{Binding RecordEditorStoredPath}" AutomationProperties.Name="Uložená cesta přílohy" AutomationProperties.AutomationId="RecordEditorStoredPathText" />
            <TextBlock Grid.Row="8" Margin="0,14,0,0" FontWeight="SemiBold" Text="Vyřešená cesta" />
            <SelectableTextBlock Grid.Row="9" Margin="0,6,0,0" Text="{Binding RecordEditorResolvedPath}" AutomationProperties.Name="Vyřešená cesta přílohy" AutomationProperties.AutomationId="RecordEditorResolvedPathText" />
            <TextBlock Grid.Row="10" Margin="0,14,0,0" Text="{Binding RecordEditorAvailability}" TextWrapping="Wrap" AutomationProperties.Name="{Binding RecordEditorAvailability}" AutomationProperties.AutomationId="RecordEditorAvailabilityText" />
            <StackPanel Grid.Row="11" Margin="0,14,0,0" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Poznámka" />
              <TextBox Height="100" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding RecordEditorNote}" AutomationProperties.Name="Poznámka k dokladu" AutomationProperties.AutomationId="RecordEditorNoteBox" />
            </StackPanel>
          </Grid>
        </Border>
        <TextBlock Grid.Row="3" Margin="0,16,0,0" IsVisible="{Binding IsRecordDetailVisible}" Text="{Binding SelectedRecordDetail}" TextWrapping="Wrap" AutomationProperties.Name="{Binding SelectedRecordDetail}" AutomationProperties.AutomationId="SelectedRecordDetailText" />
      </Grid>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
