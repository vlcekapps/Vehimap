<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.FuelWorkspaceView"
             x:DataType="vm:FuelWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+N" Command="{Binding CreateFuelCommand}" />
    <KeyBinding Gesture="Ctrl+U" Command="{Binding EditSelectedFuelCommand}" />
    <KeyBinding Gesture="F2" Command="{Binding EditSelectedFuelCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveFuelCommand}" />
  </UserControl.KeyBindings>
  <Grid ColumnDefinitions="1.15*,*" RowDefinitions="Auto,*">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding FuelSummary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding FuelSummary}"
               AutomationProperties.AutomationId="FuelSummaryText" />
    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="0,16,0,0">
      <TextBlock FontWeight="SemiBold"
                 Text="Tankování vybraného vozidla" />
      <Grid Grid.Row="1" Margin="0,10,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="Hledat" />
        <TextBox x:Name="FuelSearchBox"
                 Grid.Column="1"
                 Text="{Binding FuelSearchText}"
                 PlaceholderText="Datum, palivo, detail, místo, litry, cena, tachometr nebo poznámka..."
                 AutomationProperties.Name="Hledání v tankování vozidla"
                 AutomationProperties.HelpText="Datum, palivo, detail, místo, litry, cena, tachometr nebo poznámka"
                 AutomationProperties.AutomationId="FuelSearchBox" />
        <Button Grid.Column="2"
                Margin="12,0,0,0"
                Command="{Binding ClearFuelSearchCommand}"
                Content="Vymazat"
                AutomationProperties.Name="Vymazat hledání v tankování vozidla"
                AutomationProperties.AutomationId="ClearFuelSearchButton" />
      </Grid>
      <Grid Grid.Row="2" Margin="0,8,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="Řadit" />
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding FuelSortOptions}"
                  SelectedItem="{Binding SelectedFuelSortOption}"
                  AutomationProperties.Name="Řazení tankování vozidla"
                  AutomationProperties.AutomationId="FuelSortComboBox" />
        <CheckBox Grid.Column="2"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Content="Sestupně"
                  IsChecked="{Binding FuelSortDescending}"
                  AutomationProperties.Name="Řadit tankování sestupně"
                  AutomationProperties.AutomationId="FuelSortDescendingCheckBox" />
      </Grid>
      <TextBlock Grid.Row="3"
                 Margin="0,8,12,0"
                 Opacity="0.72"
                 Text="{Binding FuelSearchSummary}"
                 TextWrapping="Wrap"
                 AutomationProperties.Name="{Binding FuelSearchSummary}"
                 AutomationProperties.AutomationId="FuelSearchSummaryText" />
      <ListBox x:Name="FuelListBox"
               Grid.Row="4"
               Margin="0,12,12,0"
               ItemsSource="{Binding VisibleFuelItems}"
               SelectedItem="{Binding SelectedFuel}"
               AutomationProperties.Name="Tankování vybraného vozidla"
               AutomationProperties.AutomationId="FuelListBox">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="itemvm:VehicleFuelItemViewModel">
            <Border Padding="12"
                    Margin="0,0,0,8"
                    Background="#10203040"
                    CornerRadius="6"
                    AutomationProperties.Name="{Binding AccessibleLabel}"
                    AutomationProperties.ItemType="Tankování"
                    AutomationProperties.ItemStatus="{Binding TankState}">
              <Grid ColumnDefinitions="120,1.5*,110,110,110,1.2*,*">
                <TextBlock Grid.Column="0" Text="{Binding Date}" />
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding FuelType}" />
                  <TextBlock Opacity="0.75" Text="{Binding FuelDetail}" TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding Liters}" />
                <TextBlock Grid.Column="3" Text="{Binding TotalCost}" />
                <TextBlock Grid.Column="4" Text="{Binding Odometer}" />
                <TextBlock Grid.Column="5" Text="{Binding Station}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="6" Text="{Binding TankState}" TextWrapping="Wrap" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <Border Grid.Row="1"
            Grid.Column="1"
            Margin="12,16,0,0"
            Padding="16"
            Background="#10203040"
            CornerRadius="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    AutomationProperties.Name="Panel tankování vozidla"
                    AutomationProperties.AutomationId="FuelEditorScrollViewer">
      <Grid RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding FuelPanelHeading}" />
        <WrapPanel x:Name="FuelActionPanel"
                   Grid.Row="1"
                   Margin="0,14,0,0"
                   ItemWidth="122"
                   ItemHeight="34">
          <Button Command="{Binding CreateFuelCommand}"
                  Content="Nové"
                  AutomationProperties.Name="Vytvořit nové tankování"
                  AutomationProperties.AutomationId="CreateFuelButton" />
          <Button Command="{Binding EditSelectedFuelCommand}"
                  Content="Upravit"
                  AutomationProperties.Name="Upravit vybrané tankování"
                  AutomationProperties.AutomationId="EditFuelButton" />
          <Button Command="{Binding DeleteSelectedFuelCommand}"
                  Content="Odstranit"
                  AutomationProperties.Name="Odstranit vybrané tankování"
                  AutomationProperties.HelpText="Otevře potvrzení a při potvrzení odstraní vybraný záznam tankování."
                  AutomationProperties.AutomationId="DeleteFuelButton" />
          <Button Command="{Binding SaveFuelCommand}"
                  Content="Uložit"
                  IsVisible="{Binding IsEditingFuel}"
                  AutomationProperties.Name="Uložit tankování"
                  AutomationProperties.AutomationId="SaveFuelButton" />
          <Button Command="{Binding CancelFuelEditCommand}"
                  Content="Zrušit"
                  IsVisible="{Binding IsEditingFuel}"
                  AutomationProperties.Name="Zrušit úpravu tankování"
                  AutomationProperties.AutomationId="CancelFuelButton" />
        </WrapPanel>
        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Opacity="0.82"
                   Text="{Binding FuelEditorStatus}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding FuelEditorStatus}"
                   AutomationProperties.AutomationId="FuelEditorStatusText"
                   AutomationProperties.LiveSetting="Polite" />
        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0"
                    Spacing="18">
          <Border x:Name="FuelEditorHost">
            <Grid IsVisible="{Binding IsEditingFuel}"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
            <Grid ColumnDefinitions="*,160">
              <StackPanel Margin="0,0,12,0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Datum" />
                <TextBox x:Name="FuelEditorDateBox"
                         Text="{Binding FuelEditorDate}"
                         PlaceholderText="Například 15.06.2026"
                         AutomationProperties.Name="Datum tankování"
                         AutomationProperties.HelpText="Například 15.06.2026"
                         AutomationProperties.AutomationId="FuelEditorDateBox"
                         AutomationProperties.IsRequiredForForm="True" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Typ paliva" />
                <ComboBox x:Name="FuelEditorFuelTypeBox"
                          ItemsSource="{Binding FuelTypeOptions}"
                          SelectedItem="{Binding FuelEditorFuelType}"
                          AutomationProperties.Name="Typ paliva"
                          AutomationProperties.AutomationId="FuelEditorFuelTypeBox" />
              </StackPanel>
            </Grid>
            <Grid Grid.Row="1"
                  Margin="0,14,0,0"
                  ColumnDefinitions="*,*">
              <StackPanel Margin="0,0,12,0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Detail paliva" />
                <TextBox x:Name="FuelEditorFuelDetailBox"
                         Text="{Binding FuelEditorFuelDetail}"
                         PlaceholderText="Například Natural 95, V-Power nebo FuelSave"
                         AutomationProperties.Name="Detail paliva"
                         AutomationProperties.HelpText="Například Natural 95, V-Power nebo FuelSave"
                         AutomationProperties.AutomationId="FuelEditorFuelDetailBox" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Místo tankování" />
                <TextBox x:Name="FuelEditorStationBox"
                         Text="{Binding FuelEditorStation}"
                         PlaceholderText="Například Shell Brno Vídeňská"
                         AutomationProperties.Name="Místo tankování"
                         AutomationProperties.HelpText="Například Shell Brno Vídeňská"
                         AutomationProperties.AutomationId="FuelEditorStationBox" />
              </StackPanel>
            </Grid>
            <Grid Grid.Row="2"
                  Margin="0,14,0,0"
                  ColumnDefinitions="*,*,*">
              <StackPanel Margin="0,0,12,0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Množství" />
                <TextBox x:Name="FuelEditorLitersBox"
                         Text="{Binding FuelEditorLiters}"
                         AutomationProperties.Name="Množství tankovaného paliva"
                         AutomationProperties.AutomationId="FuelEditorLitersBox" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Cena celkem" />
                <TextBox x:Name="FuelEditorTotalCostBox"
                         Text="{Binding FuelEditorTotalCost}"
                         AutomationProperties.Name="Cena tankování celkem"
                         AutomationProperties.AutomationId="FuelEditorTotalCostBox" />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Tachometr" />
                <TextBox x:Name="FuelEditorOdometerBox"
                         Text="{Binding FuelEditorOdometer}"
                         AutomationProperties.Name="Tachometr při tankování"
                         AutomationProperties.AutomationId="FuelEditorOdometerBox"
                         AutomationProperties.IsRequiredForForm="True" />
              </StackPanel>
            </Grid>
            <CheckBox Grid.Row="3"
                      Margin="0,14,0,0"
                      IsChecked="{Binding FuelEditorFullTank}"
                      Content="Plná nádrž"
                      AutomationProperties.Name="Tankování do plné nádrže"
                      AutomationProperties.AutomationId="FuelEditorFullTankCheckBox" />
            <TextBlock Grid.Row="4"
                       Margin="0,14,0,0"
                       FontWeight="SemiBold"
                       Text="Poznámka" />
            <TextBox Grid.Row="5"
                     Margin="0,6,0,0"
                     Height="120"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"
                     Text="{Binding FuelEditorNote}"
                     AutomationProperties.Name="Poznámka k tankování"
                     AutomationProperties.AutomationId="FuelEditorNoteBox" />
            </Grid>
          </Border>
          <StackPanel IsVisible="{Binding IsFuelDetailVisible}"
                      Spacing="16">
            <TextBlock Text="{Binding SelectedFuelDetail}"
                       TextWrapping="Wrap"
                       AutomationProperties.Name="{Binding SelectedFuelDetail}"
                       AutomationProperties.AutomationId="SelectedFuelDetailText" />
            <Border Height="1" Background="#20304050" />
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="Analýza tankování"
                       AutomationProperties.Name="Analýza tankování"
                       AutomationProperties.AutomationId="FuelAnalysisHeadingText"
                       AutomationProperties.HeadingLevel="2" />
            <TextBlock Text="{Binding FuelAnalysisSummaryText}"
                       TextWrapping="Wrap"
                       AutomationProperties.Name="{Binding FuelAnalysisSummaryText}"
                       AutomationProperties.AutomationId="FuelAnalysisSummaryText" />
            <TextBlock FontWeight="SemiBold"
                       Text="Vývoj spotřeby"
                       AutomationProperties.Name="Vývoj spotřeby"
                       AutomationProperties.AutomationId="FuelConsumptionSegmentsHeadingText"
                       AutomationProperties.HeadingLevel="2" />
            <ListBox MinHeight="110"
                     MaxHeight="180"
                     ItemsSource="{Binding FuelConsumptionSegments}"
                     SelectedItem="{Binding SelectedFuelConsumptionSegment}"
                     AutomationProperties.Name="Vývoj spotřeby tankování"
                     AutomationProperties.AutomationId="FuelConsumptionSegmentsListBox">
              <ListBox.KeyBindings>
                <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedFuelConsumptionSegmentCommand}" />
              </ListBox.KeyBindings>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="itemvm:FuelConsumptionSegmentItemViewModel">
                  <Border Padding="10"
                          Margin="0,0,0,6"
                          Background="#10203040"
                          CornerRadius="6"
                          AutomationProperties.Name="{Binding AccessibleLabel}"
                          AutomationProperties.ItemType="Úsek spotřeby">
                    <StackPanel>
                      <TextBlock Text="{Binding Period}" />
                      <TextBlock Opacity="0.78" Text="{Binding Consumption}" />
                      <TextBlock Opacity="0.78" Text="{Binding Distance}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <Button Command="{Binding OpenSelectedFuelConsumptionSegmentCommand}"
                    Content="Otevřít tankování úseku"
                    AutomationProperties.Name="Otevřít tankování vybraného úseku spotřeby"
                    AutomationProperties.AutomationId="OpenFuelConsumptionSegmentButton" />
            <TextBlock FontWeight="SemiBold"
                       Text="Místa a paliva"
                       AutomationProperties.Name="Místa a paliva"
                       AutomationProperties.AutomationId="FuelGroupSummariesHeadingText"
                       AutomationProperties.HeadingLevel="2" />
            <ListBox MinHeight="110"
                     MaxHeight="180"
                     ItemsSource="{Binding FuelGroupSummaries}"
                     SelectedItem="{Binding SelectedFuelGroupSummary}"
                     AutomationProperties.Name="Místa tankování a paliva"
                     AutomationProperties.AutomationId="FuelGroupSummariesListBox">
              <ListBox.KeyBindings>
                <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedFuelGroupSummaryCommand}" />
              </ListBox.KeyBindings>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="itemvm:FuelGroupSummaryItemViewModel">
                  <Border Padding="10"
                          Margin="0,0,0,6"
                          Background="#10203040"
                          CornerRadius="6"
                          AutomationProperties.Name="{Binding AccessibleLabel}"
                          AutomationProperties.ItemType="Souhrn místa a paliva">
                    <StackPanel>
                      <TextBlock Text="{Binding Station}" />
                      <TextBlock Opacity="0.78" Text="{Binding Fuel}" />
                      <TextBlock Opacity="0.78" Text="{Binding AveragePricePerLiter}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <Button Command="{Binding OpenSelectedFuelGroupSummaryCommand}"
                    Content="Otevřít poslední tankování skupiny"
                    AutomationProperties.Name="Otevřít poslední tankování vybrané skupiny místa a paliva"
                    AutomationProperties.AutomationId="OpenFuelGroupSummaryButton" />
            <TextBlock FontWeight="SemiBold"
                       Text="Upozornění"
                       AutomationProperties.Name="Upozornění analýzy tankování"
                       AutomationProperties.AutomationId="FuelAnalysisWarningsHeadingText"
                       AutomationProperties.HeadingLevel="2" />
            <ListBox MinHeight="110"
                     MaxHeight="180"
                     ItemsSource="{Binding FuelAnalysisWarnings}"
                     SelectedItem="{Binding SelectedFuelAnalysisWarning}"
                     AutomationProperties.Name="Upozornění analýzy tankování"
                     AutomationProperties.AutomationId="FuelAnalysisWarningsListBox">
              <ListBox.KeyBindings>
                <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedFuelAnalysisWarningCommand}" />
              </ListBox.KeyBindings>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="itemvm:FuelAnalysisWarningItemViewModel">
                  <Border Padding="10"
                          Margin="0,0,0,6"
                          Background="#10203040"
                          CornerRadius="6"
                          AutomationProperties.Name="{Binding AccessibleLabel}"
                          AutomationProperties.ItemType="Upozornění analýzy tankování"
                          AutomationProperties.ItemStatus="{Binding Severity}">
                    <StackPanel>
                      <TextBlock Text="{Binding Title}" />
                      <TextBlock Opacity="0.78" Text="{Binding Severity}" />
                      <TextBlock Opacity="0.78" Text="{Binding Description}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <Button Command="{Binding OpenSelectedFuelAnalysisWarningCommand}"
                    Content="Otevřít související tankování"
                    AutomationProperties.Name="Otevřít tankování související s vybraným upozorněním"
                    AutomationProperties.AutomationId="OpenFuelAnalysisWarningButton" />
          </StackPanel>
        </StackPanel>
      </Grid>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
