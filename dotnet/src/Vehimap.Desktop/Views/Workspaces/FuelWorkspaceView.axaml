<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="using:Vehimap.Desktop.Localization"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.FuelWorkspaceView"
             x:DataType="vm:FuelWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+N" Command="{Binding CreateFuelCommand}" />
    <KeyBinding Gesture="Ctrl+U" Command="{Binding EditSelectedFuelCommand}" />
    <KeyBinding Gesture="F2" Command="{Binding EditSelectedFuelCommand}" />
  </UserControl.KeyBindings>
  <Grid ColumnDefinitions="1.15*,*" RowDefinitions="Auto,*">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding FuelSummary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding FuelSummary}"
               AutomationProperties.AutomationId="FuelSummaryText" />
    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="0,16,0,0">
      <TextBlock FontWeight="SemiBold"
                 Text="{i18n:Loc FuelWorkspace.Title}" />
      <Grid Grid.Row="1" Margin="0,10,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="{i18n:Loc Common.Search}" />
        <TextBox x:Name="FuelSearchBox"
                 Grid.Column="1"
                 Text="{Binding FuelSearchText}"
                 PlaceholderText="{i18n:Loc FuelWorkspace.SearchPlaceholder}"
                 AutomationProperties.Name="{i18n:Loc FuelWorkspace.SearchName}"
                 AutomationProperties.HelpText="{i18n:Loc FuelWorkspace.SearchHelp}"
                 AutomationProperties.AutomationId="FuelSearchBox" />
        <Button Grid.Column="2"
                Margin="12,0,0,0"
                Command="{Binding ClearFuelSearchCommand}"
                Content="{i18n:Loc Common.Clear}"
                AutomationProperties.Name="{i18n:Loc FuelWorkspace.ClearSearchName}"
                AutomationProperties.AutomationId="ClearFuelSearchButton" />
      </Grid>
      <Grid Grid.Row="2" Margin="0,8,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="{i18n:Loc Common.Sort}" />
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding FuelSortOptions}"
                  SelectedItem="{Binding SelectedFuelSortOption}"
                  AutomationProperties.Name="{i18n:Loc FuelWorkspace.SortName}"
                  AutomationProperties.AutomationId="FuelSortComboBox" />
        <CheckBox Grid.Column="2"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Content="{i18n:Loc Common.SortDescending}"
                  IsChecked="{Binding FuelSortDescending}"
                  AutomationProperties.Name="{i18n:Loc FuelWorkspace.SortDescendingName}"
                  AutomationProperties.AutomationId="FuelSortDescendingCheckBox" />
      </Grid>
      <TextBlock Grid.Row="3"
                 Margin="0,8,12,0"
                 Opacity="0.72"
                 Text="{Binding FuelSearchSummary}"
                 TextWrapping="Wrap"
                 AutomationProperties.Name="{Binding FuelSearchSummary}"
                 AutomationProperties.AutomationId="FuelSearchSummaryText" />
      <ListBox x:Name="FuelListBox"
               Grid.Row="4"
               Margin="0,12,12,0"
               ItemsSource="{Binding VisibleFuelItems}"
               SelectedItem="{Binding SelectedFuel}"
               AutomationProperties.Name="{i18n:Loc FuelWorkspace.ListName}"
               AutomationProperties.AutomationId="FuelListBox">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="itemvm:VehicleFuelItemViewModel">
            <Border Padding="12"
                    Margin="0,0,0,8"
                    Background="#10203040"
                    CornerRadius="6"
                    AutomationProperties.Name="{Binding AccessibleLabel}"
                    AutomationProperties.ItemType="{i18n:Loc FuelWorkspace.ItemType}"
                    AutomationProperties.ItemStatus="{Binding TankState}">
              <Grid ColumnDefinitions="120,1.5*,110,110,110,1.2*,*">
                <TextBlock Grid.Column="0" Text="{Binding Date}" />
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding FuelType}" />
                  <TextBlock Opacity="0.75" Text="{Binding FuelDetail}" TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding Liters}" />
                <TextBlock Grid.Column="3" Text="{Binding TotalCost}" />
                <TextBlock Grid.Column="4" Text="{Binding Odometer}" />
                <TextBlock Grid.Column="5" Text="{Binding Station}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="6" Text="{Binding TankState}" TextWrapping="Wrap" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <Border Grid.Row="1"
            Grid.Column="1"
            Margin="12,16,0,0"
            Padding="16"
            Background="#10203040"
            CornerRadius="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    AutomationProperties.Name="{i18n:Loc FuelWorkspace.DetailName}"
                    AutomationProperties.AutomationId="FuelDetailScrollViewer">
        <StackPanel Spacing="16">
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="{Binding FuelPanelHeading}" />
          <WrapPanel x:Name="FuelActionPanel"
                     ItemWidth="122"
                     ItemHeight="34">
            <Button Command="{Binding CreateFuelCommand}"
                    Content="{i18n:Loc FuelWorkspace.Create}"
                    AutomationProperties.Name="{i18n:Loc FuelWorkspace.CreateName}"
                    AutomationProperties.AutomationId="CreateFuelButton" />
            <Button Command="{Binding EditSelectedFuelCommand}"
                    Content="{i18n:Loc Common.Edit}"
                    AutomationProperties.Name="{i18n:Loc FuelWorkspace.EditName}"
                    AutomationProperties.AutomationId="EditFuelButton" />
            <Button Command="{Binding DeleteSelectedFuelCommand}"
                    Content="{i18n:Loc Common.Delete}"
                    AutomationProperties.Name="{i18n:Loc FuelWorkspace.DeleteName}"
                    AutomationProperties.HelpText="{i18n:Loc FuelWorkspace.DeleteHelp}"
                    AutomationProperties.AutomationId="DeleteFuelButton" />
          </WrapPanel>
          <TextBlock Opacity="0.82"
                     Text="{Binding FuelEditorStatus}"
                     TextWrapping="Wrap"
                     AutomationProperties.Name="{Binding FuelEditorStatus}"
                     AutomationProperties.AutomationId="FuelStatusText"
                     AutomationProperties.LiveSetting="Polite" />
          <TextBlock Text="{Binding SelectedFuelDetail}"
                     TextWrapping="Wrap"
                     AutomationProperties.Name="{Binding SelectedFuelDetail}"
                     AutomationProperties.AutomationId="SelectedFuelDetailText" />
          <Border Height="1" Background="#20304050" />
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="{i18n:Loc FuelWorkspace.AnalysisHeading}"
                     AutomationProperties.Name="{i18n:Loc FuelWorkspace.AnalysisHeading}"
                     AutomationProperties.AutomationId="FuelAnalysisHeadingText"
                     AutomationProperties.HeadingLevel="2" />
          <TextBlock Text="{Binding FuelAnalysisSummaryText}"
                     TextWrapping="Wrap"
                     AutomationProperties.Name="{Binding FuelAnalysisSummaryText}"
                     AutomationProperties.AutomationId="FuelAnalysisSummaryText" />
          <TextBlock FontWeight="SemiBold"
                     Text="{i18n:Loc FuelWorkspace.ConsumptionHeading}"
                     AutomationProperties.Name="{i18n:Loc FuelWorkspace.ConsumptionHeading}"
                     AutomationProperties.AutomationId="FuelConsumptionSegmentsHeadingText"
                     AutomationProperties.HeadingLevel="2" />
          <ListBox MinHeight="110"
                   MaxHeight="180"
                   ItemsSource="{Binding FuelConsumptionSegments}"
                   SelectedItem="{Binding SelectedFuelConsumptionSegment}"
                   AutomationProperties.Name="{i18n:Loc FuelWorkspace.ConsumptionListName}"
                   AutomationProperties.AutomationId="FuelConsumptionSegmentsListBox">
            <ListBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedFuelConsumptionSegmentCommand}" />
            </ListBox.KeyBindings>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="itemvm:FuelConsumptionSegmentItemViewModel">
                <Border Padding="10"
                        Margin="0,0,0,6"
                        Background="#10203040"
                        CornerRadius="6"
                        AutomationProperties.Name="{Binding AccessibleLabel}"
                        AutomationProperties.ItemType="{i18n:Loc FuelWorkspace.ConsumptionItemType}">
                  <StackPanel>
                    <TextBlock Text="{Binding Period}" />
                    <TextBlock Opacity="0.78" Text="{Binding Consumption}" />
                    <TextBlock Opacity="0.78" Text="{Binding Distance}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Button Command="{Binding OpenSelectedFuelConsumptionSegmentCommand}"
                  Content="{i18n:Loc FuelWorkspace.OpenConsumptionSegment}"
                  AutomationProperties.Name="{i18n:Loc FuelWorkspace.OpenConsumptionSegmentName}"
                  AutomationProperties.AutomationId="OpenFuelConsumptionSegmentButton" />
          <TextBlock FontWeight="SemiBold"
                     Text="{i18n:Loc FuelWorkspace.GroupsHeading}"
                     AutomationProperties.Name="{i18n:Loc FuelWorkspace.GroupsHeading}"
                     AutomationProperties.AutomationId="FuelGroupSummariesHeadingText"
                     AutomationProperties.HeadingLevel="2" />
          <ListBox MinHeight="110"
                   MaxHeight="180"
                   ItemsSource="{Binding FuelGroupSummaries}"
                   SelectedItem="{Binding SelectedFuelGroupSummary}"
                   AutomationProperties.Name="{i18n:Loc FuelWorkspace.GroupsListName}"
                   AutomationProperties.AutomationId="FuelGroupSummariesListBox">
            <ListBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedFuelGroupSummaryCommand}" />
            </ListBox.KeyBindings>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="itemvm:FuelGroupSummaryItemViewModel">
                <Border Padding="10"
                        Margin="0,0,0,6"
                        Background="#10203040"
                        CornerRadius="6"
                        AutomationProperties.Name="{Binding AccessibleLabel}"
                        AutomationProperties.ItemType="{i18n:Loc FuelWorkspace.GroupItemType}">
                  <StackPanel>
                    <TextBlock Text="{Binding Station}" />
                    <TextBlock Opacity="0.78" Text="{Binding Fuel}" />
                    <TextBlock Opacity="0.78" Text="{Binding AveragePricePerLiter}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Button Command="{Binding OpenSelectedFuelGroupSummaryCommand}"
                  Content="{i18n:Loc FuelWorkspace.OpenGroupSummary}"
                  AutomationProperties.Name="{i18n:Loc FuelWorkspace.OpenGroupSummaryName}"
                  AutomationProperties.AutomationId="OpenFuelGroupSummaryButton" />
          <TextBlock FontWeight="SemiBold"
                     Text="{i18n:Loc FuelWorkspace.WarningsHeading}"
                     AutomationProperties.Name="{i18n:Loc FuelWorkspace.WarningsName}"
                     AutomationProperties.AutomationId="FuelAnalysisWarningsHeadingText"
                     AutomationProperties.HeadingLevel="2" />
          <ListBox MinHeight="110"
                   MaxHeight="180"
                   ItemsSource="{Binding FuelAnalysisWarnings}"
                   SelectedItem="{Binding SelectedFuelAnalysisWarning}"
                   AutomationProperties.Name="{i18n:Loc FuelWorkspace.WarningsName}"
                   AutomationProperties.AutomationId="FuelAnalysisWarningsListBox">
            <ListBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedFuelAnalysisWarningCommand}" />
            </ListBox.KeyBindings>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="itemvm:FuelAnalysisWarningItemViewModel">
                <Border Padding="10"
                        Margin="0,0,0,6"
                        Background="#10203040"
                        CornerRadius="6"
                        AutomationProperties.Name="{Binding AccessibleLabel}"
                        AutomationProperties.ItemType="{i18n:Loc FuelWorkspace.WarningItemType}"
                        AutomationProperties.ItemStatus="{Binding Severity}">
                  <StackPanel>
                    <TextBlock Text="{Binding Title}" />
                    <TextBlock Opacity="0.78" Text="{Binding Severity}" />
                    <TextBlock Opacity="0.78" Text="{Binding Description}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Button Command="{Binding OpenSelectedFuelAnalysisWarningCommand}"
                  Content="{i18n:Loc FuelWorkspace.OpenWarning}"
                  AutomationProperties.Name="{i18n:Loc FuelWorkspace.OpenWarningName}"
                  AutomationProperties.AutomationId="OpenFuelAnalysisWarningButton" />
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
