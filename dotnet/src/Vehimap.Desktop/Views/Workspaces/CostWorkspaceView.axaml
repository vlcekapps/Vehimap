<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.CostWorkspaceView"
             x:DataType="vm:CostWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding RefreshCostCommand}" />
    <KeyBinding Gesture="Ctrl+P" Command="{Binding FocusSelectedCostDetailCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenSelectedCostVehicleCommand}" />
    <KeyBinding Gesture="Ctrl+U" Command="{Binding EditSelectedCostVehicleCommand}" />
    <KeyBinding Gesture="F2" Command="{Binding EditSelectedCostVehicleCommand}" />
  </UserControl.KeyBindings>

  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                AutomationProperties.Name="Obsah nákladového přehledu"
                AutomationProperties.AutomationId="CostWorkspaceScrollViewer">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
    <StackPanel Spacing="8">
      <TextBlock FontWeight="SemiBold"
                 Text="Období nákladů" />
      <Grid ColumnDefinitions="170,150,42,150,Auto" RowDefinitions="Auto,Auto">
        <ComboBox x:Name="CostPeriodPresetComboBox"
                  ItemsSource="{Binding CostPeriodPresets}"
                  SelectedItem="{Binding SelectedCostPeriodPreset}"
                  AutomationProperties.Name="Předvolba období nákladů"
                  AutomationProperties.AutomationId="CostPeriodPresetComboBox" />
        <TextBox x:Name="CostPeriodStartBox"
                 Grid.Column="1"
                 Margin="12,0,0,0"
                 Text="{Binding CostPeriodStartText}"
                 PlaceholderText="Od"
                 AutomationProperties.Name="Začátek období nákladů"
                 AutomationProperties.AutomationId="CostPeriodStartBox" />
        <TextBlock Grid.Column="2"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Text="až" />
        <TextBox x:Name="CostPeriodEndBox"
                 Grid.Column="3"
                 Text="{Binding CostPeriodEndText}"
                 PlaceholderText="Do"
                 AutomationProperties.Name="Konec období nákladů"
                 AutomationProperties.AutomationId="CostPeriodEndBox" />
        <Button Grid.Column="4"
                Margin="12,0,0,0"
                Command="{Binding ApplyCostPeriodCommand}"
                Content="Přepočítat"
                AutomationProperties.Name="Přepočítat náklady pro zadané období"
                AutomationProperties.AutomationId="ApplyCostPeriodButton" />
        <TextBlock Grid.Row="1"
                   Grid.ColumnSpan="5"
                   Margin="0,6,0,0"
                   Opacity="0.72"
                   Text="{Binding CostPeriodStatus}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding CostPeriodStatus}"
                   AutomationProperties.AutomationId="CostPeriodStatusText"
                   AutomationProperties.LiveSetting="Polite" />
      </Grid>
    </StackPanel>

    <TextBlock Grid.Row="1"
               Margin="0,10,0,0"
               Text="{Binding CostSummary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding CostSummary}"
               AutomationProperties.AutomationId="CostSummaryText" />
    <TextBlock Grid.Row="2"
               Margin="0,8,0,0"
               Opacity="0.75"
               Text="{Binding CostComparison}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding CostComparison}"
               AutomationProperties.AutomationId="CostComparisonText" />
    <StackPanel Grid.Row="3"
                Margin="0,12,0,0"
                Orientation="Horizontal"
                Spacing="10">
      <Button Command="{Binding ExportFleetCostSummaryCommand}"
              Content="Export souhrnu TSV"
              AutomationProperties.Name="Exportovat souhrn nákladů do TSV"
              AutomationProperties.AutomationId="ExportFleetCostSummaryButton" />
      <Button Command="{Binding ExportSelectedVehicleCostDetailCommand}"
              Content="Export detailu TSV"
              AutomationProperties.Name="Exportovat detail nákladů vybraného vozidla do TSV"
              AutomationProperties.AutomationId="ExportSelectedVehicleCostDetailButton" />
      <Button Command="{Binding ExportSelectedVehicleCostReportCommand}"
              Content="Export HTML sestavy"
              AutomationProperties.Name="Exportovat HTML sestavu nákladů vybraného vozidla"
              AutomationProperties.AutomationId="ExportSelectedVehicleCostReportButton" />
    </StackPanel>
    <StackPanel Grid.Row="4"
                Margin="0,10,0,0"
                Orientation="Horizontal"
                Spacing="10">
      <Button Command="{Binding RefreshCostCommand}"
              Content="Obnovit"
              AutomationProperties.Name="Obnovit nákladový přehled"
              AutomationProperties.AutomationId="CostRefreshButton" />
      <Button Command="{Binding FocusSelectedCostDetailCommand}"
              Content="Zobrazit rozpad"
              AutomationProperties.Name="Zobrazit rozpad nákladů vybraného vozidla"
              AutomationProperties.AutomationId="FocusCostDetailButton" />
      <Button Command="{Binding OpenSelectedCostVehicleCommand}"
              Content="Zobrazit vozidlo"
              AutomationProperties.Name="Zobrazit detail vozidla z nákladového přehledu"
              AutomationProperties.AutomationId="OpenCostVehicleButton" />
      <Button Command="{Binding EditSelectedCostVehicleCommand}"
              Content="Upravit vozidlo"
              AutomationProperties.Name="Upravit vozidlo z nákladového přehledu"
              AutomationProperties.AutomationId="EditCostVehicleButton" />
    </StackPanel>
    <TextBlock Grid.Row="5"
               Margin="0,8,0,0"
               Text="{Binding CostExportStatus}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding CostExportStatus}"
               AutomationProperties.AutomationId="CostExportStatusText"
               AutomationProperties.LiveSetting="Polite" />
    <Border x:Name="SelectedCostVehicleDetailHost"
            Grid.Row="6"
            Margin="0,12,0,0"
            Padding="12"
            Background="#10203040"
            CornerRadius="6"
            Focusable="True"
            AutomationProperties.Name="{Binding SelectedCostVehicleDetail}"
            AutomationProperties.AutomationId="SelectedCostVehicleDetailText">
      <TextBlock Text="{Binding SelectedCostVehicleDetail}"
                 TextWrapping="Wrap" />
    </Border>
    <Grid Grid.Row="7" Margin="0,12,0,0" ColumnDefinitions="80,*,120">
      <TextBlock VerticalAlignment="Center" Text="Hledat" />
      <TextBox x:Name="CostSearchBox"
               Grid.Column="1"
               Text="{Binding CostSearchText}"
               PlaceholderText="Vozidlo, kategorie, částka, cena za km nebo stav výpočtu..."
               AutomationProperties.Name="Hledání v nákladovém přehledu"
               AutomationProperties.AutomationId="CostSearchBox" />
      <Button Grid.Column="2"
              Margin="12,0,0,0"
              Command="{Binding ClearCostSearchCommand}"
              Content="Vymazat"
              AutomationProperties.Name="Vymazat hledání v nákladovém přehledu"
              AutomationProperties.AutomationId="ClearCostSearchButton" />
    </Grid>
    <TextBlock Grid.Row="8"
               Margin="0,8,0,0"
               Opacity="0.72"
               Text="{Binding CostSearchSummary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding CostSearchSummary}"
               AutomationProperties.AutomationId="CostSearchSummaryText" />
    <ListBox x:Name="CostListBox"
             Grid.Row="9"
             Margin="0,12,0,0"
             ItemsSource="{Binding VisibleCostVehicles}"
             SelectedItem="{Binding SelectedDashboardCostVehicle}"
             AutomationProperties.Name="Seznam nákladových souhrnů vozidel"
             AutomationProperties.AutomationId="CostListBox">
      <ListBox.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedCostVehicleCommand}" />
      </ListBox.KeyBindings>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="itemvm:CostVehicleItemViewModel">
          <Border Padding="12"
                  Margin="0,0,0,8"
                  Background="#10203040"
                  CornerRadius="6"
                  AutomationProperties.Name="{Binding AccessibleLabel}">
            <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*,1.5*">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding VehicleName}" />
                <TextBlock Opacity="0.8" Text="{Binding Category}" />
              </StackPanel>
              <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TotalCost}" />
              <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Distance}" />
              <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding CostPerKm}" />
              <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding Status}" TextWrapping="Wrap" />
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
  </ScrollViewer>
</UserControl>
