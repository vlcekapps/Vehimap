<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.CostWorkspaceView"
             x:DataType="vm:CostWorkspaceViewModel">
  <Grid RowDefinitions="Auto,Auto,*">
    <TextBlock Text="{Binding CostSummary}" TextWrapping="Wrap" />
    <TextBlock Grid.Row="1"
               Margin="0,8,0,0"
               Opacity="0.75"
               Text="{Binding CostComparison}"
               TextWrapping="Wrap" />
    <ListBox x:Name="CostListBox"
             Grid.Row="2"
             Margin="0,12,0,0"
             ItemsSource="{Binding CostVehicles}"
             SelectedItem="{Binding SelectedDashboardCostVehicle}"
             AutomationProperties.Name="Seznam nákladových souhrnů vozidel">
      <ListBox.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedDashboardCostVehicleCommand}" />
      </ListBox.KeyBindings>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="itemvm:CostVehicleItemViewModel">
          <Border Padding="12"
                  Margin="0,0,0,8"
                  Background="#10203040"
                  CornerRadius="6"
                  AutomationProperties.Name="{Binding AccessibleLabel}">
            <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*,1.5*">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding VehicleName}" />
                <TextBlock Opacity="0.8" Text="{Binding Category}" />
              </StackPanel>
              <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TotalCost}" />
              <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Distance}" />
              <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding CostPerKm}" />
              <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding Status}" TextWrapping="Wrap" />
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
