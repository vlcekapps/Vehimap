<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.MaintenanceWorkspaceView"
             x:DataType="vm:MaintenanceWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+N" Command="{Binding CreateMaintenanceCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+N" Command="{Binding OpenMaintenanceTemplatesCommand}" />
    <KeyBinding Gesture="Ctrl+U" Command="{Binding EditSelectedMaintenanceCommand}" />
    <KeyBinding Gesture="F2" Command="{Binding EditSelectedMaintenanceCommand}" />
    <KeyBinding Gesture="Ctrl+L" Command="{Binding CompleteSelectedMaintenanceCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveMaintenanceCommand}" />
  </UserControl.KeyBindings>
  <Grid ColumnDefinitions="1.15*,*" RowDefinitions="Auto,*">
    <TextBlock Grid.ColumnSpan="2" Text="{Binding MaintenanceSummary}" TextWrapping="Wrap" AutomationProperties.Name="{Binding MaintenanceSummary}" AutomationProperties.AutomationId="MaintenanceSummaryText" />
    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="0,16,0,0">
      <TextBlock FontWeight="SemiBold" Text="Servisní plány vybraného vozidla" />
      <Grid Grid.Row="1" Margin="0,10,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="Hledat" />
        <TextBox x:Name="MaintenanceSearchBox"
                 Grid.Column="1"
                 Text="{Binding MaintenanceSearchText}"
                 PlaceholderText="Úkon, interval, poslední servis, stav nebo poznámka..."
                 AutomationProperties.Name="Hledání v plánu údržby"
                 AutomationProperties.HelpText="Úkon, interval, poslední servis, stav nebo poznámka"
                 AutomationProperties.AutomationId="MaintenanceSearchBox" />
        <Button Grid.Column="2"
                Margin="12,0,0,0"
                Command="{Binding ClearMaintenanceSearchCommand}"
                Content="Vymazat"
                AutomationProperties.Name="Vymazat hledání v plánu údržby"
                AutomationProperties.AutomationId="ClearMaintenanceSearchButton" />
      </Grid>
      <Grid Grid.Row="2" Margin="0,8,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="Řadit" />
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding MaintenanceSortOptions}"
                  SelectedItem="{Binding SelectedMaintenanceSortOption}"
                  AutomationProperties.Name="Řazení plánu údržby"
                  AutomationProperties.AutomationId="MaintenanceSortComboBox" />
        <CheckBox Grid.Column="2"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Content="Sestupně"
                  IsChecked="{Binding MaintenanceSortDescending}"
                  AutomationProperties.Name="Řadit plán údržby sestupně"
                  AutomationProperties.AutomationId="MaintenanceSortDescendingCheckBox" />
      </Grid>
      <TextBlock Grid.Row="3" Margin="0,8,12,0" Opacity="0.72" Text="{Binding MaintenanceSearchSummary}" TextWrapping="Wrap" AutomationProperties.Name="{Binding MaintenanceSearchSummary}" AutomationProperties.AutomationId="MaintenanceSearchSummaryText" />
      <ListBox x:Name="MaintenanceListBox"
               Grid.Row="4"
               Margin="0,12,12,0"
               ItemsSource="{Binding VisibleMaintenanceItems}"
               SelectedItem="{Binding SelectedMaintenance}"
               AutomationProperties.Name="Plán údržby vybraného vozidla"
               AutomationProperties.AutomationId="MaintenanceListBox">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="itemvm:VehicleMaintenanceItemViewModel">
            <Border Padding="12" Margin="0,0,0,8" Background="#10203040" CornerRadius="6" AutomationProperties.Name="{Binding AccessibleLabel}" AutomationProperties.ItemType="Servisní plán" AutomationProperties.ItemStatus="{Binding Status}">
              <Grid ColumnDefinitions="2*,170,170,180,*">
                <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="1" Text="{Binding Interval}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="2" Text="{Binding LastService}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="3" Text="{Binding Status}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <Border Grid.Row="1" Grid.Column="1" Margin="12,16,0,0" Padding="16" Background="#10203040" CornerRadius="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    AutomationProperties.Name="Panel plánu údržby"
                    AutomationProperties.AutomationId="MaintenanceEditorScrollViewer">
      <Grid RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding MaintenancePanelHeading}"
                   AutomationProperties.Name="{Binding MaintenancePanelHeading}"
                   AutomationProperties.AutomationId="MaintenancePanelHeadingText"
                   AutomationProperties.HeadingLevel="2" />
        <WrapPanel x:Name="MaintenanceActionPanel" Grid.Row="1" Margin="0,14,0,0" ItemWidth="132" ItemHeight="34">
          <Button Command="{Binding CreateMaintenanceCommand}" Content="Nový plán" AutomationProperties.Name="Vytvořit nový servisní plán" AutomationProperties.AutomationId="CreateMaintenanceButton" />
          <Button Command="{Binding OpenMaintenanceTemplatesCommand}" Content="Doporučené" IsEnabled="{Binding CanOpenMaintenanceRecommendations}" AutomationProperties.Name="Otevřít doporučené servisní šablony" AutomationProperties.AutomationId="OpenMaintenanceTemplatesButton" />
          <Button Command="{Binding EditSelectedMaintenanceCommand}" Content="Upravit" AutomationProperties.Name="Upravit vybraný servisní plán" AutomationProperties.AutomationId="EditMaintenanceButton" />
          <Button Command="{Binding DeleteSelectedMaintenanceCommand}" Content="Odstranit" AutomationProperties.Name="Odstranit vybraný servisní plán" AutomationProperties.HelpText="Otevře potvrzení a při potvrzení odstraní vybraný servisní plán." AutomationProperties.AutomationId="DeleteMaintenanceButton" />
          <Button Command="{Binding CompleteSelectedMaintenanceCommand}" Content="Splněno" AutomationProperties.Name="Označit vybraný servisní úkon jako splněný" AutomationProperties.AutomationId="CompleteMaintenanceButton" />
          <Button Command="{Binding SaveMaintenanceCommand}" Content="Uložit" IsVisible="{Binding IsEditingMaintenance}" AutomationProperties.Name="Uložit servisní plán" AutomationProperties.AutomationId="SaveMaintenanceButton" />
          <Button Command="{Binding CancelMaintenanceEditCommand}" Content="Zrušit" IsVisible="{Binding IsEditingMaintenance}" AutomationProperties.Name="Zrušit úpravu servisního plánu" AutomationProperties.AutomationId="CancelMaintenanceButton" />
        </WrapPanel>
        <TextBlock Grid.Row="2" Margin="0,12,0,0" Opacity="0.82" Text="{Binding MaintenanceEditorStatus}" TextWrapping="Wrap" AutomationProperties.Name="{Binding MaintenanceEditorStatus}" AutomationProperties.AutomationId="MaintenanceEditorStatusText" AutomationProperties.LiveSetting="Polite" />
        <Border x:Name="MaintenanceEditorHost" Grid.Row="3" Margin="0,16,0,0">
          <Grid IsVisible="{Binding IsEditingMaintenance}" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock FontWeight="SemiBold" Text="Šablona úkonu" />
          <ComboBox x:Name="MaintenanceTemplateComboBox"
                    Grid.Row="1"
                    Margin="0,6,0,0"
                    ItemsSource="{Binding MaintenanceTemplateOptions}"
                    SelectedItem="{Binding SelectedMaintenanceTemplate}"
                    AutomationProperties.Name="Šablona servisního úkonu"
                    AutomationProperties.AutomationId="MaintenanceTemplateComboBox" />
          <TextBlock Grid.Row="2" Margin="0,14,0,0" FontWeight="SemiBold" Text="Název úkonu" />
          <TextBox x:Name="MaintenanceEditorTitleBox"
                   Grid.Row="3"
                   Margin="0,6,0,0"
                   Text="{Binding MaintenanceEditorTitle}"
                   PlaceholderText="Například Motorový olej"
                   AutomationProperties.Name="Název servisního úkonu"
                   AutomationProperties.HelpText="Například Motorový olej"
                   AutomationProperties.AutomationId="MaintenanceEditorTitleBox"
                   AutomationProperties.IsRequiredForForm="True" />
          <Grid Grid.Row="4" Margin="0,14,0,0" ColumnDefinitions="*,*">
            <StackPanel Margin="0,0,12,0" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Interval km" />
              <TextBox x:Name="MaintenanceEditorIntervalKmBox"
                       Text="{Binding MaintenanceEditorIntervalKm}"
                       PlaceholderText="Například 15000"
                       AutomationProperties.Name="Interval údržby v kilometrech"
                       AutomationProperties.HelpText="Například 15000"
                       AutomationProperties.AutomationId="MaintenanceEditorIntervalKmBox" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Interval měsíců" />
              <TextBox x:Name="MaintenanceEditorIntervalMonthsBox"
                       Text="{Binding MaintenanceEditorIntervalMonths}"
                       PlaceholderText="Například 12"
                       AutomationProperties.Name="Interval údržby v měsících"
                       AutomationProperties.HelpText="Například 12"
                       AutomationProperties.AutomationId="MaintenanceEditorIntervalMonthsBox" />
            </StackPanel>
          </Grid>
          <Grid Grid.Row="5" Margin="0,14,0,0" ColumnDefinitions="*,*">
            <StackPanel Margin="0,0,12,0" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Poslední servis - datum" />
              <TextBox x:Name="MaintenanceEditorLastServiceDateBox"
                       Text="{Binding MaintenanceEditorLastServiceDate}"
                       PlaceholderText="Například 15.06.2026"
                       AutomationProperties.Name="Datum posledního servisu"
                       AutomationProperties.HelpText="Například 15.06.2026"
                       AutomationProperties.AutomationId="MaintenanceEditorLastServiceDateBox" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Poslední servis - tachometr" />
              <TextBox x:Name="MaintenanceEditorLastServiceOdometerBox"
                       Text="{Binding MaintenanceEditorLastServiceOdometer}"
                       PlaceholderText="Například 123456"
                       AutomationProperties.Name="Tachometr při posledním servisu"
                       AutomationProperties.HelpText="Například 123456"
                       AutomationProperties.AutomationId="MaintenanceEditorLastServiceOdometerBox" />
            </StackPanel>
          </Grid>
          <CheckBox Grid.Row="6" Margin="0,14,0,0" IsChecked="{Binding MaintenanceEditorIsActive}" Content="Aktivní servisní plán" AutomationProperties.Name="Servisní plán je aktivní" AutomationProperties.AutomationId="MaintenanceEditorIsActiveCheckBox" />
          <TextBlock Grid.Row="7" Margin="0,14,0,0" FontWeight="SemiBold" Text="Poznámka" />
          <TextBox Grid.Row="8" Margin="0,6,0,0" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding MaintenanceEditorNote}" AutomationProperties.Name="Poznámka k servisnímu plánu" AutomationProperties.AutomationId="MaintenanceEditorNoteBox" />
          </Grid>
        </Border>
        <TextBlock Grid.Row="3" Margin="0,16,0,0" IsVisible="{Binding IsMaintenanceDetailVisible}" Text="{Binding SelectedMaintenanceDetail}" TextWrapping="Wrap" AutomationProperties.Name="{Binding SelectedMaintenanceDetail}" AutomationProperties.AutomationId="SelectedMaintenanceDetailText" />
      </Grid>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
