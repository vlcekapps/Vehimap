<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.MaintenanceWorkspaceView"
             x:DataType="vm:MaintenanceWorkspaceViewModel">
  <Grid ColumnDefinitions="1.15*,*" RowDefinitions="Auto,*">
    <TextBlock Grid.ColumnSpan="2" Text="{Binding MaintenanceSummary}" TextWrapping="Wrap" />
    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,16,0,0">
      <TextBlock FontWeight="SemiBold" Text="Servisní plány vybraného vozidla" />
      <ListBox x:Name="MaintenanceListBox"
               Grid.Row="1"
               Margin="0,12,12,0"
               ItemsSource="{Binding SelectedVehicleMaintenance}"
               SelectedItem="{Binding SelectedMaintenance}"
               AutomationProperties.Name="Plán údržby vybraného vozidla">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="itemvm:VehicleMaintenanceItemViewModel">
            <Border Padding="12" Margin="0,0,0,8" Background="#10203040" CornerRadius="6" AutomationProperties.Name="{Binding AccessibleLabel}">
              <Grid ColumnDefinitions="2*,170,170,180,*">
                <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="1" Text="{Binding Interval}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="2" Text="{Binding LastService}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="3" Text="{Binding Status}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <Border Grid.Row="1" Grid.Column="1" Margin="12,16,0,0" Padding="16" Background="#10203040" CornerRadius="8">
      <Grid RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding MaintenancePanelHeading}" />
        <WrapPanel Grid.Row="1" Margin="0,14,0,0" ItemWidth="132" ItemHeight="34">
          <Button Command="{Binding CreateMaintenanceCommand}" Content="Nový plán" AutomationProperties.Name="Vytvořit nový servisní plán" AutomationProperties.AutomationId="CreateMaintenanceButton" />
          <Button Command="{Binding EditSelectedMaintenanceCommand}" Content="Upravit" AutomationProperties.Name="Upravit vybraný servisní plán" AutomationProperties.AutomationId="EditMaintenanceButton" />
          <Button Command="{Binding DeleteSelectedMaintenanceCommand}" Content="Odstranit" AutomationProperties.Name="Odstranit vybraný servisní plán" AutomationProperties.AutomationId="DeleteMaintenanceButton" />
          <Button Command="{Binding SaveMaintenanceCommand}" Content="Uložit" IsVisible="{Binding IsEditingMaintenance}" AutomationProperties.Name="Uložit servisní plán" AutomationProperties.AutomationId="SaveMaintenanceButton" />
          <Button Command="{Binding CancelMaintenanceEditCommand}" Content="Zrušit" IsVisible="{Binding IsEditingMaintenance}" AutomationProperties.Name="Zrušit úpravu servisního plánu" AutomationProperties.AutomationId="CancelMaintenanceButton" />
        </WrapPanel>
        <TextBlock Grid.Row="2" Margin="0,12,0,0" Opacity="0.82" Text="{Binding MaintenanceEditorStatus}" TextWrapping="Wrap" />
        <Grid Grid.Row="3" Margin="0,16,0,0" IsVisible="{Binding IsEditingMaintenance}" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock FontWeight="SemiBold" Text="Název úkonu" />
          <TextBox x:Name="MaintenanceEditorTitleBox" Grid.Row="1" Margin="0,6,0,0" Text="{Binding MaintenanceEditorTitle}" PlaceholderText="Například Motorový olej" AutomationProperties.Name="Název servisního úkonu" AutomationProperties.AutomationId="MaintenanceEditorTitleBox" />
          <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="*,*">
            <StackPanel Margin="0,0,12,0" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Interval km" />
              <TextBox Text="{Binding MaintenanceEditorIntervalKm}" PlaceholderText="Například 15000" AutomationProperties.Name="Interval údržby v kilometrech" AutomationProperties.AutomationId="MaintenanceEditorIntervalKmBox" />
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Interval měsíců" />
              <TextBox Text="{Binding MaintenanceEditorIntervalMonths}" PlaceholderText="Například 12" AutomationProperties.Name="Interval údržby v měsících" AutomationProperties.AutomationId="MaintenanceEditorIntervalMonthsBox" />
            </StackPanel>
          </Grid>
          <Grid Grid.Row="3" Margin="0,14,0,0" ColumnDefinitions="*,*">
            <StackPanel Margin="0,0,12,0" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Poslední servis - datum" />
              <TextBox Text="{Binding MaintenanceEditorLastServiceDate}" PlaceholderText="Například 15.06.2026" AutomationProperties.Name="Datum posledního servisu" AutomationProperties.AutomationId="MaintenanceEditorLastServiceDateBox" />
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Poslední servis - tachometr" />
              <TextBox Text="{Binding MaintenanceEditorLastServiceOdometer}" PlaceholderText="Například 123456" AutomationProperties.Name="Tachometr při posledním servisu" AutomationProperties.AutomationId="MaintenanceEditorLastServiceOdometerBox" />
            </StackPanel>
          </Grid>
          <CheckBox Grid.Row="4" Margin="0,14,0,0" IsChecked="{Binding MaintenanceEditorIsActive}" Content="Aktivní servisní plán" AutomationProperties.Name="Servisní plán je aktivní" AutomationProperties.AutomationId="MaintenanceEditorIsActiveCheckBox" />
          <TextBlock Grid.Row="5" Margin="0,14,0,0" FontWeight="SemiBold" Text="Poznámka" />
          <TextBox Grid.Row="6" Margin="0,6,0,0" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding MaintenanceEditorNote}" AutomationProperties.Name="Poznámka k servisnímu plánu" AutomationProperties.AutomationId="MaintenanceEditorNoteBox" />
        </Grid>
        <TextBlock Grid.Row="3" Margin="0,16,0,0" IsVisible="{Binding IsMaintenanceDetailVisible}" Text="{Binding SelectedMaintenanceDetail}" TextWrapping="Wrap" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
