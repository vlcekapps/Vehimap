<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.TimelineWorkspaceView"
             x:DataType="vm:TimelineWorkspaceViewModel">
  <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.35*,*">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding TimelineSummary}"
               TextWrapping="Wrap" />

    <Grid Grid.Row="1"
          Grid.ColumnSpan="2"
          Margin="0,12,0,0"
          ColumnDefinitions="100,170,100,*">
      <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Zobrazit" />
      <ComboBox x:Name="TimelineFilterComboBox"
                Grid.Column="1"
                ItemsSource="{Binding TimelineFilters}"
                SelectedItem="{Binding SelectedTimelineFilter}"
                AutomationProperties.Name="Filtr časové osy"
                AutomationProperties.AutomationId="TimelineFilterComboBox" />
      <TextBlock Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center" Text="Hledat" />
      <TextBox x:Name="TimelineSearchBox"
               Grid.Column="3"
               Margin="12,0,0,0"
               Text="{Binding TimelineSearchText}"
               PlaceholderText="Položka, stav nebo poznámka"
               AutomationProperties.Name="Hledání v časové ose"
               AutomationProperties.AutomationId="TimelineSearchBox" />
    </Grid>

    <ListBox x:Name="TimelineListBox"
             Grid.Row="2"
             Margin="0,12,12,0"
             ItemsSource="{Binding SelectedVehicleTimeline}"
             SelectedItem="{Binding SelectedTimelineItem}"
             AutomationProperties.Name="Časová osa vybraného vozidla"
             AutomationProperties.AutomationId="TimelineListBox">
      <ListBox.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedTimelineItemCommand}" />
      </ListBox.KeyBindings>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="itemvm:VehicleTimelineItemViewModel">
          <Border Padding="12"
                  Margin="0,0,0,8"
                  Background="#10203040"
                  CornerRadius="6"
                  AutomationProperties.Name="{Binding AccessibleLabel}">
            <Grid ColumnDefinitions="110,150,*">
              <TextBlock Grid.Column="0" Text="{Binding Date}" />
              <TextBlock Grid.Column="1" Text="{Binding KindLabel}" />
              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                <TextBlock Opacity="0.82" Text="{Binding Detail}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.72" Text="{Binding Status}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Border Grid.Row="2"
            Grid.Column="1"
            Margin="12,12,0,0"
            Padding="16"
            Background="#10203040"
            CornerRadius="8">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail časové osy" />
        <Button Grid.Row="1"
                x:Name="TimelineOpenButton"
                Margin="0,12,0,0"
                Width="150"
                HorizontalAlignment="Left"
                Command="{Binding OpenSelectedTimelineItemCommand}"
                Content="Otevřít položku"
                AutomationProperties.Name="Otevřít vybranou položku časové osy"
                AutomationProperties.AutomationId="TimelineOpenButton" />
        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Opacity="0.78"
                   Text="{Binding ExportStatus}"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   Opacity="0.75"
                   Text="Enter nebo tlačítko otevře navazující kartu evidence."
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="4"
                   Margin="0,16,0,0"
                   Text="{Binding SelectedTimelineDetail}"
                   TextWrapping="Wrap" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
