<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="using:Vehimap.Desktop.Localization"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.TimelineWorkspaceView"
             x:DataType="vm:TimelineWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding RefreshTimelineCommand}" />
    <KeyBinding Gesture="Ctrl+P" Command="{Binding OpenSelectedTimelineItemCommand}" />
  </UserControl.KeyBindings>
  <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.35*,*">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding TimelineSummary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding TimelineSummary}"
               AutomationProperties.AutomationId="TimelineSummaryText" />

    <Grid Grid.Row="1"
          Grid.ColumnSpan="2"
          Margin="0,12,0,0"
          ColumnDefinitions="100,170,100,*,120,130">
      <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{i18n:Loc TimelineWorkspace.ShowFilter}" />
      <ComboBox x:Name="TimelineFilterComboBox"
                Grid.Column="1"
                ItemsSource="{Binding TimelineFilters}"
                SelectedItem="{Binding SelectedTimelineFilter}"
                AutomationProperties.Name="{i18n:Loc TimelineWorkspace.FilterName}"
                AutomationProperties.AutomationId="TimelineFilterComboBox" />
      <TextBlock Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center" Text="{i18n:Loc Common.Search}" />
      <TextBox x:Name="TimelineSearchBox"
               Grid.Column="3"
               Margin="12,0,0,0"
               Text="{Binding TimelineSearchText}"
               PlaceholderText="{i18n:Loc TimelineWorkspace.SearchPlaceholder}"
               AutomationProperties.Name="{i18n:Loc TimelineWorkspace.SearchName}"
               AutomationProperties.HelpText="{i18n:Loc TimelineWorkspace.SearchHelp}"
               AutomationProperties.AutomationId="TimelineSearchBox" />
      <Button Grid.Column="4"
              x:Name="ClearTimelineSearchButton"
              Margin="12,0,0,0"
              Width="108"
              Command="{Binding ClearTimelineSearchCommand}"
              Content="{i18n:Loc Common.Clear}"
              AutomationProperties.Name="{i18n:Loc TimelineWorkspace.ClearSearchName}"
              AutomationProperties.AutomationId="ClearTimelineSearchButton" />
      <Button Grid.Column="5"
              x:Name="TimelineRefreshButton"
              Margin="12,0,0,0"
              Width="118"
              Command="{Binding RefreshTimelineCommand}"
              Content="{i18n:Loc TimelineWorkspace.Refresh}"
              AutomationProperties.Name="{i18n:Loc TimelineWorkspace.RefreshName}"
              AutomationProperties.AutomationId="TimelineRefreshButton" />
    </Grid>

    <ListBox x:Name="TimelineListBox"
             Grid.Row="2"
             Margin="0,12,12,0"
             ItemsSource="{Binding SelectedVehicleTimeline}"
             SelectedItem="{Binding SelectedTimelineItem}"
             AutomationProperties.Name="{i18n:Loc TimelineWorkspace.ListName}"
             AutomationProperties.AutomationId="TimelineListBox">
      <ListBox.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedTimelineItemCommand}" />
      </ListBox.KeyBindings>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="itemvm:VehicleTimelineItemViewModel">
          <Border Padding="12"
                  Margin="0,0,0,8"
                  Background="#10203040"
                  CornerRadius="6"
                  AutomationProperties.Name="{Binding AccessibleLabel}"
                  AutomationProperties.ItemType="{i18n:Loc TimelineWorkspace.ItemType}"
                  AutomationProperties.ItemStatus="{Binding Status}">
            <Grid ColumnDefinitions="110,150,*">
              <TextBlock Grid.Column="0" Text="{Binding Date}" />
              <TextBlock Grid.Column="1" Text="{Binding KindLabel}" />
              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                <TextBlock Opacity="0.82" Text="{Binding Detail}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.72" Text="{Binding Status}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Border Grid.Row="2"
            Grid.Column="1"
            Margin="12,12,0,0"
            Padding="16"
            Background="#10203040"
            CornerRadius="8">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{i18n:Loc TimelineWorkspace.DetailHeading}"
                   AutomationProperties.Name="{i18n:Loc TimelineWorkspace.DetailHeading}"
                   AutomationProperties.AutomationId="TimelineDetailHeadingText"
                   AutomationProperties.HeadingLevel="2" />
        <Button Grid.Row="1"
                x:Name="TimelineOpenButton"
                Margin="0,12,0,0"
                Width="150"
                HorizontalAlignment="Left"
                Command="{Binding OpenSelectedTimelineItemCommand}"
                Content="{i18n:Loc TimelineWorkspace.OpenItem}"
                AutomationProperties.Name="{i18n:Loc TimelineWorkspace.OpenItemName}"
                AutomationProperties.AutomationId="TimelineOpenButton" />
        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Opacity="0.78"
                   Text="{Binding ExportStatus}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding ExportStatus}"
                   AutomationProperties.AutomationId="TimelineExportStatusText"
                   AutomationProperties.LiveSetting="Polite" />
        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   Opacity="0.75"
                   Text="{i18n:Loc TimelineWorkspace.KeyboardHelp}"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="4"
                   Margin="0,16,0,0"
                   Text="{Binding SelectedTimelineDetail}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedTimelineDetail}"
                   AutomationProperties.AutomationId="SelectedTimelineDetailText" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
