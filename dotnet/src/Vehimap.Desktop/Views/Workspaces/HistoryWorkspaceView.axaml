<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.HistoryWorkspaceView"
             x:DataType="vm:HistoryWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+N" Command="{Binding CreateHistoryCommand}" />
    <KeyBinding Gesture="Ctrl+U" Command="{Binding EditSelectedHistoryCommand}" />
    <KeyBinding Gesture="F2" Command="{Binding EditSelectedHistoryCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveHistoryCommand}" />
  </UserControl.KeyBindings>
  <Grid ColumnDefinitions="1.15*,*" RowDefinitions="Auto,*">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding HistorySummary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding HistorySummary}"
               AutomationProperties.AutomationId="HistorySummaryText" />
    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="0,16,0,0">
      <TextBlock FontWeight="SemiBold"
                 Text="Historické záznamy vybraného vozidla" />
      <Grid Grid.Row="1" Margin="0,10,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="Hledat" />
        <TextBox x:Name="HistorySearchBox"
                 Grid.Column="1"
                 Text="{Binding HistorySearchText}"
                 PlaceholderText="Datum, typ, tachometr, cena nebo poznámka..."
                 AutomationProperties.Name="Hledání v historii vozidla"
                 AutomationProperties.AutomationId="HistorySearchBox" />
        <Button Grid.Column="2"
                Margin="12,0,0,0"
                Command="{Binding ClearHistorySearchCommand}"
                Content="Vymazat"
                AutomationProperties.Name="Vymazat hledání v historii vozidla"
                AutomationProperties.AutomationId="ClearHistorySearchButton" />
      </Grid>
      <Grid Grid.Row="2" Margin="0,8,12,0" ColumnDefinitions="80,*,120">
        <TextBlock VerticalAlignment="Center" Text="Řadit" />
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding HistorySortOptions}"
                  SelectedItem="{Binding SelectedHistorySortOption}"
                  AutomationProperties.Name="Řazení historie vozidla"
                  AutomationProperties.AutomationId="HistorySortComboBox" />
        <CheckBox Grid.Column="2"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Content="Sestupně"
                  IsChecked="{Binding HistorySortDescending}"
                  AutomationProperties.Name="Řadit historii sestupně"
                  AutomationProperties.AutomationId="HistorySortDescendingCheckBox" />
      </Grid>
      <TextBlock Grid.Row="3"
                 Margin="0,8,12,0"
                 Opacity="0.72"
                 Text="{Binding HistorySearchSummary}"
                 TextWrapping="Wrap"
                 AutomationProperties.Name="{Binding HistorySearchSummary}"
                 AutomationProperties.AutomationId="HistorySearchSummaryText" />
      <ListBox x:Name="HistoryListBox"
               Grid.Row="4"
               Margin="0,12,12,0"
               ItemsSource="{Binding VisibleHistoryItems}"
               SelectedItem="{Binding SelectedHistory}"
               AutomationProperties.Name="Historie vybraného vozidla"
               AutomationProperties.AutomationId="HistoryListBox">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="itemvm:VehicleHistoryItemViewModel">
            <Border Padding="12"
                    Margin="0,0,0,8"
                    Background="#10203040"
                    CornerRadius="6"
                    AutomationProperties.Name="{Binding AccessibleLabel}"
                    AutomationProperties.ItemType="Historický záznam">
              <Grid ColumnDefinitions="120,160,130,120,*">
                <TextBlock Grid.Column="0" Text="{Binding Date}" />
                <TextBlock Grid.Column="1" Text="{Binding EventType}" />
                <TextBlock Grid.Column="2" Text="{Binding Odometer}" />
                <TextBlock Grid.Column="3" Text="{Binding Cost}" />
                <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <Border Grid.Row="1"
            Grid.Column="1"
            Margin="12,16,0,0"
            Padding="16"
            Background="#10203040"
            CornerRadius="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    AutomationProperties.Name="Panel historie vozidla"
                    AutomationProperties.AutomationId="HistoryEditorScrollViewer">
      <Grid RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding HistoryPanelHeading}" />
        <WrapPanel x:Name="HistoryActionPanel"
                   Grid.Row="1"
                   Margin="0,14,0,0"
                   ItemWidth="128"
                   ItemHeight="34">
          <Button Command="{Binding CreateHistoryCommand}"
                  Content="Nový záznam"
                  AutomationProperties.Name="Vytvořit nový historický záznam"
                  AutomationProperties.AutomationId="CreateHistoryButton" />
          <Button Command="{Binding EditSelectedHistoryCommand}"
                  Content="Upravit"
                  AutomationProperties.Name="Upravit vybraný historický záznam"
                  AutomationProperties.AutomationId="EditHistoryButton" />
          <Button Command="{Binding DeleteSelectedHistoryCommand}"
                  Content="Odstranit"
                  AutomationProperties.Name="Odstranit vybraný historický záznam"
                  AutomationProperties.AutomationId="DeleteHistoryButton" />
          <Button Command="{Binding SaveHistoryCommand}"
                  Content="Uložit"
                  IsVisible="{Binding IsEditingHistory}"
                  AutomationProperties.Name="Uložit historický záznam"
                  AutomationProperties.AutomationId="SaveHistoryButton" />
          <Button Command="{Binding CancelHistoryEditCommand}"
                  Content="Zrušit"
                  IsVisible="{Binding IsEditingHistory}"
                  AutomationProperties.Name="Zrušit úpravu historického záznamu"
                  AutomationProperties.AutomationId="CancelHistoryButton" />
        </WrapPanel>
        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Opacity="0.82"
                   Text="{Binding HistoryEditorStatus}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding HistoryEditorStatus}"
                   AutomationProperties.AutomationId="HistoryEditorStatusText"
                   AutomationProperties.LiveSetting="Polite" />
        <Border x:Name="HistoryEditorHost"
                Grid.Row="3"
                Margin="0,16,0,0">
          <Grid IsVisible="{Binding IsEditingHistory}"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock FontWeight="SemiBold" Text="Datum" />
          <TextBox x:Name="HistoryEditorDateBox"
                   Grid.Row="1"
                   Margin="0,6,0,0"
                   Text="{Binding HistoryEditorDate}"
                   PlaceholderText="Například 15.06.2026"
                   AutomationProperties.Name="Datum historického záznamu"
                   AutomationProperties.AutomationId="HistoryEditorDateBox" />
          <Grid Grid.Row="2"
                Margin="0,14,0,0"
                ColumnDefinitions="*,160">
            <StackPanel Margin="0,0,12,0" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Typ události" />
              <TextBox x:Name="HistoryEditorTypeBox"
                       Text="{Binding HistoryEditorType}"
                       PlaceholderText="Například Servis"
                       AutomationProperties.Name="Typ historické události"
                       AutomationProperties.AutomationId="HistoryEditorTypeBox" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Tachometr" />
              <TextBox x:Name="HistoryEditorOdometerBox"
                       Text="{Binding HistoryEditorOdometer}"
                       PlaceholderText="Například 123456"
                       AutomationProperties.Name="Tachometr historického záznamu"
                       AutomationProperties.AutomationId="HistoryEditorOdometerBox" />
            </StackPanel>
          </Grid>
          <TextBlock Grid.Row="3"
                     Margin="0,14,0,0"
                     FontWeight="SemiBold"
                     Text="Cena" />
          <TextBox x:Name="HistoryEditorCostBox"
                   Grid.Row="4"
                   Margin="0,6,0,0"
                   Text="{Binding HistoryEditorCost}"
                   PlaceholderText="Například 2500"
                   AutomationProperties.Name="Cena historického záznamu"
                   AutomationProperties.AutomationId="HistoryEditorCostBox" />
          <TextBlock Grid.Row="5"
                     Margin="0,14,0,0"
                     FontWeight="SemiBold"
                     Text="Poznámka" />
          <TextBox Grid.Row="6"
                   Margin="0,6,0,0"
                   Height="120"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   VerticalContentAlignment="Top"
                   Text="{Binding HistoryEditorNote}"
                   AutomationProperties.Name="Poznámka k historickému záznamu"
                   AutomationProperties.AutomationId="HistoryEditorNoteBox" />
          </Grid>
        </Border>
        <TextBlock Grid.Row="3"
                   Margin="0,16,0,0"
                   IsVisible="{Binding IsHistoryDetailVisible}"
                   Text="{Binding SelectedHistoryDetail}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedHistoryDetail}"
                   AutomationProperties.AutomationId="SelectedHistoryDetailText" />
      </Grid>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
