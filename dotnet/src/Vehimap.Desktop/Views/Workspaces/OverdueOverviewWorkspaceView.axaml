<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.OverdueOverviewWorkspaceView"
             x:DataType="vm:OverdueOverviewWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding RefreshOverdueOverviewCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenSelectedOverdueOverviewVehicleCommand}" />
    <KeyBinding Gesture="Ctrl+P" Command="{Binding OpenSelectedOverdueOverviewItemCommand}" />
  </UserControl.KeyBindings>
  <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.25*,*">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding OverdueOverviewSummary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding OverdueOverviewSummary}"
               AutomationProperties.AutomationId="OverdueOverviewSummaryText" />
    <Grid Grid.Row="1"
          Grid.ColumnSpan="2"
          Margin="0,12,0,0"
          RowDefinitions="Auto,Auto"
          ColumnDefinitions="100,*,120,110,160,130,130">
      <TextBlock Grid.Column="0"
                 VerticalAlignment="Center"
                 Text="Hledat" />
      <TextBox x:Name="OverdueOverviewSearchBox"
               Grid.Column="1"
               Margin="12,0,0,0"
               Text="{Binding OverdueOverviewSearchText}"
               PlaceholderText="Vozidlo, SPZ, termín nebo položka..."
               AutomationProperties.Name="Hledání v přehledu propadlých termínů"
               AutomationProperties.HelpText="Vozidlo, SPZ, termín nebo položka"
               AutomationProperties.AutomationId="OverdueOverviewSearchBox" />
      <Button Grid.Column="2"
              x:Name="ClearOverdueOverviewSearchButton"
              Margin="12,0,0,0"
              Width="108"
              Command="{Binding ClearOverdueOverviewSearchCommand}"
              Content="Vymazat"
              AutomationProperties.Name="Vymazat hledání v přehledu propadlých termínů"
              AutomationProperties.AutomationId="ClearOverdueOverviewSearchButton" />
      <TextBlock Grid.Column="3"
                 Margin="12,0,0,0"
                 VerticalAlignment="Center"
                 Text="Filtrovat" />
      <ComboBox x:Name="OverdueOverviewFilterComboBox"
                Grid.Column="4"
                Margin="12,0,0,0"
                ItemsSource="{Binding OverviewFilters}"
                SelectedItem="{Binding SelectedOverdueOverviewFilter}"
                AutomationProperties.Name="Filtr přehledu propadlých termínů"
                AutomationProperties.AutomationId="OverdueOverviewFilterComboBox" />
      <Button Grid.Column="5"
              x:Name="OverdueOverviewRefreshButton"
              Margin="12,0,0,0"
              Width="120"
              Command="{Binding RefreshOverdueOverviewCommand}"
              Content="Obnovit"
              AutomationProperties.Name="Obnovit přehled propadlých termínů"
              AutomationProperties.AutomationId="OverdueOverviewRefreshButton" />
      <Button Grid.Column="6"
              x:Name="OverdueOverviewOpenButton"
              Margin="12,0,0,0"
              Width="120"
              Command="{Binding OpenSelectedOverdueOverviewItemCommand}"
              Content="Otevřít položku"
              AutomationProperties.Name="Otevřít vybraný propadlý termín"
              AutomationProperties.AutomationId="OverdueOverviewOpenButton" />
      <TextBlock Grid.Row="1"
                 Grid.Column="0"
                 Margin="0,8,0,0"
                 VerticalAlignment="Center"
                 Text="Řadit" />
      <ComboBox Grid.Row="1"
                Grid.Column="1"
                Margin="12,8,0,0"
                ItemsSource="{Binding OverviewSortOptions}"
                SelectedItem="{Binding SelectedOverdueOverviewSortOption}"
                AutomationProperties.Name="Řazení přehledu propadlých termínů"
                AutomationProperties.AutomationId="OverdueOverviewSortComboBox" />
      <CheckBox Grid.Row="1"
                Grid.Column="2"
                Grid.ColumnSpan="2"
                Margin="12,8,0,0"
                VerticalAlignment="Center"
                Content="Sestupně"
                IsChecked="{Binding OverdueOverviewSortDescending}"
                AutomationProperties.Name="Řadit přehled propadlých termínů sestupně"
                AutomationProperties.AutomationId="OverdueOverviewSortDescendingCheckBox" />
    </Grid>

    <ListBox x:Name="OverdueOverviewListBox"
             Grid.Row="2"
             Margin="0,12,12,0"
             ItemsSource="{Binding OverdueOverviewItems}"
             SelectedItem="{Binding SelectedOverdueOverviewItem}"
             AutomationProperties.Name="Přehled propadlých termínů napříč vozidly"
             AutomationProperties.AutomationId="OverdueOverviewListBox">
      <ListBox.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedOverdueOverviewItemCommand}" />
      </ListBox.KeyBindings>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="itemvm:VehicleTimelineItemViewModel">
          <Border Padding="12"
                  Margin="0,0,0,8"
                  Background="#10203040"
                  CornerRadius="6"
                  AutomationProperties.Name="{Binding AccessibleLabel}"
                  AutomationProperties.ItemType="Položka časové osy"
                  AutomationProperties.ItemStatus="{Binding Status}">
            <Grid ColumnDefinitions="110,140,150,*">
              <TextBlock Grid.Column="0" Text="{Binding Date}" />
              <TextBlock Grid.Column="1" Text="{Binding KindLabel}" />
              <TextBlock Grid.Column="2" Text="{Binding VehicleName}" />
              <StackPanel Grid.Column="3" Spacing="4">
                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                <TextBlock Opacity="0.82" Text="{Binding Detail}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.72" Text="{Binding Status}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Border Grid.Row="2"
            Grid.Column="1"
            Margin="12,12,0,0"
            Padding="16"
            Background="#10203040"
            CornerRadius="8">
      <Grid RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Detail propadlého termínu"
                   AutomationProperties.Name="Detail propadlého termínu"
                   AutomationProperties.AutomationId="OverdueOverviewDetailHeadingText"
                   AutomationProperties.HeadingLevel="2" />
        <WrapPanel Grid.Row="1" Margin="0,12,0,0" ItemWidth="150" ItemHeight="34">
          <Button Command="{Binding OpenSelectedOverdueOverviewVehicleCommand}"
                  Content="Zobrazit vozidlo"
                  AutomationProperties.Name="Zobrazit vozidlo k vybranému propadlému termínu"
                  AutomationProperties.AutomationId="OverdueOverviewOpenVehicleButton" />
          <Button Command="{Binding OpenSelectedOverdueOverviewItemCommand}"
                  Content="Otevřít položku"
                  AutomationProperties.Name="Otevřít evidenci vybraného propadlého termínu"
                  AutomationProperties.AutomationId="OverdueOverviewOpenItemButton" />
        </WrapPanel>
        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Opacity="0.75"
                   Text="Propadlé termíny vám pomohou rychle projít všechny záznamy, které už jsou po termínu a vyžadují zásah."
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="3"
                   Margin="0,16,0,0"
                   Text="{Binding SelectedOverdueOverviewDetail}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedOverdueOverviewDetail}"
                   AutomationProperties.AutomationId="SelectedOverdueOverviewDetailText" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
