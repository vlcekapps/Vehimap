<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.ReminderWorkspaceView"
             x:DataType="vm:ReminderWorkspaceViewModel">
  <Grid ColumnDefinitions="1.15*,*" RowDefinitions="Auto,*">
    <TextBlock Grid.ColumnSpan="2" Text="{Binding ReminderSummary}" TextWrapping="Wrap" />
    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,16,0,0">
      <TextBlock FontWeight="SemiBold" Text="Seznam připomínek vybraného vozidla" />
      <ListBox x:Name="ReminderListBox"
               Grid.Row="1"
               Margin="0,12,12,0"
               ItemsSource="{Binding SelectedVehicleReminders}"
               SelectedItem="{Binding SelectedReminder}"
               AutomationProperties.Name="Připomínky vybraného vozidla">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="itemvm:VehicleReminderItemViewModel">
            <Border Padding="12" Margin="0,0,0,8" Background="#10203040" CornerRadius="6" AutomationProperties.Name="{Binding AccessibleLabel}">
              <Grid ColumnDefinitions="2*,130,130,130,*">
                <TextBlock Grid.Column="0" Text="{Binding Title}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="1" Text="{Binding DueDate}" />
                <TextBlock Grid.Column="2" Text="{Binding Status}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="3" Text="{Binding RepeatMode}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <Border Grid.Row="1" Grid.Column="1" Margin="12,16,0,0" Padding="16" Background="#10203040" CornerRadius="8">
      <Grid RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding ReminderPanelHeading}" />
        <WrapPanel Grid.Row="1" Margin="0,14,0,0" ItemWidth="122" ItemHeight="34">
          <Button Command="{Binding CreateReminderCommand}" Content="Nová" AutomationProperties.Name="Vytvořit novou připomínku" />
          <Button Command="{Binding EditSelectedReminderCommand}" Content="Upravit" AutomationProperties.Name="Upravit vybranou připomínku" />
          <Button Command="{Binding DeleteSelectedReminderCommand}" Content="Odstranit" AutomationProperties.Name="Odstranit vybranou připomínku" />
          <Button Command="{Binding SaveReminderCommand}" Content="Uložit" IsVisible="{Binding IsEditingReminder}" AutomationProperties.Name="Uložit připomínku" />
          <Button Command="{Binding CancelReminderEditCommand}" Content="Zrušit" IsVisible="{Binding IsEditingReminder}" AutomationProperties.Name="Zrušit úpravu připomínky" />
        </WrapPanel>
        <TextBlock Grid.Row="2" Margin="0,12,0,0" Opacity="0.82" Text="{Binding ReminderEditorStatus}" TextWrapping="Wrap" />
        <Grid Grid.Row="3" Margin="0,16,0,0" IsVisible="{Binding IsEditingReminder}" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock FontWeight="SemiBold" Text="Název připomínky" />
          <TextBox x:Name="ReminderEditorTitleBox" Grid.Row="1" Margin="0,6,0,0" Text="{Binding ReminderEditorTitle}" PlaceholderText="Například objednat servis" AutomationProperties.Name="Název připomínky" />
          <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="*,140">
            <StackPanel Margin="0,0,12,0" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Termín" />
              <TextBox Text="{Binding ReminderEditorDueDate}" PlaceholderText="Například 15.06.2026 nebo 06/2026" AutomationProperties.Name="Termín připomínky" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6">
              <TextBlock FontWeight="SemiBold" Text="Předstih dnů" />
              <TextBox Text="{Binding ReminderEditorDays}" PlaceholderText="Například 30" AutomationProperties.Name="Předstih připomínky ve dnech" />
            </StackPanel>
          </Grid>
          <TextBlock Grid.Row="3" Margin="0,14,0,0" FontWeight="SemiBold" Text="Opakování" />
          <TextBox Grid.Row="4" Margin="0,6,0,0" Text="{Binding ReminderEditorRepeatMode}" PlaceholderText="Například Ročně nebo bez opakování" AutomationProperties.Name="Opakování připomínky" />
          <TextBlock Grid.Row="5" Margin="0,14,0,0" FontWeight="SemiBold" Text="Poznámka" />
          <TextBox Grid.Row="6" Margin="0,6,0,0" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding ReminderEditorNote}" AutomationProperties.Name="Poznámka k připomínce" />
        </Grid>
        <TextBlock Grid.Row="3" Margin="0,16,0,0" IsVisible="{Binding IsReminderDetailVisible}" Text="{Binding SelectedReminderDetail}" TextWrapping="Wrap" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
