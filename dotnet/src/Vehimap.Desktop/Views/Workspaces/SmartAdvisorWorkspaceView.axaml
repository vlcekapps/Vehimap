<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.SmartAdvisorWorkspaceView"
             x:DataType="vm:SmartAdvisorWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding RefreshSmartAdvisorCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenSelectedSmartAdvisorItemCommand}" />
    <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedSmartAdvisorItemCommand}" />
  </UserControl.KeyBindings>
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
    <TextBlock Text="{Binding SmartAdvisorSummary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding SmartAdvisorSummary}"
               AutomationProperties.AutomationId="SmartAdvisorSummaryText" />

    <Grid Grid.Row="1"
          Margin="0,12,0,0"
          ColumnDefinitions="90,*,120,130,150,150">
      <TextBlock Grid.Column="0"
                 VerticalAlignment="Center"
                 Text="Hledat" />
      <TextBox x:Name="SmartAdvisorSearchBox"
               Grid.Column="1"
               Margin="12,0,0,0"
               Text="{Binding SmartAdvisorSearchText}"
               PlaceholderText="Vozidlo, priorita, kategorie nebo text doporučení..."
               AutomationProperties.Name="Hledání v chytrém poradci"
               AutomationProperties.AutomationId="SmartAdvisorSearchBox" />
      <Button Grid.Column="2"
              Margin="12,0,0,0"
              Command="{Binding ClearSmartAdvisorFiltersCommand}"
              Content="Vymazat"
              AutomationProperties.Name="Vymazat filtry chytrého poradce"
              AutomationProperties.AutomationId="SmartAdvisorClearFiltersButton" />
      <Button Grid.Column="3"
              Margin="12,0,0,0"
              Command="{Binding RefreshSmartAdvisorCommand}"
              Content="Obnovit"
              AutomationProperties.Name="Obnovit chytrého poradce"
              AutomationProperties.AutomationId="SmartAdvisorRefreshButton" />
      <Button Grid.Column="4"
              Margin="12,0,0,0"
              Command="{Binding OpenSelectedSmartAdvisorItemCommand}"
              Content="Otevřít položku"
              AutomationProperties.Name="Otevřít vybrané doporučení"
              AutomationProperties.AutomationId="SmartAdvisorOpenItemButton" />
      <Button Grid.Column="5"
              Margin="12,0,0,0"
              Command="{Binding OpenSelectedSmartAdvisorVehicleCommand}"
              Content="Zobrazit vozidlo"
              AutomationProperties.Name="Zobrazit vozidlo vybraného doporučení"
              AutomationProperties.AutomationId="SmartAdvisorOpenVehicleButton" />
    </Grid>

    <Grid Grid.Row="2"
          Margin="0,10,0,0"
          ColumnDefinitions="90,220,100,220,100,220,*">
      <TextBlock Grid.Column="0"
                 VerticalAlignment="Center"
                 Text="Priorita" />
      <ComboBox Grid.Column="1"
                Margin="12,0,0,0"
                ItemsSource="{Binding PriorityFilters}"
                SelectedItem="{Binding SelectedSmartAdvisorPriorityFilter}"
                AutomationProperties.Name="Filtr priority chytrého poradce"
                AutomationProperties.AutomationId="SmartAdvisorPriorityFilterBox" />
      <TextBlock Grid.Column="2"
                 Margin="18,0,0,0"
                 VerticalAlignment="Center"
                 Text="Kategorie" />
      <ComboBox Grid.Column="3"
                Margin="12,0,0,0"
                ItemsSource="{Binding CategoryFilters}"
                SelectedItem="{Binding SelectedSmartAdvisorCategoryFilter}"
                AutomationProperties.Name="Filtr kategorie chytrého poradce"
                AutomationProperties.AutomationId="SmartAdvisorCategoryFilterBox" />
      <TextBlock Grid.Column="4"
                 Margin="18,0,0,0"
                 VerticalAlignment="Center"
                 Text="Vozidlo" />
      <ComboBox Grid.Column="5"
                Margin="12,0,0,0"
                ItemsSource="{Binding VehicleFilters}"
                SelectedItem="{Binding SelectedSmartAdvisorVehicleFilter}"
                AutomationProperties.Name="Filtr vozidla chytrého poradce"
                AutomationProperties.AutomationId="SmartAdvisorVehicleFilterBox" />
    </Grid>

    <TextBlock Grid.Row="3"
               Margin="0,8,0,0"
               Opacity="0.75"
               Text="Ctrl+F hledá, Ctrl+R obnoví poradce a Enter nebo Ctrl+O otevře vybrané doporučení."
               TextWrapping="Wrap"
               AutomationProperties.Name="Nápověda chytrého poradce. Ctrl+F hledá, Ctrl+R obnoví poradce a Enter nebo Ctrl+O otevře vybrané doporučení."
               AutomationProperties.AutomationId="SmartAdvisorKeyboardHelpText" />

    <Grid Grid.Row="4"
          Margin="0,12,0,0"
          ColumnDefinitions="1.25*,*">
      <ListBox x:Name="SmartAdvisorListBox"
               ItemsSource="{Binding VisibleSmartAdvisorItems}"
               SelectedItem="{Binding SelectedSmartAdvisorItem}"
               AutomationProperties.Name="Seznam doporučení chytrého poradce"
               AutomationProperties.AutomationId="SmartAdvisorListBox">
        <ListBox.KeyBindings>
          <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedSmartAdvisorItemCommand}" />
        </ListBox.KeyBindings>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="itemvm:SmartAdvisorItemViewModel">
            <Border Padding="12"
                    Margin="0,0,0,8"
                    Background="#10203040"
                    CornerRadius="6"
                    AutomationProperties.Name="{Binding AccessibleLabel}"
                    AutomationProperties.ItemType="Doporučení chytrého poradce"
                    AutomationProperties.ItemStatus="{Binding Priority}">
              <Grid ColumnDefinitions="120,140,1.4*,1.2*">
                <TextBlock Grid.Column="0"
                           FontWeight="SemiBold"
                           Text="{Binding Priority}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Category}" />
                <StackPanel Grid.Column="2"
                            Spacing="4">
                  <TextBlock FontWeight="SemiBold"
                             Text="{Binding Title}"
                             TextWrapping="Wrap" />
                  <TextBlock Opacity="0.78"
                             Text="{Binding Summary}"
                             TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="3"
                            Spacing="4">
                  <TextBlock Text="{Binding VehicleName}"
                             TextWrapping="Wrap" />
                  <TextBlock Opacity="0.78"
                             Text="{Binding DueDate}" />
                  <TextBlock Opacity="0.78"
                             Text="{Binding ActionLabel}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Border Grid.Column="1"
              Margin="16,0,0,0"
              Padding="16"
              Background="#10203040"
              CornerRadius="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      AutomationProperties.Name="Detail vybraného doporučení chytrého poradce"
                      AutomationProperties.AutomationId="SmartAdvisorDetailScrollViewer">
          <StackPanel Spacing="12">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="Detail doporučení"
                       AutomationProperties.Name="Detail doporučení"
                       AutomationProperties.AutomationId="SmartAdvisorDetailHeadingText"
                       AutomationProperties.HeadingLevel="2" />
            <TextBlock Text="{Binding SelectedSmartAdvisorDetail}"
                       TextWrapping="Wrap"
                       AutomationProperties.Name="{Binding SelectedSmartAdvisorDetail}"
                       AutomationProperties.AutomationId="SmartAdvisorSelectedDetailText" />
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>
