<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="using:Vehimap.Desktop.Localization"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.UpcomingOverviewWorkspaceView"
             x:DataType="vm:UpcomingOverviewWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding RefreshUpcomingOverviewCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenSelectedUpcomingOverviewVehicleCommand}" />
    <KeyBinding Gesture="Ctrl+P" Command="{Binding OpenSelectedUpcomingOverviewItemCommand}" />
  </UserControl.KeyBindings>
  <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.25*,*">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding UpcomingOverviewSummary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding UpcomingOverviewSummary}"
               AutomationProperties.AutomationId="UpcomingOverviewSummaryText" />
    <Grid Grid.Row="1"
          Grid.ColumnSpan="2"
          Margin="0,12,0,0"
          RowDefinitions="Auto,Auto,Auto"
          ColumnDefinitions="100,*,120,110,160,130,130">
      <TextBlock Grid.Column="0"
                 VerticalAlignment="Center"
                 Text="{i18n:Loc Common.Search}" />
      <TextBox x:Name="UpcomingOverviewSearchBox"
               Grid.Column="1"
               Margin="12,0,0,0"
               Text="{Binding UpcomingOverviewSearchText}"
               PlaceholderText="{i18n:Loc UpcomingOverviewWorkspace.SearchPlaceholder}"
               AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.SearchName}"
               AutomationProperties.HelpText="{i18n:Loc UpcomingOverviewWorkspace.SearchHelp}"
               AutomationProperties.AutomationId="UpcomingOverviewSearchBox" />
      <Button Grid.Column="2"
              x:Name="ClearUpcomingOverviewSearchButton"
              Margin="12,0,0,0"
              Width="108"
              Command="{Binding ClearUpcomingOverviewSearchCommand}"
              Content="{i18n:Loc Common.Clear}"
              AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.ClearSearchName}"
              AutomationProperties.AutomationId="ClearUpcomingOverviewSearchButton" />
      <TextBlock Grid.Column="3"
                 Margin="12,0,0,0"
                 VerticalAlignment="Center"
                 Text="{i18n:Loc UpcomingOverviewWorkspace.FilterLabel}" />
      <ComboBox x:Name="UpcomingOverviewFilterComboBox"
                Grid.Column="4"
                Margin="12,0,0,0"
                ItemsSource="{Binding OverviewFilters}"
                SelectedItem="{Binding SelectedUpcomingOverviewFilter}"
                AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.FilterName}"
                AutomationProperties.AutomationId="UpcomingOverviewFilterComboBox" />
      <Button Grid.Column="5"
              x:Name="UpcomingOverviewRefreshButton"
              Margin="12,0,0,0"
              Width="120"
              Command="{Binding RefreshUpcomingOverviewCommand}"
              Content="{i18n:Loc UpcomingOverviewWorkspace.Refresh}"
              AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.RefreshName}"
              AutomationProperties.AutomationId="UpcomingOverviewRefreshButton" />
      <Button Grid.Column="6"
              x:Name="UpcomingOverviewOpenButton"
              Margin="12,0,0,0"
              Width="120"
              Command="{Binding OpenSelectedUpcomingOverviewItemCommand}"
              Content="{i18n:Loc UpcomingOverviewWorkspace.OpenItem}"
              AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.OpenItemName}"
              AutomationProperties.AutomationId="UpcomingOverviewOpenButton" />
      <CheckBox Grid.Row="1"
                Grid.Column="1"
                Margin="12,8,0,0"
                Content="{i18n:Loc UpcomingOverviewWorkspace.IncludeMissingGreenCards}"
                IsChecked="{Binding IncludeMissingGreenCardsInUpcomingOverview}"
                AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.IncludeMissingGreenCardsName}"
                AutomationProperties.AutomationId="UpcomingOverviewIncludeMissingGreenCardsCheckBox" />
      <CheckBox Grid.Row="1"
                Grid.Column="3"
                Grid.ColumnSpan="4"
                Margin="12,8,0,0"
                Content="{i18n:Loc UpcomingOverviewWorkspace.IncludeDataIssues}"
                IsChecked="{Binding IncludeDataIssuesInUpcomingOverview}"
                AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.IncludeDataIssuesName}"
                AutomationProperties.AutomationId="UpcomingOverviewIncludeDataIssuesCheckBox" />
      <TextBlock Grid.Row="2"
                 Grid.Column="0"
                 Margin="0,8,0,0"
                 VerticalAlignment="Center"
                 Text="{i18n:Loc Common.Sort}" />
      <ComboBox Grid.Row="2"
                Grid.Column="1"
                Margin="12,8,0,0"
                ItemsSource="{Binding OverviewSortOptions}"
                SelectedItem="{Binding SelectedUpcomingOverviewSortOption}"
                AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.SortName}"
                AutomationProperties.AutomationId="UpcomingOverviewSortComboBox" />
      <CheckBox Grid.Row="2"
                Grid.Column="2"
                Grid.ColumnSpan="2"
                Margin="12,8,0,0"
                VerticalAlignment="Center"
                Content="{i18n:Loc Common.SortDescending}"
                IsChecked="{Binding UpcomingOverviewSortDescending}"
                AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.SortDescendingName}"
                AutomationProperties.AutomationId="UpcomingOverviewSortDescendingCheckBox" />
    </Grid>

    <ListBox x:Name="UpcomingOverviewListBox"
             Grid.Row="2"
             Margin="0,12,12,0"
             ItemsSource="{Binding UpcomingOverviewItems}"
             SelectedItem="{Binding SelectedUpcomingOverviewItem}"
             AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.ListName}"
             AutomationProperties.AutomationId="UpcomingOverviewListBox">
      <ListBox.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedUpcomingOverviewItemCommand}" />
      </ListBox.KeyBindings>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="itemvm:VehicleTimelineItemViewModel">
          <Border Padding="12"
                  Margin="0,0,0,8"
                  Background="#10203040"
                  CornerRadius="6"
                  AutomationProperties.Name="{Binding AccessibleLabel}"
                  AutomationProperties.ItemType="{i18n:Loc UpcomingOverviewWorkspace.ItemType}"
                  AutomationProperties.ItemStatus="{Binding Status}">
            <Grid ColumnDefinitions="110,140,150,*">
              <TextBlock Grid.Column="0" Text="{Binding Date}" />
              <TextBlock Grid.Column="1" Text="{Binding KindLabel}" />
              <TextBlock Grid.Column="2" Text="{Binding VehicleName}" />
              <StackPanel Grid.Column="3" Spacing="4">
                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                <TextBlock Opacity="0.82" Text="{Binding Detail}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.72" Text="{Binding Status}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Border Grid.Row="2"
            Grid.Column="1"
            Margin="12,12,0,0"
            Padding="16"
            Background="#10203040"
            CornerRadius="8">
      <Grid RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{i18n:Loc UpcomingOverviewWorkspace.DetailHeading}"
                   AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.DetailHeading}"
                   AutomationProperties.AutomationId="UpcomingOverviewDetailHeadingText"
                   AutomationProperties.HeadingLevel="2" />
        <WrapPanel Grid.Row="1" Margin="0,12,0,0" ItemWidth="150" ItemHeight="34">
          <Button Command="{Binding OpenSelectedUpcomingOverviewVehicleCommand}"
                  Content="{i18n:Loc UpcomingOverviewWorkspace.OpenVehicle}"
                  AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.OpenVehicleName}"
                  AutomationProperties.AutomationId="UpcomingOverviewOpenVehicleButton" />
          <Button Command="{Binding OpenSelectedUpcomingOverviewItemCommand}"
                  Content="{i18n:Loc UpcomingOverviewWorkspace.OpenItem}"
                  AutomationProperties.Name="{i18n:Loc UpcomingOverviewWorkspace.OpenEvidenceName}"
                  AutomationProperties.AutomationId="UpcomingOverviewOpenItemButton" />
        </WrapPanel>
        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Opacity="0.75"
                   Text="{i18n:Loc UpcomingOverviewWorkspace.Help}"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="3"
                   Margin="0,16,0,0"
                   Text="{Binding SelectedUpcomingOverviewDetail}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedUpcomingOverviewDetail}"
                   AutomationProperties.AutomationId="SelectedUpcomingOverviewDetailText" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
