<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.VehicleDetailWorkspaceView"
             x:DataType="vm:VehicleDetailWorkspaceViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*">
    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding VehiclePanelHeading}" />
    <TextBlock Grid.Row="1"
               Margin="0,12,0,0"
               Opacity="0.82"
               Text="{Binding VehicleEditorStatus}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding VehicleEditorStatus}"
               AutomationProperties.AutomationId="VehicleEditorStatusText" />
    <WrapPanel x:Name="VehicleActionPanel"
               Grid.Row="2"
               Margin="0,14,0,0"
               ItemWidth="138"
               ItemHeight="34">
      <Button x:Name="CreateVehicleButton"
              Command="{Binding CreateVehicleCommand}"
              Content="Nové vozidlo"
              AutomationProperties.Name="Vytvořit nové vozidlo"
              AutomationProperties.AutomationId="CreateVehicleButton" />
      <Button x:Name="EditVehicleButton"
              Command="{Binding EditSelectedVehicleCommand}"
              Content="Upravit"
              AutomationProperties.Name="Upravit vybrané vozidlo"
              AutomationProperties.AutomationId="EditVehicleButton" />
      <Button x:Name="DeleteVehicleButton"
              Command="{Binding DeleteSelectedVehicleCommand}"
              Content="Odstranit"
              IsVisible="{Binding IsVehicleDetailVisible}"
              AutomationProperties.Name="Odstranit vybrané vozidlo"
              AutomationProperties.AutomationId="DeleteVehicleButton" />
      <Button x:Name="OpenVehicleStarterBundleButton"
              Click="OnOpenVehicleStarterBundleClick"
              Content="Balíček"
              IsVisible="{Binding IsVehicleDetailVisible}"
              IsEnabled="{Binding CanOpenVehicleStarterBundle}"
              AutomationProperties.Name="Otevřít balíček pro vybrané vozidlo"
              AutomationProperties.AutomationId="OpenVehicleStarterBundleButton" />
      <Button x:Name="SaveVehicleButton"
              Click="OnSaveVehicleClick"
              Content="Uložit"
              IsVisible="{Binding IsEditingVehicle}"
              AutomationProperties.Name="Uložit vozidlo"
              AutomationProperties.AutomationId="SaveVehicleButton" />
      <Button x:Name="CancelVehicleButton"
              Command="{Binding CancelVehicleEditCommand}"
              Content="Zrušit"
              IsVisible="{Binding IsEditingVehicle}"
              AutomationProperties.Name="Zrušit úpravu vozidla"
              AutomationProperties.AutomationId="CancelVehicleButton" />
    </WrapPanel>

    <Border x:Name="VehicleEditorHost"
            Grid.Row="3"
            Margin="0,16,0,0">
      <Grid IsVisible="{Binding IsEditingVehicle}"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
      <Grid ColumnDefinitions="*,200">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Název vozidla" />
          <TextBox x:Name="VehicleEditorNameBox"
                   Text="{Binding VehicleEditorName}"
                   PlaceholderText="Například Milena"
                   AutomationProperties.Name="Název vozidla"
                   AutomationProperties.AutomationId="VehicleEditorNameBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Kategorie" />
          <ComboBox x:Name="VehicleEditorCategoryBox"
                    ItemsSource="{Binding VehicleCategoryOptions}"
                    SelectedItem="{Binding VehicleEditorCategory}"
                    AutomationProperties.Name="Kategorie vozidla"
                    AutomationProperties.AutomationId="VehicleEditorCategoryBox" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1" Margin="0,14,0,0" ColumnDefinitions="*,200">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Značka a model" />
          <TextBox Text="{Binding VehicleEditorMakeModel}"
                   PlaceholderText="Například Škoda 120L"
                   AutomationProperties.Name="Značka a model vozidla"
                   AutomationProperties.AutomationId="VehicleEditorMakeModelBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="SPZ" />
          <TextBox Text="{Binding VehicleEditorPlate}"
                   PlaceholderText="Například 1AB2345"
                   AutomationProperties.Name="Státní poznávací značka vozidla"
                   AutomationProperties.AutomationId="VehicleEditorPlateBox" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="160,160,*">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Rok" />
          <TextBox Text="{Binding VehicleEditorYear}"
                   AutomationProperties.Name="Rok vozidla"
                   AutomationProperties.AutomationId="VehicleEditorYearBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Výkon" />
          <TextBox Text="{Binding VehicleEditorPower}"
                   AutomationProperties.Name="Výkon vozidla"
                   AutomationProperties.AutomationId="VehicleEditorPowerBox" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Stav vozidla" />
          <ComboBox ItemsSource="{Binding VehicleStateOptions}"
                    SelectedItem="{Binding VehicleEditorState}"
                    AutomationProperties.Name="Stav vozidla"
                    AutomationProperties.AutomationId="VehicleEditorStateBox" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="3" Margin="0,14,0,0" ColumnDefinitions="*,*">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Poslední TK" />
          <TextBox Text="{Binding VehicleEditorLastTk}"
                   AutomationProperties.Name="Poslední technická kontrola"
                   AutomationProperties.AutomationId="VehicleEditorLastTkBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Příští TK" />
          <TextBox Text="{Binding VehicleEditorNextTk}"
                   AutomationProperties.Name="Příští technická kontrola"
                   AutomationProperties.AutomationId="VehicleEditorNextTkBox" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="4" Margin="0,14,0,0" ColumnDefinitions="*,*">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Zelená karta od" />
          <TextBox Text="{Binding VehicleEditorGreenCardFrom}"
                   AutomationProperties.Name="Zelená karta od"
                   AutomationProperties.AutomationId="VehicleEditorGreenCardFromBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Zelená karta do" />
          <TextBox Text="{Binding VehicleEditorGreenCardTo}"
                   AutomationProperties.Name="Zelená karta do"
                   AutomationProperties.AutomationId="VehicleEditorGreenCardToBox" />
        </StackPanel>
      </Grid>

      <TextBlock Grid.Row="5" Margin="0,14,0,0" FontWeight="SemiBold" Text="Servisní profil" />
      <Grid Grid.Row="6" Margin="0,6,0,0" ColumnDefinitions="*,*,*,*">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Pohon" />
          <ComboBox ItemsSource="{Binding VehiclePowertrainOptions}"
                    SelectedItem="{Binding VehicleEditorPowertrain}"
                    AutomationProperties.Name="Pohon vozidla"
                    AutomationProperties.AutomationId="VehicleEditorPowertrainBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Klimatizace" />
          <ComboBox ItemsSource="{Binding VehicleClimateProfileOptions}"
                    SelectedItem="{Binding VehicleEditorClimateProfile}"
                    AutomationProperties.Name="Klimatizace vozidla"
                    AutomationProperties.AutomationId="VehicleEditorClimateProfileBox" />
        </StackPanel>
        <StackPanel Grid.Column="2" Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Rozvody" />
          <ComboBox ItemsSource="{Binding VehicleTimingDriveOptions}"
                    SelectedItem="{Binding VehicleEditorTimingDrive}"
                    AutomationProperties.Name="Typ rozvodů vozidla"
                    AutomationProperties.AutomationId="VehicleEditorTimingDriveBox" />
        </StackPanel>
        <StackPanel Grid.Column="3" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Převodovka" />
          <ComboBox ItemsSource="{Binding VehicleTransmissionOptions}"
                    SelectedItem="{Binding VehicleEditorTransmission}"
                    AutomationProperties.Name="Převodovka vozidla"
                    AutomationProperties.AutomationId="VehicleEditorTransmissionBox" />
        </StackPanel>
      </Grid>

      <TextBlock Grid.Row="7" Margin="0,14,0,0" FontWeight="SemiBold" Text="Poznámka k vozidlu" />
      <TextBox Grid.Row="8"
               Margin="0,6,0,0"
               Height="110"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               VerticalContentAlignment="Top"
               Text="{Binding VehicleEditorNote}"
               AutomationProperties.Name="Poznámka k vozidlu"
               AutomationProperties.AutomationId="VehicleEditorNoteBox" />
      <TextBlock Grid.Row="9"
                 Margin="0,14,0,0"
                 Opacity="0.72"
                 Text="Změna vozidla zachová související historii, tankování, doklady, připomínky i údržbu."
                 TextWrapping="Wrap" />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="3"
                  Margin="0,16,0,0"
                  IsVisible="{Binding IsVehicleDetailVisible}">
      <StackPanel Spacing="14">
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedVehicleHeading}" />
        <TextBlock Text="{Binding SelectedVehicleOverview}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedVehicleOverview}"
                   AutomationProperties.AutomationId="SelectedVehicleOverviewText" />
        <TextBlock Text="{Binding SelectedVehicleDates}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedVehicleDates}"
                   AutomationProperties.AutomationId="SelectedVehicleDatesText" />
        <Border Padding="14" Background="#10203040" CornerRadius="8">
          <TextBlock Text="{Binding SelectedVehicleProfile}"
                     TextWrapping="Wrap"
                     AutomationProperties.Name="{Binding SelectedVehicleProfile}"
                     AutomationProperties.AutomationId="SelectedVehicleProfileText" />
        </Border>
        <TextBlock Text="{Binding SelectedVehicleEvidenceSummary}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedVehicleEvidenceSummary}"
                   AutomationProperties.AutomationId="SelectedVehicleEvidenceSummaryText" />
        <ItemsControl ItemsSource="{Binding EvidenceSummaryItems}"
                      AutomationProperties.Name="Stav navazujících evidencí vybraného vozidla"
                      AutomationProperties.AutomationId="VehicleDetailEvidenceSummaryItems">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="itemvm:VehicleDetailEvidenceSummaryItemViewModel">
              <Border Padding="10"
                      Margin="0,0,0,6"
                      Background="#08102030"
                      CornerRadius="6"
                      AutomationProperties.Name="{Binding AccessibleLabel}">
                <Grid ColumnDefinitions="130,*">
                  <TextBlock FontWeight="SemiBold"
                             Text="{Binding Title}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Summary}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Border Padding="14"
                Background="#10143A2A"
                CornerRadius="8"
                AutomationProperties.Name="Související evidence vybraného vozidla"
                AutomationProperties.AutomationId="VehicleDetailRelatedActionsPanel">
          <StackPanel Spacing="8">
            <TextBlock FontWeight="SemiBold" Text="Související evidence" />
            <TextBlock Opacity="0.76"
                       Text="Přejděte přímo do evidence, časové osy nebo nákladů vybraného vozidla."
                       TextWrapping="Wrap"
                       AutomationProperties.Name="Přejděte přímo do evidence, časové osy nebo nákladů vybraného vozidla."
                       AutomationProperties.AutomationId="VehicleDetailRelatedActionsHelpText" />
            <WrapPanel ItemWidth="148" ItemHeight="34">
              <Button Click="OnOpenVehicleHistoryWorkspaceClick"
                      Content="Historie"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít historii vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailHistoryButton" />
              <Button Click="OnOpenVehicleFuelWorkspaceClick"
                      Content="Tankování"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít tankování vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailFuelButton" />
              <Button Click="OnOpenVehicleReminderWorkspaceClick"
                      Content="Připomínky"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít připomínky vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailRemindersButton" />
              <Button Click="OnOpenVehicleMaintenanceWorkspaceClick"
                      Content="Údržba"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít plán údržby vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailMaintenanceButton" />
              <Button Click="OnOpenVehicleRecordWorkspaceClick"
                      Content="Doklady"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít doklady a přílohy vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailRecordsButton" />
              <Button Click="OnOpenVehicleTimelineWorkspaceClick"
                      Content="Časová osa"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít časovou osu vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailTimelineButton" />
              <Button Click="OnOpenVehicleCostsWorkspaceClick"
                      Content="Náklady"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít náklady vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailCostsButton" />
            </WrapPanel>
          </StackPanel>
        </Border>
        <TextBlock FontWeight="SemiBold"
                   Text="{Binding SelectedVehicleRecentHistorySummary}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedVehicleRecentHistorySummary}"
                   AutomationProperties.AutomationId="SelectedVehicleRecentHistorySummaryText" />
        <ListBox ItemsSource="{Binding RecentHistoryItems}"
                 MinHeight="96"
                 MaxHeight="180"
                 AutomationProperties.Name="Poslední historické události vybraného vozidla"
                 AutomationProperties.AutomationId="VehicleDetailRecentHistoryListBox">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="itemvm:VehicleHistoryItemViewModel">
              <Border Padding="8" Margin="0,0,0,6" Background="#08102030" CornerRadius="6" AutomationProperties.Name="{Binding AccessibleLabel}">
                <Grid ColumnDefinitions="110,*,110,120">
                  <TextBlock Text="{Binding Date}" />
                  <TextBlock Grid.Column="1" Text="{Binding EventType}" TextWrapping="Wrap" />
                  <TextBlock Grid.Column="2" Text="{Binding Odometer}" />
                  <TextBlock Grid.Column="3" Text="{Binding Cost}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
