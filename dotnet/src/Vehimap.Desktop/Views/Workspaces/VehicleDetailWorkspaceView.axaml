<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             x:Class="Vehimap.Desktop.Views.Workspaces.VehicleDetailWorkspaceView"
             x:DataType="vm:VehicleDetailWorkspaceViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*">
    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding VehiclePanelHeading}" />
    <TextBlock Grid.Row="1"
               Margin="0,12,0,0"
               Opacity="0.82"
               Text="{Binding VehicleEditorStatus}"
               TextWrapping="Wrap" />
    <WrapPanel Grid.Row="2"
               Margin="0,14,0,0"
               ItemWidth="126"
               ItemHeight="34">
      <Button x:Name="CreateVehicleButton"
              Command="{Binding CreateVehicleCommand}"
              Content="Nové vozidlo"
              AutomationProperties.Name="Vytvořit nové vozidlo"
              AutomationProperties.AutomationId="CreateVehicleButton" />
      <Button x:Name="EditVehicleButton"
              Command="{Binding EditSelectedVehicleCommand}"
              Content="Upravit"
              AutomationProperties.Name="Upravit vybrané vozidlo"
              AutomationProperties.AutomationId="EditVehicleButton" />
      <Button x:Name="SaveVehicleButton"
              Command="{Binding SaveVehicleCommand}"
              Content="Uložit"
              IsVisible="{Binding IsEditingVehicle}"
              AutomationProperties.Name="Uložit vozidlo"
              AutomationProperties.AutomationId="SaveVehicleButton" />
      <Button x:Name="CancelVehicleButton"
              Command="{Binding CancelVehicleEditCommand}"
              Content="Zrušit"
              IsVisible="{Binding IsEditingVehicle}"
              AutomationProperties.Name="Zrušit úpravu vozidla"
              AutomationProperties.AutomationId="CancelVehicleButton" />
    </WrapPanel>
    <Grid Grid.Row="3"
          Margin="0,16,0,0"
          IsVisible="{Binding IsEditingVehicle}"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
      <Grid ColumnDefinitions="*,180">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Název vozidla" />
          <TextBox x:Name="VehicleEditorNameBox"
                   Text="{Binding VehicleEditorName}"
                   PlaceholderText="Například Milena"
                   AutomationProperties.Name="Název vozidla"
                   AutomationProperties.AutomationId="VehicleEditorNameBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Kategorie" />
          <ComboBox x:Name="VehicleEditorCategoryBox"
                    ItemsSource="{Binding VehicleCategoryOptions}"
                    SelectedItem="{Binding VehicleEditorCategory}"
                    AutomationProperties.Name="Kategorie vozidla"
                    AutomationProperties.AutomationId="VehicleEditorCategoryBox" />
        </StackPanel>
      </Grid>
      <Grid Grid.Row="1" Margin="0,14,0,0" ColumnDefinitions="*,200">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Značka a model" />
          <TextBox Text="{Binding VehicleEditorMakeModel}"
                   PlaceholderText="Například Škoda 120L"
                   AutomationProperties.Name="Značka a model vozidla"
                   AutomationProperties.AutomationId="VehicleEditorMakeModelBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="SPZ" />
          <TextBox Text="{Binding VehicleEditorPlate}"
                   PlaceholderText="Například 1AB2345"
                   AutomationProperties.Name="Státní poznávací značka vozidla"
                   AutomationProperties.AutomationId="VehicleEditorPlateBox" />
        </StackPanel>
      </Grid>
      <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="160,160,*">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Rok" />
          <TextBox Text="{Binding VehicleEditorYear}"
                   AutomationProperties.Name="Rok vozidla"
                   AutomationProperties.AutomationId="VehicleEditorYearBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Výkon" />
          <TextBox Text="{Binding VehicleEditorPower}"
                   AutomationProperties.Name="Výkon vozidla"
                   AutomationProperties.AutomationId="VehicleEditorPowerBox" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Stav vozidla" />
          <TextBox Text="{Binding VehicleEditorState}"
                   PlaceholderText="Například Běžný provoz"
                   AutomationProperties.Name="Stav vozidla"
                   AutomationProperties.AutomationId="VehicleEditorStateBox" />
        </StackPanel>
      </Grid>
      <Grid Grid.Row="3" Margin="0,14,0,0" ColumnDefinitions="*,*">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Poslední TK" />
          <TextBox Text="{Binding VehicleEditorLastTk}"
                   AutomationProperties.Name="Poslední technická kontrola"
                   AutomationProperties.AutomationId="VehicleEditorLastTkBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Příští TK" />
          <TextBox Text="{Binding VehicleEditorNextTk}"
                   AutomationProperties.Name="Příští technická kontrola"
                   AutomationProperties.AutomationId="VehicleEditorNextTkBox" />
        </StackPanel>
      </Grid>
      <Grid Grid.Row="4" Margin="0,14,0,0" ColumnDefinitions="*,*">
        <StackPanel Margin="0,0,12,0" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Zelená karta od" />
          <TextBox Text="{Binding VehicleEditorGreenCardFrom}"
                   AutomationProperties.Name="Zelená karta od"
                   AutomationProperties.AutomationId="VehicleEditorGreenCardFromBox" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Zelená karta do" />
          <TextBox Text="{Binding VehicleEditorGreenCardTo}"
                   AutomationProperties.Name="Zelená karta do"
                   AutomationProperties.AutomationId="VehicleEditorGreenCardToBox" />
        </StackPanel>
      </Grid>
      <TextBlock Grid.Row="5" Margin="0,14,0,0" FontWeight="SemiBold" Text="Pohon a servisní profil" />
      <TextBox Grid.Row="6"
               Margin="0,6,0,0"
               Text="{Binding VehicleEditorPowertrain}"
               PlaceholderText="Například benzín, diesel nebo elektro"
               AutomationProperties.Name="Pohon a servisní profil vozidla"
               AutomationProperties.AutomationId="VehicleEditorPowertrainBox" />
      <TextBlock Grid.Row="7" Margin="0,14,0,0" FontWeight="SemiBold" Text="Poznámka k vozidlu" />
      <TextBox Grid.Row="8"
               Margin="0,6,0,0"
               Height="110"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               VerticalContentAlignment="Top"
               Text="{Binding VehicleEditorNote}"
               AutomationProperties.Name="Poznámka k vozidlu"
               AutomationProperties.AutomationId="VehicleEditorNoteBox" />
      <TextBlock Grid.Row="9"
                 Margin="0,14,0,0"
                 Opacity="0.72"
                 Text="Změna vozidla zachová související historii, tankování, doklady, připomínky i údržbu."
                 TextWrapping="Wrap" />
    </Grid>
    <Grid Grid.Row="3"
          Margin="0,16,0,0"
          IsVisible="{Binding IsVehicleDetailVisible}"
          RowDefinitions="Auto,Auto,Auto,*">
      <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedVehicleHeading}" />
      <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="{Binding SelectedVehicleOverview}" TextWrapping="Wrap" />
      <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="{Binding SelectedVehicleDates}" TextWrapping="Wrap" />
      <Border Grid.Row="3" Margin="0,16,0,0" Padding="14" Background="#10203040" CornerRadius="8">
        <TextBlock Text="{Binding SelectedVehicleProfile}" TextWrapping="Wrap" />
      </Border>
    </Grid>
  </Grid>
</UserControl>
