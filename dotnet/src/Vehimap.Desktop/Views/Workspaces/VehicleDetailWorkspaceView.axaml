<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.VehicleDetailWorkspaceView"
             x:DataType="vm:VehicleDetailWorkspaceViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*">
    <TextBlock FontSize="18"
               FontWeight="SemiBold"
               Text="{Binding VehiclePanelHeading}"
               AutomationProperties.Name="{Binding VehiclePanelHeading}"
               AutomationProperties.AutomationId="VehiclePanelHeadingText"
               AutomationProperties.HeadingLevel="2" />
    <TextBlock Grid.Row="1"
               Margin="0,12,0,0"
               Opacity="0.82"
               Text="{Binding VehicleEditorStatus}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding VehicleEditorStatus}"
               AutomationProperties.AutomationId="VehicleDetailStatusText"
               AutomationProperties.LiveSetting="Polite" />
    <WrapPanel x:Name="VehicleActionPanel"
               Grid.Row="2"
               Margin="0,14,0,0"
               ItemWidth="138"
               ItemHeight="34">
      <Button x:Name="CreateVehicleButton"
              Command="{Binding CreateVehicleCommand}"
              Content="Nové vozidlo"
              AutomationProperties.Name="Vytvořit nové vozidlo"
              AutomationProperties.AutomationId="CreateVehicleButton" />
      <Button x:Name="EditVehicleButton"
              Command="{Binding EditSelectedVehicleCommand}"
              Content="Upravit"
              AutomationProperties.Name="Upravit vybrané vozidlo"
              AutomationProperties.AutomationId="EditVehicleButton" />
      <Button x:Name="DeleteVehicleButton"
              Command="{Binding DeleteSelectedVehicleCommand}"
              Content="Odstranit"
              IsVisible="{Binding IsVehicleDetailVisible}"
              AutomationProperties.Name="Odstranit vybrané vozidlo"
              AutomationProperties.HelpText="Otevře potvrzení a při potvrzení odstraní vybrané vozidlo včetně jeho souvisejících evidencí."
              AutomationProperties.AutomationId="DeleteVehicleButton" />
      <Button x:Name="OpenVehicleStarterBundleButton"
              Click="OnOpenVehicleStarterBundleClick"
              Content="Balíček"
              IsVisible="{Binding IsVehicleDetailVisible}"
              IsEnabled="{Binding CanOpenVehicleStarterBundle}"
              AutomationProperties.Name="Otevřít balíček pro vybrané vozidlo"
              AutomationProperties.AutomationId="OpenVehicleStarterBundleButton" />
    </WrapPanel>

    <ScrollViewer Grid.Row="3"
                  Margin="0,16,0,0">
      <StackPanel Spacing="14">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding SelectedVehicleHeading}"
                   AutomationProperties.Name="{Binding SelectedVehicleHeading}"
                   AutomationProperties.AutomationId="SelectedVehicleHeadingText"
                   AutomationProperties.HeadingLevel="2" />
        <TextBlock Text="{Binding SelectedVehicleOverview}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedVehicleOverview}"
                   AutomationProperties.AutomationId="SelectedVehicleOverviewText" />
        <TextBlock Text="{Binding SelectedVehicleDates}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedVehicleDates}"
                   AutomationProperties.AutomationId="SelectedVehicleDatesText" />
        <Border Padding="14" Background="#10203040" CornerRadius="8">
          <TextBlock Text="{Binding SelectedVehicleProfile}"
                     TextWrapping="Wrap"
                     AutomationProperties.Name="{Binding SelectedVehicleProfile}"
                     AutomationProperties.AutomationId="SelectedVehicleProfileText" />
        </Border>
        <TextBlock Text="{Binding SelectedVehicleEvidenceSummary}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedVehicleEvidenceSummary}"
                   AutomationProperties.AutomationId="SelectedVehicleEvidenceSummaryText" />
        <ItemsControl ItemsSource="{Binding EvidenceSummaryItems}"
                      AutomationProperties.Name="Stav navazujících evidencí vybraného vozidla"
                      AutomationProperties.AutomationId="VehicleDetailEvidenceSummaryItems">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="itemvm:VehicleDetailEvidenceSummaryItemViewModel">
              <Border Padding="10"
                      Margin="0,0,0,6"
                      Background="#08102030"
                      CornerRadius="6"
                      AutomationProperties.Name="{Binding AccessibleLabel}"
                      AutomationProperties.ItemType="Souhrn evidence vozidla">
                <Grid ColumnDefinitions="130,*">
                  <TextBlock FontWeight="SemiBold"
                             Text="{Binding Title}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Summary}"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Border Padding="14"
                Background="#10143A2A"
                CornerRadius="8"
                AutomationProperties.Name="Související evidence vybraného vozidla"
                AutomationProperties.AutomationId="VehicleDetailRelatedActionsPanel">
          <StackPanel Spacing="8">
            <TextBlock FontWeight="SemiBold" Text="Související evidence" />
            <TextBlock Opacity="0.76"
                       Text="Přejděte přímo do evidence, časové osy nebo nákladů vybraného vozidla."
                       TextWrapping="Wrap"
                       AutomationProperties.Name="Přejděte přímo do evidence, časové osy nebo nákladů vybraného vozidla."
                       AutomationProperties.AutomationId="VehicleDetailRelatedActionsHelpText" />
            <WrapPanel ItemWidth="148" ItemHeight="34">
              <Button Click="OnOpenVehicleHistoryWorkspaceClick"
                      Content="Historie"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít historii vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailHistoryButton" />
              <Button Click="OnOpenVehicleFuelWorkspaceClick"
                      Content="Tankování"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít tankování vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailFuelButton" />
              <Button Click="OnOpenVehicleReminderWorkspaceClick"
                      Content="Připomínky"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít připomínky vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailRemindersButton" />
              <Button Click="OnOpenVehicleMaintenanceWorkspaceClick"
                      Content="Údržba"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít plán údržby vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailMaintenanceButton" />
              <Button Click="OnOpenVehicleRecordWorkspaceClick"
                      Content="Doklady"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít doklady a přílohy vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailRecordsButton" />
              <Button Click="OnOpenVehicleTimelineWorkspaceClick"
                      Content="Časová osa"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít časovou osu vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailTimelineButton" />
              <Button Click="OnOpenVehicleServiceBookClick"
                      Content="Servisní knížka"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít servisní knížku vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailServiceBookButton" />
              <Button Click="OnOpenVehicleCostsWorkspaceClick"
                      Content="Náklady"
                      IsEnabled="{Binding CanOpenVehicleRelatedWorkspace}"
                      AutomationProperties.Name="Otevřít náklady vybraného vozidla"
                      AutomationProperties.AutomationId="OpenDetailCostsButton" />
            </WrapPanel>
          </StackPanel>
        </Border>
        <TextBlock FontWeight="SemiBold"
                   Text="{Binding SelectedVehicleRecentHistorySummary}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedVehicleRecentHistorySummary}"
                   AutomationProperties.AutomationId="SelectedVehicleRecentHistorySummaryText" />
        <ListBox ItemsSource="{Binding RecentHistoryItems}"
                 MinHeight="96"
                 MaxHeight="180"
                 AutomationProperties.Name="Poslední historické události vybraného vozidla"
                 AutomationProperties.AutomationId="VehicleDetailRecentHistoryListBox">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="itemvm:VehicleHistoryItemViewModel">
              <Border Padding="8" Margin="0,0,0,6" Background="#08102030" CornerRadius="6" AutomationProperties.Name="{Binding AccessibleLabel}" AutomationProperties.ItemType="Historický záznam">
                <Grid ColumnDefinitions="110,*,110,120">
                  <TextBlock Text="{Binding Date}" />
                  <TextBlock Grid.Column="1" Text="{Binding EventType}" TextWrapping="Wrap" />
                  <TextBlock Grid.Column="2" Text="{Binding Odometer}" />
                  <TextBlock Grid.Column="3" Text="{Binding Cost}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
