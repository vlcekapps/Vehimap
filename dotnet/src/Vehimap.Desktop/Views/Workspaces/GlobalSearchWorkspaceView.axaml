<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="using:Vehimap.Desktop.Localization"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.GlobalSearchWorkspaceView"
             x:DataType="vm:GlobalSearchWorkspaceViewModel">
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding RefreshGlobalSearchCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenSelectedSearchResultCommand}" />
    <KeyBinding Gesture="Ctrl+P" Command="{Binding OpenSelectedSearchResultCommand}" />
  </UserControl.KeyBindings>
  <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.25*,*">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding GlobalSearchSummary}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding GlobalSearchSummary}"
               AutomationProperties.AutomationId="GlobalSearchSummaryText" />
    <Grid Grid.Row="1"
          Grid.ColumnSpan="2"
          Margin="0,12,0,0"
          RowDefinitions="Auto,Auto"
          ColumnDefinitions="100,*,120,120,150">
      <TextBlock Grid.Column="0"
                 VerticalAlignment="Center"
                 Text="{i18n:Loc Common.Search}" />
      <TextBox x:Name="GlobalSearchTextBox"
               Grid.Column="1"
               Margin="12,0,0,0"
               Text="{Binding GlobalSearchText}"
               PlaceholderText="{i18n:Loc GlobalSearchWorkspace.SearchPlaceholder}"
               AutomationProperties.Name="{i18n:Loc GlobalSearchWorkspace.SearchName}"
               AutomationProperties.HelpText="{i18n:Loc GlobalSearchWorkspace.SearchHelp}"
               AutomationProperties.AutomationId="GlobalSearchTextBox" />
      <Button Grid.Column="2"
              x:Name="ClearGlobalSearchButton"
              Margin="12,0,0,0"
              Width="108"
              Command="{Binding ClearGlobalSearchCommand}"
              Content="{i18n:Loc Common.Clear}"
              AutomationProperties.Name="{i18n:Loc GlobalSearchWorkspace.ClearSearchName}"
              AutomationProperties.AutomationId="ClearGlobalSearchButton" />
      <Button Grid.Column="3"
              x:Name="GlobalSearchRefreshButton"
              Margin="12,0,0,0"
              Width="118"
              Command="{Binding RefreshGlobalSearchCommand}"
              Content="{i18n:Loc GlobalSearchWorkspace.Refresh}"
              AutomationProperties.Name="{i18n:Loc GlobalSearchWorkspace.RefreshName}"
              AutomationProperties.AutomationId="GlobalSearchRefreshButton" />
      <Button Grid.Column="4"
              x:Name="SearchOpenButton"
              Margin="12,0,0,0"
              Width="150"
              Command="{Binding OpenSelectedSearchResultCommand}"
              Content="{i18n:Loc GlobalSearchWorkspace.OpenItem}"
              AutomationProperties.Name="{i18n:Loc GlobalSearchWorkspace.OpenItemName}"
              AutomationProperties.AutomationId="SearchOpenButton" />
      <TextBlock Grid.Row="1"
                 Grid.Column="0"
                 Margin="0,8,0,0"
                 VerticalAlignment="Center"
                 Text="{i18n:Loc Common.Sort}" />
      <ComboBox Grid.Row="1"
                Grid.Column="1"
                Margin="12,8,0,0"
                ItemsSource="{Binding GlobalSearchSortOptions}"
                SelectedItem="{Binding SelectedGlobalSearchSortOption}"
                AutomationProperties.Name="{i18n:Loc GlobalSearchWorkspace.SortName}"
                AutomationProperties.AutomationId="GlobalSearchSortComboBox" />
      <CheckBox Grid.Row="1"
                Grid.Column="2"
                Grid.ColumnSpan="2"
                Margin="12,8,0,0"
                VerticalAlignment="Center"
                Content="{i18n:Loc Common.SortDescending}"
                IsChecked="{Binding GlobalSearchSortDescending}"
                AutomationProperties.Name="{i18n:Loc GlobalSearchWorkspace.SortDescendingName}"
                AutomationProperties.AutomationId="GlobalSearchSortDescendingCheckBox" />
    </Grid>

    <ListBox x:Name="SearchResultsListBox"
             Grid.Row="2"
             Margin="0,12,12,0"
             ItemsSource="{Binding GlobalSearchResults}"
             SelectedItem="{Binding SelectedSearchResult}"
             AutomationProperties.Name="{i18n:Loc GlobalSearchWorkspace.ListName}"
             AutomationProperties.AutomationId="SearchResultsListBox">
      <ListBox.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedSearchResultCommand}" />
      </ListBox.KeyBindings>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="itemvm:GlobalSearchResultItemViewModel">
          <Border Padding="12"
                  Margin="0,0,0,8"
                  Background="#10203040"
                  CornerRadius="6"
                  AutomationProperties.Name="{Binding AccessibleLabel}"
                  AutomationProperties.ItemType="{i18n:Loc GlobalSearchWorkspace.ItemType}">
            <StackPanel Spacing="4">
              <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
              <TextBlock Opacity="0.82" Text="{Binding SectionLabel}" />
              <TextBlock Opacity="0.82" Text="{Binding VehicleName}" />
              <TextBlock Opacity="0.72" Text="{Binding Summary}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Border Grid.Row="2"
            Grid.Column="1"
            Margin="12,12,0,0"
            Padding="16"
            Background="#10203040"
            CornerRadius="8">
      <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{i18n:Loc GlobalSearchWorkspace.DetailHeading}"
                   AutomationProperties.Name="{i18n:Loc GlobalSearchWorkspace.DetailHeading}"
                   AutomationProperties.AutomationId="GlobalSearchDetailHeadingText"
                   AutomationProperties.HeadingLevel="2" />
        <TextBlock Grid.Row="1"
                   Margin="0,12,0,0"
                   Opacity="0.75"
                   Text="{i18n:Loc GlobalSearchWorkspace.KeyboardHelp}"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="2"
                   Margin="0,16,0,0"
                   Text="{Binding SelectedSearchResultDetail}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding SelectedSearchResultDetail}"
                   AutomationProperties.AutomationId="SelectedSearchResultDetailText" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
