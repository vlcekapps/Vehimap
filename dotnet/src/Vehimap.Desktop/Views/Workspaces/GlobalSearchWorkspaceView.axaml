<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
             xmlns:itemvm="using:Vehimap.Desktop.ViewModels"
             x:Class="Vehimap.Desktop.Views.Workspaces.GlobalSearchWorkspaceView"
             x:DataType="vm:GlobalSearchWorkspaceViewModel">
  <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="1.25*,*">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding GlobalSearchSummary}"
               TextWrapping="Wrap" />
    <Grid Grid.Row="1"
          Grid.ColumnSpan="2"
          Margin="0,12,0,0"
          ColumnDefinitions="100,*,150">
      <TextBlock Grid.Column="0"
                 VerticalAlignment="Center"
                 Text="Hledat" />
      <TextBox x:Name="GlobalSearchTextBox"
               Grid.Column="1"
               Margin="12,0,0,0"
               Text="{Binding GlobalSearchText}"
               PlaceholderText="Vozidlo, SPZ, doklad, připomínka, údržba..."
               AutomationProperties.Name="Globální hledání ve Vehimapu"
               AutomationProperties.AutomationId="GlobalSearchTextBox" />
      <Button Grid.Column="2"
              x:Name="SearchOpenButton"
              Margin="12,0,0,0"
              Width="150"
              Command="{Binding OpenSelectedSearchResultCommand}"
              Content="Otevřít položku"
              AutomationProperties.Name="Otevřít vybraný výsledek hledání"
              AutomationProperties.AutomationId="SearchOpenButton" />
    </Grid>

    <ListBox x:Name="SearchResultsListBox"
             Grid.Row="2"
             Margin="0,12,12,0"
             ItemsSource="{Binding GlobalSearchResults}"
             SelectedItem="{Binding SelectedSearchResult}"
             AutomationProperties.Name="Výsledky globálního hledání"
             AutomationProperties.AutomationId="SearchResultsListBox">
      <ListBox.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding OpenSelectedSearchResultCommand}" />
      </ListBox.KeyBindings>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="itemvm:GlobalSearchResultItemViewModel">
          <Border Padding="12"
                  Margin="0,0,0,8"
                  Background="#10203040"
                  CornerRadius="6"
                  AutomationProperties.Name="{Binding AccessibleLabel}">
            <StackPanel Spacing="4">
              <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
              <TextBlock Opacity="0.82" Text="{Binding SectionLabel}" />
              <TextBlock Opacity="0.82" Text="{Binding VehicleName}" />
              <TextBlock Opacity="0.72" Text="{Binding Summary}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Border Grid.Row="2"
            Grid.Column="1"
            Margin="12,12,0,0"
            Padding="16"
            Background="#10203040"
            CornerRadius="8">
      <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Detail výsledku" />
        <TextBlock Grid.Row="1"
                   Margin="0,12,0,0"
                   Opacity="0.75"
                   Text="Enter nebo tlačítko otevře rovnou správné vozidlo nebo evidenci."
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="2"
                   Margin="0,16,0,0"
                   Text="{Binding SelectedSearchResultDetail}"
                   TextWrapping="Wrap" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
