<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.OverdueOverviewWindow"
        x:DataType="vm:OverdueOverviewWorkspaceViewModel"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="{i18n:Loc WorkspaceWindow.OverdueName}"
        AutomationProperties.AutomationId="OverdueOverviewWindow"
        AutomationProperties.HelpText="{i18n:Loc WorkspaceWindow.OverdueHelpText}">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}"
                   AutomationProperties.Name="{Binding WindowTitle}"
                   AutomationProperties.AutomationId="OverdueOverviewWindowHeadingText"
                   AutomationProperties.HeadingLevel="1" />
        <TextBlock Opacity="0.78"
                   Text="{Binding OverdueOverviewSummary}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              x:Name="CloseOverdueOverviewWindowButton"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="{i18n:Loc Common.Close}"
              AutomationProperties.Name="{i18n:Loc WorkspaceWindow.CloseOverdueName}"
              AutomationProperties.AutomationId="CloseOverdueOverviewWindowButton" />
    </Grid>

    <workspaces:OverdueOverviewWorkspaceView x:Name="OverdueOverviewWorkspaceHost"
                                             Grid.Row="1"
                                             Margin="0,18,0,0" />
  </Grid>
</Window>
