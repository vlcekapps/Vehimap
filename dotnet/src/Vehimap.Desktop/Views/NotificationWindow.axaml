<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        x:Class="Vehimap.Desktop.Views.NotificationWindow"
        Width="380"
        Height="140"
        ShowInTaskbar="False"
        CanResize="False"
        WindowDecorations="None"
        WindowStartupLocation="Manual"
        ShowActivated="False"
        Topmost="True"
        Title="{i18n:Loc Notification.Title}"
        AutomationProperties.Name="{i18n:Loc Notification.WindowName}"
        AutomationProperties.AutomationId="NotificationWindow"
        AutomationProperties.HelpText="{i18n:Loc Notification.HelpText}">
  <Border Margin="12" Padding="16" Background="#1C2B38" CornerRadius="10">
    <StackPanel Spacing="10">
      <TextBlock x:Name="NotificationTitleTextBlock"
                 FontSize="18"
                 FontWeight="SemiBold"
                 TextWrapping="Wrap"
                 AutomationProperties.Name="{i18n:Loc Notification.HeadingName}"
                 AutomationProperties.AutomationId="NotificationHeadingText"
                 AutomationProperties.HeadingLevel="1" />
      <TextBlock x:Name="NotificationMessageTextBlock" TextWrapping="Wrap" />
    </StackPanel>
  </Border>
</Window>
