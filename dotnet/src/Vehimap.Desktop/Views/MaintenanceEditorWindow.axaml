<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        x:Class="Vehimap.Desktop.Views.MaintenanceEditorWindow"
        x:DataType="vm:MaintenanceWorkspaceViewModel"
        Width="760"
        Height="660"
        MinWidth="660"
        MinHeight="520"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="{Binding MaintenanceEditorHeading}"
        AutomationProperties.Name="{Binding MaintenanceEditorHeading}"
        AutomationProperties.AutomationId="MaintenanceEditorWindow"
        AutomationProperties.HelpText="{i18n:Loc MaintenanceEditor.HelpText}">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock FontSize="20"
               FontWeight="SemiBold"
               Text="{Binding MaintenanceEditorHeading}"
               AutomationProperties.Name="{Binding MaintenanceEditorHeading}"
               AutomationProperties.AutomationId="MaintenanceEditorHeadingText"
               AutomationProperties.HeadingLevel="1" />
    <TextBlock Grid.Row="1"
               Margin="0,12,0,0"
               Opacity="0.82"
               Text="{Binding MaintenanceEditorStatus}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding MaintenanceEditorStatus}"
               AutomationProperties.AutomationId="MaintenanceEditorStatusText"
               AutomationProperties.LiveSetting="Polite" />
    <ScrollViewer Grid.Row="2"
                  Margin="0,16,0,0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  AutomationProperties.Name="{i18n:Loc MaintenanceEditor.FieldsName}"
                  AutomationProperties.AutomationId="MaintenanceEditorScrollViewer">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <TextBlock FontWeight="SemiBold" Text="{i18n:Loc MaintenanceEditor.TemplateLabel}" />
        <ComboBox x:Name="MaintenanceTemplateComboBox"
                  Grid.Row="1"
                  Margin="0,6,0,0"
                  ItemsSource="{Binding MaintenanceTemplateOptions}"
                  SelectedItem="{Binding SelectedMaintenanceTemplate}"
                  AutomationProperties.Name="{i18n:Loc MaintenanceEditor.TemplateName}"
                  AutomationProperties.AutomationId="MaintenanceTemplateComboBox" />
        <TextBlock Grid.Row="2" Margin="0,14,0,0" FontWeight="SemiBold" Text="{i18n:Loc MaintenanceEditor.TitleLabel}" />
        <TextBox x:Name="MaintenanceEditorTitleBox"
                 Grid.Row="3"
                 Margin="0,6,0,0"
                 Text="{Binding MaintenanceEditorTitle}"
                 PlaceholderText="{i18n:Loc MaintenanceEditor.TitleExample}"
                 AutomationProperties.Name="{i18n:Loc MaintenanceEditor.TitleName}"
                 AutomationProperties.HelpText="{i18n:Loc MaintenanceEditor.TitleExample}"
                 AutomationProperties.AutomationId="MaintenanceEditorTitleBox"
                 AutomationProperties.IsRequiredForForm="True" />
        <Grid Grid.Row="4" Margin="0,14,0,0" ColumnDefinitions="*,*">
          <StackPanel Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{Binding MaintenanceEditorIntervalDistanceLabel}" />
            <TextBox x:Name="MaintenanceEditorIntervalKmBox"
                     Text="{Binding MaintenanceEditorIntervalKm}"
                     PlaceholderText="{i18n:Loc MaintenanceEditor.IntervalDistanceExample}"
                     AutomationProperties.Name="{Binding MaintenanceEditorIntervalDistanceName}"
                     AutomationProperties.HelpText="{Binding MaintenanceEditorIntervalDistanceHelp}"
                     AutomationProperties.AutomationId="MaintenanceEditorIntervalKmBox" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc MaintenanceEditor.IntervalMonthsLabel}" />
            <TextBox x:Name="MaintenanceEditorIntervalMonthsBox"
                     Text="{Binding MaintenanceEditorIntervalMonths}"
                     PlaceholderText="{i18n:Loc MaintenanceEditor.IntervalMonthsExample}"
                     AutomationProperties.Name="{i18n:Loc MaintenanceEditor.IntervalMonthsName}"
                     AutomationProperties.HelpText="{i18n:Loc MaintenanceEditor.IntervalMonthsExample}"
                     AutomationProperties.AutomationId="MaintenanceEditorIntervalMonthsBox" />
          </StackPanel>
        </Grid>
        <Grid Grid.Row="5" Margin="0,14,0,0" ColumnDefinitions="*,*">
          <StackPanel Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc MaintenanceEditor.LastServiceDateLabel}" />
            <TextBox x:Name="MaintenanceEditorLastServiceDateBox"
                     Text="{Binding MaintenanceEditorLastServiceDate}"
                     PlaceholderText="{i18n:Loc MaintenanceEditor.LastServiceDateExample}"
                     AutomationProperties.Name="{i18n:Loc MaintenanceEditor.LastServiceDateName}"
                     AutomationProperties.HelpText="{i18n:Loc MaintenanceEditor.LastServiceDateExample}"
                     AutomationProperties.AutomationId="MaintenanceEditorLastServiceDateBox" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{Binding MaintenanceEditorLastServiceOdometerLabel}" />
            <TextBox x:Name="MaintenanceEditorLastServiceOdometerBox"
                     Text="{Binding MaintenanceEditorLastServiceOdometer}"
                     PlaceholderText="{i18n:Loc MaintenanceEditor.LastServiceOdometerExample}"
                     AutomationProperties.Name="{Binding MaintenanceEditorLastServiceOdometerName}"
                     AutomationProperties.HelpText="{Binding MaintenanceEditorLastServiceOdometerHelp}"
                     AutomationProperties.AutomationId="MaintenanceEditorLastServiceOdometerBox" />
          </StackPanel>
        </Grid>
        <CheckBox Grid.Row="6"
                  Margin="0,14,0,0"
                  IsChecked="{Binding MaintenanceEditorIsActive}"
                  Content="{i18n:Loc MaintenanceEditor.IsActive}"
                  AutomationProperties.Name="{i18n:Loc MaintenanceEditor.IsActiveName}"
                  AutomationProperties.AutomationId="MaintenanceEditorIsActiveCheckBox" />
        <TextBlock Grid.Row="7" Margin="0,14,0,0" FontWeight="SemiBold" Text="{i18n:Loc MaintenanceEditor.NoteLabel}" />
        <TextBox Grid.Row="8"
                 Margin="0,6,0,0"
                 Height="120"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalContentAlignment="Top"
                 Text="{Binding MaintenanceEditorNote}"
                 AutomationProperties.Name="{i18n:Loc MaintenanceEditor.NoteName}"
                 AutomationProperties.AutomationId="MaintenanceEditorNoteBox" />
      </Grid>
    </ScrollViewer>
    <StackPanel Grid.Row="3"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10">
      <Button x:Name="CancelMaintenanceButton"
              MinWidth="110"
              Content="{i18n:Loc Common.Cancel}"
              Click="OnCancelClick"
              AutomationProperties.Name="{i18n:Loc MaintenanceEditor.CancelName}"
              AutomationProperties.AutomationId="CancelMaintenanceButton" />
      <Button MinWidth="110"
              Content="{i18n:Loc Common.Save}"
              IsEnabled="{Binding IsEditingMaintenance}"
              Click="OnSaveClick"
              AutomationProperties.Name="{i18n:Loc MaintenanceEditor.SaveName}"
              AutomationProperties.AutomationId="SaveMaintenanceButton" />
    </StackPanel>
  </Grid>
</Window>
