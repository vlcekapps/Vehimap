<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.SmartAdvisorWindow"
        x:DataType="vm:SmartAdvisorWorkspaceViewModel"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="Chytrý poradce"
        AutomationProperties.AutomationId="SmartAdvisorWindow"
        AutomationProperties.HelpText="Samostatné okno chytrého poradce. Escape okno zavře.">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}" />
        <TextBlock Opacity="0.78"
                   Text="{Binding SmartAdvisorSummary}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              x:Name="CloseSmartAdvisorWindowButton"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="Zavřít"
              AutomationProperties.Name="Zavřít okno chytrého poradce"
              AutomationProperties.AutomationId="CloseSmartAdvisorWindowButton" />
    </Grid>

    <workspaces:SmartAdvisorWorkspaceView x:Name="SmartAdvisorWorkspaceHost"
                                          Grid.Row="1"
                                          Margin="0,18,0,0" />
  </Grid>
</Window>
