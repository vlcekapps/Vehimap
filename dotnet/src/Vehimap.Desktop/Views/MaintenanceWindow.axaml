<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.MaintenanceWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1320"
        Height="800"
        MinWidth="1080"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Title="{Binding MaintenanceWindowTitle}"
        AutomationProperties.Name="Plán údržby vozidla"
        AutomationProperties.HelpText="Samostatné okno pro práci s plánem údržby vybraného vozidla.">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*">
    <TextBlock FontSize="24"
               FontWeight="SemiBold"
               Text="{Binding MaintenanceWindowTitle}" />
    <TextBlock Grid.Row="1"
               Margin="0,8,0,0"
               Opacity="0.78"
               Text="{Binding MaintenanceSummary}"
               TextWrapping="Wrap" />

    <Grid Grid.Row="2"
          Margin="0,18,0,0"
          ColumnDefinitions="1.15*,*">
      <Grid RowDefinitions="Auto,*">
        <TextBlock FontWeight="SemiBold"
                   Text="Servisní plány vybraného vozidla" />
        <ListBox x:Name="MaintenanceWindowListBox"
                 Grid.Row="1"
                 Margin="0,12,12,0"
                 ItemsSource="{Binding SelectedVehicleMaintenance}"
                 SelectedItem="{Binding SelectedMaintenance}"
                 AutomationProperties.Name="Plán údržby vybraného vozidla v samostatném okně">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:VehicleMaintenanceItemViewModel">
              <Border Padding="12"
                      Margin="0,0,0,8"
                      Background="#10203040"
                      CornerRadius="6"
                      AutomationProperties.Name="{Binding AccessibleLabel}">
                <Grid ColumnDefinitions="2*,170,170,180,*">
                  <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                  <TextBlock Grid.Column="1" Text="{Binding Interval}" TextWrapping="Wrap" />
                  <TextBlock Grid.Column="2" Text="{Binding LastService}" TextWrapping="Wrap" />
                  <TextBlock Grid.Column="3" Text="{Binding Status}" TextWrapping="Wrap" />
                  <TextBlock Grid.Column="4" Text="{Binding Note}" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <Border Grid.Column="1"
              Margin="12,0,0,0"
              Padding="16"
              Background="#10203040"
              CornerRadius="8">
        <Grid RowDefinitions="Auto,Auto,Auto,*">
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="{Binding MaintenancePanelHeading}" />
          <WrapPanel Grid.Row="1"
                     Margin="0,14,0,0"
                     ItemWidth="132"
                     ItemHeight="34">
            <Button Command="{Binding CreateMaintenanceCommand}"
                    Content="Nový plán"
                    AutomationProperties.Name="Vytvořit nový servisní plán" />
            <Button Command="{Binding EditSelectedMaintenanceCommand}"
                    Content="Upravit"
                    AutomationProperties.Name="Upravit vybraný servisní plán" />
            <Button Command="{Binding DeleteSelectedMaintenanceCommand}"
                    Content="Odstranit"
                    AutomationProperties.Name="Odstranit vybraný servisní plán" />
            <Button Command="{Binding SaveMaintenanceCommand}"
                    Content="Uložit"
                    IsVisible="{Binding IsEditingMaintenance}"
                    AutomationProperties.Name="Uložit servisní plán" />
            <Button Command="{Binding CancelMaintenanceEditCommand}"
                    Content="Zrušit"
                    IsVisible="{Binding IsEditingMaintenance}"
                    AutomationProperties.Name="Zrušit úpravu servisního plánu" />
            <Button Click="OnCloseClick"
                    Content="Zavřít"
                    AutomationProperties.Name="Zavřít okno plánu údržby" />
          </WrapPanel>
          <TextBlock Grid.Row="2"
                     Margin="0,12,0,0"
                     Opacity="0.82"
                     Text="{Binding MaintenanceEditorStatus}"
                     TextWrapping="Wrap" />
          <Grid Grid.Row="3"
                Margin="0,16,0,0"
                IsVisible="{Binding IsEditingMaintenance}"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            <TextBlock FontWeight="SemiBold" Text="Název úkonu" />
            <TextBox x:Name="MaintenanceWindowTitleBox"
                     Grid.Row="1"
                     Margin="0,6,0,0"
                     Text="{Binding MaintenanceEditorTitle}"
                     PlaceholderText="Například Motorový olej" />
            <Grid Grid.Row="2"
                  Margin="0,14,0,0"
                  ColumnDefinitions="*,*">
              <StackPanel Margin="0,0,12,0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Interval km" />
                <TextBox Text="{Binding MaintenanceEditorIntervalKm}"
                         PlaceholderText="Například 15000" />
              </StackPanel>
              <StackPanel Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Interval měsíců" />
                <TextBox Text="{Binding MaintenanceEditorIntervalMonths}"
                         PlaceholderText="Například 12" />
              </StackPanel>
            </Grid>
            <Grid Grid.Row="3"
                  Margin="0,14,0,0"
                  ColumnDefinitions="*,*">
              <StackPanel Margin="0,0,12,0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Poslední servis - datum" />
                <TextBox Text="{Binding MaintenanceEditorLastServiceDate}"
                         PlaceholderText="Například 15.06.2026" />
              </StackPanel>
              <StackPanel Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="Poslední servis - tachometr" />
                <TextBox Text="{Binding MaintenanceEditorLastServiceOdometer}"
                         PlaceholderText="Například 123456" />
              </StackPanel>
            </Grid>
            <CheckBox Grid.Row="4"
                      Margin="0,14,0,0"
                      IsChecked="{Binding MaintenanceEditorIsActive}"
                      Content="Aktivní servisní plán"
                      AutomationProperties.Name="Servisní plán je aktivní" />
            <TextBlock Grid.Row="5"
                       Margin="0,14,0,0"
                       FontWeight="SemiBold"
                       Text="Poznámka" />
            <TextBox Grid.Row="6"
                     Margin="0,6,0,0"
                     Height="120"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"
                     Text="{Binding MaintenanceEditorNote}" />
          </Grid>
          <TextBlock Grid.Row="3"
                     Margin="0,16,0,0"
                     IsVisible="{Binding IsMaintenanceDetailVisible}"
                     Text="{Binding SelectedMaintenanceDetail}"
                     TextWrapping="Wrap" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
