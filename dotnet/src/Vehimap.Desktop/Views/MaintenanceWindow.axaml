<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.MaintenanceWindow"
        x:DataType="vm:MaintenanceWorkspaceViewModel"
        Width="1360"
        Height="820"
        MinWidth="1120"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="Plán údržby vozidla"
        AutomationProperties.AutomationId="MaintenanceWindow"
        AutomationProperties.HelpText="Samostatné okno pro práci s plánem údržby vybraného vozidla.">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}" />
        <TextBlock Opacity="0.78"
                   Text="{Binding MaintenanceSummary}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="Zavřít"
              AutomationProperties.Name="Zavřít okno plánu údržby"
              AutomationProperties.AutomationId="CloseMaintenanceWindowButton" />
    </Grid>

    <workspaces:MaintenanceWorkspaceView x:Name="MaintenanceWorkspaceHost"
                                         Grid.Row="1"
                                         Margin="0,18,0,0" />
  </Grid>
</Window>
