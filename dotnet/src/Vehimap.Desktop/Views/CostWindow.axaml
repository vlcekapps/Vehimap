<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.CostWindow"
        x:DataType="vm:CostWorkspaceViewModel"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="{i18n:Loc WorkspaceWindow.CostName}"
        AutomationProperties.AutomationId="CostWindow"
        AutomationProperties.HelpText="{i18n:Loc WorkspaceWindow.CostHelpText}">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}"
                   AutomationProperties.Name="{Binding WindowTitle}"
                   AutomationProperties.AutomationId="CostWindowHeadingText"
                   AutomationProperties.HeadingLevel="1" />
        <TextBlock Opacity="0.78"
                   Text="{Binding CostSummary}"
                   TextWrapping="Wrap" />
        <TextBlock Opacity="0.78"
                   Text="{Binding CostComparison}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              x:Name="CloseCostWindowButton"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="{i18n:Loc Common.Close}"
              AutomationProperties.Name="{i18n:Loc WorkspaceWindow.CloseCostName}"
              AutomationProperties.AutomationId="CloseCostWindowButton" />
    </Grid>

    <workspaces:CostWorkspaceView x:Name="CostWorkspaceHost"
                                  Grid.Row="1"
                                  Margin="0,18,0,0" />
  </Grid>
</Window>
