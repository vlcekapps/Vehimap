<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.DashboardWindow"
        x:DataType="vm:DashboardWorkspaceViewModel"
        Width="1460"
        Height="860"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="{i18n:Loc WorkspaceWindow.DashboardName}"
        AutomationProperties.AutomationId="DashboardWindow"
        AutomationProperties.HelpText="{i18n:Loc WorkspaceWindow.DashboardHelpText}">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}"
                   AutomationProperties.Name="{Binding WindowTitle}"
                   AutomationProperties.AutomationId="DashboardWindowHeadingText"
                   AutomationProperties.HeadingLevel="1" />
        <TextBlock Text="{Binding AuditSummary}" TextWrapping="Wrap" />
        <TextBlock Opacity="0.82" Text="{Binding CostSummary}" TextWrapping="Wrap" />
        <TextBlock Opacity="0.75" Text="{Binding CostComparison}" TextWrapping="Wrap" />
        <TextBlock Opacity="0.75" Text="{Binding DashboardTimelineSummary}" TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              x:Name="CloseDashboardWindowButton"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="{i18n:Loc Common.Close}"
              AutomationProperties.Name="{i18n:Loc WorkspaceWindow.CloseDashboardName}"
              AutomationProperties.AutomationId="CloseDashboardWindowButton" />
    </Grid>

    <workspaces:DashboardWorkspaceView x:Name="DashboardWorkspaceHost"
                                       Grid.Row="1"
                                       Margin="0,18,0,0" />
  </Grid>
</Window>
