<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.AboutWindow"
        x:DataType="vm:AboutDialogViewModel"
        Width="620"
        Height="390"
        MinWidth="560"
        MinHeight="360"
        CanResize="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="O programu"
        AutomationProperties.Name="O programu"
        AutomationProperties.AutomationId="AboutWindow"
        AutomationProperties.HelpText="Informace o aplikaci Vehimap. Ctrl+O otevře release poznámky, Ctrl+Shift+C zkopíruje diagnostická data a Escape dialog zavře.">
  <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
    <TextBlock FontSize="22"
               FontWeight="SemiBold"
               Text="{Binding Title}"
               AutomationProperties.Name="{Binding Title}"
               AutomationProperties.AutomationId="AboutTitleText" />

    <TextBlock Grid.Row="1"
               Margin="0,8,0,0"
               Opacity="0.78"
               Text="Přístupná evidence vozidel pro Windows a postupně další platformy."
               TextWrapping="Wrap"
               AutomationProperties.Name="Přístupná evidence vozidel pro Windows a postupně další platformy."
               AutomationProperties.AutomationId="AboutDescriptionText" />

    <Border Grid.Row="2"
            Margin="0,18,0,0"
            Padding="14"
            Background="#10203040"
            CornerRadius="8"
            AutomationProperties.Name="Základní informace o aplikaci"
            AutomationProperties.AutomationId="AboutSummaryPanel">
      <Grid ColumnDefinitions="130,*"
            RowDefinitions="Auto,Auto,Auto"
            RowSpacing="8">
        <TextBlock Grid.Row="0" Text="Aplikace" FontWeight="SemiBold" />
        <TextBlock Grid.Row="0"
                   Grid.Column="1"
                   Text="{Binding Title}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding Title}"
                   AutomationProperties.AutomationId="AboutApplicationText" />

        <TextBlock Grid.Row="1" Text="Autor" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Grid.Column="1"
                   Text="{Binding Author}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding Author}"
                   AutomationProperties.AutomationId="AboutAuthorText" />

        <TextBlock Grid.Row="2" Text="Verze" FontWeight="SemiBold" />
        <TextBlock Grid.Row="2"
                   Grid.Column="1"
                   Text="{Binding DisplayVersion}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding DisplayVersion}"
                   AutomationProperties.AutomationId="AboutVersionText" />
      </Grid>
    </Border>

    <Button x:Name="ToggleAboutDiagnosticsButton"
            Grid.Row="3"
            Margin="0,18,0,0"
            HorizontalAlignment="Left"
            MinWidth="210"
            Click="OnToggleDiagnosticsClick"
            Content="{Binding ToggleDiagnosticsLabel}"
            AutomationProperties.Name="{Binding ToggleDiagnosticsLabel}"
            AutomationProperties.AutomationId="ToggleAboutDiagnosticsButton" />

    <ScrollViewer Grid.Row="4"
                  Margin="0,12,0,0"
                  MaxHeight="180"
                  IsVisible="{Binding IsDiagnosticsVisible}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  AutomationProperties.Name="Diagnostická data o aplikaci"
                  AutomationProperties.AutomationId="AboutDetailsScrollViewer">
      <TextBox x:Name="AboutDiagnosticsTextBox"
               Text="{Binding DiagnosticText}"
               IsReadOnly="True"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               BorderThickness="0"
               Background="Transparent"
               AutomationProperties.Name="Diagnostická data o aplikaci"
               AutomationProperties.AutomationId="AboutDiagnosticsTextBox" />
    </ScrollViewer>

    <Border Grid.Row="5"
            Margin="0,18,0,0"
            Padding="12"
            Background="#143A4A5A"
            CornerRadius="8">
      <TextBlock Text="{Binding StatusMessage}"
                 TextWrapping="Wrap"
                 AutomationProperties.Name="{Binding StatusMessage}"
                 AutomationProperties.AutomationId="AboutStatusText" />
    </Border>

    <StackPanel Grid.Row="6"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10">
      <Button x:Name="ReleaseNotesButton"
              MinWidth="170"
              Click="OnReleaseNotesClick"
              Content="Release poznámky"
              AutomationProperties.Name="Otevřít release poznámky"
              AutomationProperties.AutomationId="ReleaseNotesButton" />
      <Button x:Name="CopyAboutDetailsButton"
              MinWidth="190"
              Click="OnCopyDetailsClick"
              Content="Kopírovat diagnostiku"
              AutomationProperties.Name="Kopírovat diagnostická data o aplikaci do schránky"
              AutomationProperties.AutomationId="CopyAboutDetailsButton" />
      <Button x:Name="CloseAboutButton"
              MinWidth="110"
              Click="OnCloseClick"
              Content="Zavřít"
              AutomationProperties.Name="Zavřít dialog O programu"
              AutomationProperties.AutomationId="CloseAboutButton" />
    </StackPanel>
  </Grid>
</Window>
