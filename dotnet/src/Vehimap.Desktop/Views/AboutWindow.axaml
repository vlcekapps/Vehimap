<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.AboutWindow"
        x:DataType="vm:AboutDialogViewModel"
        Width="620"
        Height="430"
        MinWidth="560"
        MinHeight="390"
        CanResize="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="{i18n:Loc About.Title}"
        AutomationProperties.Name="{i18n:Loc About.Title}"
        AutomationProperties.AutomationId="AboutWindow"
        AutomationProperties.HelpText="{i18n:Loc About.HelpText}">
  <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
    <TextBlock FontSize="22"
               FontWeight="SemiBold"
               Text="{Binding Title}"
               AutomationProperties.Name="{Binding Title}"
               AutomationProperties.AutomationId="AboutTitleText"
               AutomationProperties.HeadingLevel="1" />

    <TextBlock Grid.Row="1"
               Margin="0,8,0,0"
               Opacity="0.78"
               Text="{i18n:Loc About.Description}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{i18n:Loc About.Description}"
               AutomationProperties.AutomationId="AboutDescriptionText" />

    <Border Grid.Row="2"
            Margin="0,18,0,0"
            Padding="14"
            Background="#10203040"
            CornerRadius="8"
            AutomationProperties.Name="{i18n:Loc About.BasicInfo}"
            AutomationProperties.AutomationId="AboutSummaryPanel">
      <Grid ColumnDefinitions="130,*"
            RowDefinitions="Auto,Auto,Auto"
            RowSpacing="8">
        <TextBlock Grid.Row="0" Text="{i18n:Loc About.Application}" FontWeight="SemiBold" />
        <TextBlock Grid.Row="0"
                   Grid.Column="1"
                   Text="{Binding Title}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding Title}"
                   AutomationProperties.AutomationId="AboutApplicationText" />

        <TextBlock Grid.Row="1" Text="{i18n:Loc About.Author}" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Grid.Column="1"
                   Text="{Binding Author}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding Author}"
                   AutomationProperties.AutomationId="AboutAuthorText" />

        <TextBlock Grid.Row="2" Text="{i18n:Loc About.Version}" FontWeight="SemiBold" />
        <TextBlock Grid.Row="2"
                   Grid.Column="1"
                   Text="{Binding DisplayVersion}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{Binding DisplayVersion}"
                   AutomationProperties.AutomationId="AboutVersionText" />
      </Grid>
    </Border>

    <Button x:Name="ToggleAboutDiagnosticsButton"
            Grid.Row="3"
            Margin="0,18,0,0"
            HorizontalAlignment="Left"
            MinWidth="210"
            Click="OnToggleDiagnosticsClick"
            Content="{Binding ToggleDiagnosticsLabel}"
            AutomationProperties.Name="{Binding ToggleDiagnosticsLabel}"
            AutomationProperties.AutomationId="ToggleAboutDiagnosticsButton" />

    <ScrollViewer Grid.Row="4"
                  Margin="0,12,0,0"
                  MaxHeight="180"
                  IsVisible="{Binding IsDiagnosticsVisible}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  AutomationProperties.Name="{i18n:Loc About.DiagnosticsName}"
                  AutomationProperties.AutomationId="AboutDetailsScrollViewer">
      <TextBox x:Name="AboutDiagnosticsTextBox"
               Text="{Binding DiagnosticText}"
               IsReadOnly="True"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               BorderThickness="0"
               Background="Transparent"
               AutomationProperties.Name="{i18n:Loc About.DiagnosticsName}"
               AutomationProperties.AutomationId="AboutDiagnosticsTextBox" />
    </ScrollViewer>

    <Border Grid.Row="5"
            Margin="0,18,0,0"
            Padding="12"
            Background="#143A4A5A"
            CornerRadius="8">
      <TextBlock Text="{Binding StatusMessage}"
                 TextWrapping="Wrap"
                 AutomationProperties.Name="{Binding StatusMessage}"
                 AutomationProperties.AutomationId="AboutStatusText"
                 AutomationProperties.LiveSetting="Polite" />
    </Border>

    <StackPanel Grid.Row="6"
                Margin="0,18,0,0"
                Orientation="Vertical"
                HorizontalAlignment="Right"
                Spacing="8">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="10">
        <Button x:Name="ReleaseNotesButton"
                MinWidth="170"
                Click="OnReleaseNotesClick"
                Content="{i18n:Loc About.Action.ReleaseNotes}"
                AutomationProperties.Name="{i18n:Loc About.ReleaseNotesName}"
                AutomationProperties.AutomationId="ReleaseNotesButton" />
        <Button x:Name="ThankAuthorButton"
                MinWidth="170"
                Click="OnThankAuthorClick"
                Content="{Binding ThankAuthorLabel}"
                AutomationProperties.Name="{Binding ThankAuthorHelpText}"
                AutomationProperties.AutomationId="ThankAuthorButton" />
      </StackPanel>
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="10">
        <Button x:Name="CopyAboutDetailsButton"
                MinWidth="190"
                Click="OnCopyDetailsClick"
                Content="{i18n:Loc About.Action.CopyDiagnostics}"
                AutomationProperties.Name="{i18n:Loc About.CopyDiagnosticsName}"
                AutomationProperties.AutomationId="CopyAboutDetailsButton" />
        <Button x:Name="CloseAboutButton"
                MinWidth="110"
                Click="OnCloseClick"
                Content="{i18n:Loc About.Action.Close}"
                AutomationProperties.Name="{i18n:Loc About.CloseName}"
                AutomationProperties.AutomationId="CloseAboutButton" />
      </StackPanel>
    </StackPanel>
  </Grid>
</Window>
