<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        x:Class="Vehimap.Desktop.Views.VehicleEditorWindow"
        x:DataType="vm:VehicleDetailWorkspaceViewModel"
        Width="820"
        Height="720"
        MinWidth="720"
        MinHeight="560"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="{Binding VehicleEditorHeading}"
        AutomationProperties.Name="{Binding VehicleEditorHeading}"
        AutomationProperties.AutomationId="VehicleEditorWindow"
        AutomationProperties.HelpText="{i18n:Loc VehicleEditor.HelpText}">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock FontSize="20"
               FontWeight="SemiBold"
               Text="{Binding VehicleEditorHeading}"
               AutomationProperties.Name="{Binding VehicleEditorHeading}"
               AutomationProperties.AutomationId="VehicleEditorHeadingText"
               AutomationProperties.HeadingLevel="1" />

    <TextBlock Grid.Row="1"
               Margin="0,12,0,0"
               Opacity="0.82"
               Text="{Binding VehicleEditorStatus}"
               TextWrapping="Wrap"
               AutomationProperties.Name="{Binding VehicleEditorStatus}"
               AutomationProperties.AutomationId="VehicleEditorStatusText"
               AutomationProperties.LiveSetting="Polite" />

    <ScrollViewer Grid.Row="2"
                  Margin="0,16,0,0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  AutomationProperties.Name="{i18n:Loc VehicleEditor.FieldsName}"
                  AutomationProperties.AutomationId="VehicleEditorScrollViewer">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <Grid ColumnDefinitions="*,220">
          <StackPanel Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.Name}" />
            <TextBox x:Name="VehicleEditorNameBox"
                     Text="{Binding VehicleEditorName}"
                     PlaceholderText="{i18n:Loc VehicleEditor.NameHelp}"
                     AutomationProperties.Name="{i18n:Loc VehicleEditor.Name}"
                     AutomationProperties.HelpText="{i18n:Loc VehicleEditor.NameHelp}"
                     AutomationProperties.AutomationId="VehicleEditorNameBox"
                     AutomationProperties.IsRequiredForForm="True" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.Category}" />
            <ComboBox x:Name="VehicleEditorCategoryBox"
                      ItemsSource="{Binding VehicleCategoryOptions}"
                      SelectedItem="{Binding VehicleEditorCategory}"
                      AutomationProperties.Name="{i18n:Loc VehicleEditor.CategoryName}"
                      AutomationProperties.AutomationId="VehicleEditorCategoryBox"
                      AutomationProperties.IsRequiredForForm="True" />
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,0" ColumnDefinitions="*,220">
          <StackPanel Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.MakeModel}" />
            <TextBox x:Name="VehicleEditorMakeModelBox"
                     Text="{Binding VehicleEditorMakeModel}"
                     PlaceholderText="{i18n:Loc VehicleEditor.MakeModelHelp}"
                     AutomationProperties.Name="{i18n:Loc VehicleEditor.MakeModelName}"
                     AutomationProperties.HelpText="{i18n:Loc VehicleEditor.MakeModelHelp}"
                     AutomationProperties.AutomationId="VehicleEditorMakeModelBox"
                     AutomationProperties.IsRequiredForForm="True" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.Plate}" />
            <TextBox x:Name="VehicleEditorPlateBox"
                     Text="{Binding VehicleEditorPlate}"
                     PlaceholderText="{i18n:Loc VehicleEditor.PlateHelp}"
                     AutomationProperties.Name="{i18n:Loc VehicleEditor.PlateName}"
                     AutomationProperties.HelpText="{i18n:Loc VehicleEditor.PlateHelp}"
                     AutomationProperties.AutomationId="VehicleEditorPlateBox" />
          </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="160,160,*">
          <StackPanel Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.Year}" />
            <TextBox x:Name="VehicleEditorYearBox"
                     Text="{Binding VehicleEditorYear}"
                     AutomationProperties.Name="{i18n:Loc VehicleEditor.YearName}"
                     AutomationProperties.AutomationId="VehicleEditorYearBox" />
          </StackPanel>
          <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.Power}" />
            <TextBox x:Name="VehicleEditorPowerBox"
                     Text="{Binding VehicleEditorPower}"
                     AutomationProperties.Name="{i18n:Loc VehicleEditor.PowerName}"
                     AutomationProperties.AutomationId="VehicleEditorPowerBox" />
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.State}" />
            <ComboBox x:Name="VehicleEditorStateBox"
                      ItemsSource="{Binding VehicleStateOptions}"
                      SelectedItem="{Binding VehicleEditorState}"
                      AutomationProperties.Name="{i18n:Loc VehicleEditor.StateName}"
                      AutomationProperties.AutomationId="VehicleEditorStateBox" />
          </StackPanel>
        </Grid>

        <Grid Grid.Row="3" Margin="0,14,0,0" ColumnDefinitions="*,*">
          <StackPanel Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.LastTk}" />
            <TextBox x:Name="VehicleEditorLastTkBox"
                     Text="{Binding VehicleEditorLastTk}"
                     AutomationProperties.Name="{i18n:Loc VehicleEditor.LastTk}"
                     AutomationProperties.AutomationId="VehicleEditorLastTkBox" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.NextTk}" />
            <TextBox x:Name="VehicleEditorNextTkBox"
                     Text="{Binding VehicleEditorNextTk}"
                     AutomationProperties.Name="{i18n:Loc VehicleEditor.NextTk}"
                     AutomationProperties.AutomationId="VehicleEditorNextTkBox"
                     AutomationProperties.IsRequiredForForm="True" />
          </StackPanel>
        </Grid>

        <Grid Grid.Row="4" Margin="0,14,0,0" ColumnDefinitions="*,*">
          <StackPanel Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.GreenCardFrom}" />
            <TextBox x:Name="VehicleEditorGreenCardFromBox"
                     Text="{Binding VehicleEditorGreenCardFrom}"
                     AutomationProperties.Name="{i18n:Loc VehicleEditor.GreenCardFrom}"
                     AutomationProperties.AutomationId="VehicleEditorGreenCardFromBox" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.GreenCardTo}" />
            <TextBox x:Name="VehicleEditorGreenCardToBox"
                     Text="{Binding VehicleEditorGreenCardTo}"
                     AutomationProperties.Name="{i18n:Loc VehicleEditor.GreenCardTo}"
                     AutomationProperties.AutomationId="VehicleEditorGreenCardToBox" />
          </StackPanel>
        </Grid>

        <TextBlock Grid.Row="5" Margin="0,14,0,0" FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.ServiceProfile}" />
        <Grid Grid.Row="6" Margin="0,6,0,0" ColumnDefinitions="*,*,*,*">
          <StackPanel Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.Powertrain}" />
            <ComboBox x:Name="VehicleEditorPowertrainBox"
                      ItemsSource="{Binding VehiclePowertrainOptions}"
                      SelectedItem="{Binding VehicleEditorPowertrain}"
                      AutomationProperties.Name="{i18n:Loc VehicleEditor.PowertrainName}"
                      AutomationProperties.AutomationId="VehicleEditorPowertrainBox" />
          </StackPanel>
          <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.Climate}" />
            <ComboBox x:Name="VehicleEditorClimateProfileBox"
                      ItemsSource="{Binding VehicleClimateProfileOptions}"
                      SelectedItem="{Binding VehicleEditorClimateProfile}"
                      AutomationProperties.Name="{i18n:Loc VehicleEditor.ClimateName}"
                      AutomationProperties.AutomationId="VehicleEditorClimateProfileBox" />
          </StackPanel>
          <StackPanel Grid.Column="2" Margin="0,0,12,0" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.TimingDrive}" />
            <ComboBox x:Name="VehicleEditorTimingDriveBox"
                      ItemsSource="{Binding VehicleTimingDriveOptions}"
                      SelectedItem="{Binding VehicleEditorTimingDrive}"
                      AutomationProperties.Name="{i18n:Loc VehicleEditor.TimingDriveName}"
                      AutomationProperties.AutomationId="VehicleEditorTimingDriveBox" />
          </StackPanel>
          <StackPanel Grid.Column="3" Spacing="6">
            <TextBlock FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.Transmission}" />
            <ComboBox x:Name="VehicleEditorTransmissionBox"
                      ItemsSource="{Binding VehicleTransmissionOptions}"
                      SelectedItem="{Binding VehicleEditorTransmission}"
                      AutomationProperties.Name="{i18n:Loc VehicleEditor.TransmissionName}"
                      AutomationProperties.AutomationId="VehicleEditorTransmissionBox" />
          </StackPanel>
        </Grid>

        <TextBlock Grid.Row="7" Margin="0,14,0,0" FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.Tags}" />
        <TextBox x:Name="VehicleEditorTagsBox"
                 Grid.Row="8"
                 Margin="0,6,0,0"
                 Text="{Binding VehicleEditorTags}"
                 PlaceholderText="{i18n:Loc VehicleEditor.TagsHelp}"
                 AutomationProperties.Name="{i18n:Loc VehicleEditor.Tags}"
                 AutomationProperties.HelpText="{i18n:Loc VehicleEditor.TagsHelp}"
                 AutomationProperties.AutomationId="VehicleEditorTagsBox" />

        <TextBlock Grid.Row="9" Margin="0,14,0,0" FontWeight="SemiBold" Text="{i18n:Loc VehicleEditor.Note}" />
        <TextBox x:Name="VehicleEditorNoteBox"
                 Grid.Row="10"
                 Margin="0,6,0,0"
                 Height="110"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalContentAlignment="Top"
                 Text="{Binding VehicleEditorNote}"
                 AutomationProperties.Name="{i18n:Loc VehicleEditor.NoteName}"
                 AutomationProperties.AutomationId="VehicleEditorNoteBox" />
        <TextBlock Grid.Row="11"
                   Margin="0,14,0,0"
                   Opacity="0.72"
                   Text="{i18n:Loc VehicleEditor.Warning}"
                   TextWrapping="Wrap" />
      </Grid>
    </ScrollViewer>

    <StackPanel Grid.Row="3"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10">
      <Button x:Name="SaveVehicleButton"
              Click="OnSaveClick"
              Content="{i18n:Loc Common.Save}"
              AutomationProperties.Name="{i18n:Loc VehicleEditor.SaveName}"
              AutomationProperties.AutomationId="SaveVehicleButton" />
      <Button x:Name="CancelVehicleButton"
              Click="OnCancelClick"
              Content="{i18n:Loc Common.Cancel}"
              AutomationProperties.Name="{i18n:Loc VehicleEditor.CancelName}"
              AutomationProperties.AutomationId="CancelVehicleButton" />
    </StackPanel>
  </Grid>
</Window>
