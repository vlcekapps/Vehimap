<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.VehicleDetailWindow"
        x:DataType="vm:VehicleDetailWorkspaceViewModel"
        Width="1280"
        Height="840"
        MinWidth="1040"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="Detail vozidla"
        AutomationProperties.HelpText="Samostatné okno pro detail a úpravu vybraného vozidla.">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}" />
        <TextBlock Opacity="0.78"
                   Text="{Binding SelectedVehicleOverview}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="Zavřít"
              AutomationProperties.Name="Zavřít okno detailu vozidla" />
    </Grid>

    <workspaces:VehicleDetailWorkspaceView x:Name="VehicleDetailWorkspaceHost"
                                           Grid.Row="1"
                                           Margin="0,18,0,0" />
  </Grid>
</Window>
