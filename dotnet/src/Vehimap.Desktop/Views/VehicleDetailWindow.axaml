<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels.Workspaces"
        xmlns:workspaces="using:Vehimap.Desktop.Views.Workspaces"
        x:Class="Vehimap.Desktop.Views.VehicleDetailWindow"
        x:DataType="vm:VehicleDetailWorkspaceViewModel"
        Width="1280"
        Height="840"
        MinWidth="1040"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        AutomationProperties.Name="{i18n:Loc WorkspaceWindow.VehicleDetailName}"
        AutomationProperties.AutomationId="VehicleDetailWindow"
        AutomationProperties.HelpText="{i18n:Loc WorkspaceWindow.VehicleDetailHelpText}">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="4">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding WindowTitle}"
                   AutomationProperties.Name="{Binding WindowTitle}"
                   AutomationProperties.AutomationId="VehicleDetailWindowHeadingText"
                   AutomationProperties.HeadingLevel="1" />
        <TextBlock Opacity="0.78"
                   Text="{Binding SelectedVehicleOverview}"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              x:Name="CloseVehicleDetailWindowButton"
              Width="120"
              Height="34"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="OnCloseClick"
              Content="{i18n:Loc Common.Close}"
              AutomationProperties.Name="{i18n:Loc WorkspaceWindow.CloseVehicleDetailName}"
              AutomationProperties.AutomationId="CloseVehicleDetailWindowButton" />
    </Grid>

    <workspaces:VehicleDetailWorkspaceView x:Name="VehicleDetailWorkspaceHost"
                                           Grid.Row="1"
                                           Margin="0,18,0,0" />
  </Grid>
</Window>
