<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i18n="using:Vehimap.Desktop.Localization"
        xmlns:vm="using:Vehimap.Desktop.ViewModels"
        x:Class="Vehimap.Desktop.Views.SettingsWindow"
        x:DataType="vm:SettingsDialogViewModel"
        Width="620"
        Height="700"
        MinWidth="580"
        MinHeight="660"
        CanResize="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="{i18n:Loc Settings.Title}"
        AutomationProperties.Name="{i18n:Loc Settings.Title}"
        AutomationProperties.AutomationId="SettingsWindow"
        AutomationProperties.HelpText="{i18n:Loc Settings.HelpText}">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto,Auto">
    <TextBlock FontSize="22"
               FontWeight="SemiBold"
               Text="{i18n:Loc Settings.Title}"
               AutomationProperties.Name="{i18n:Loc Settings.Title}"
               AutomationProperties.AutomationId="SettingsHeadingText"
               AutomationProperties.HeadingLevel="1" />
    <TextBlock Grid.Row="1"
               Margin="0,8,0,0"
               Opacity="0.78"
               Text="{i18n:Loc Settings.Description}"
               TextWrapping="Wrap" />

    <ScrollViewer Grid.Row="2"
                  Margin="0,18,0,0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  AutomationProperties.Name="Volby nastavení"
                  AutomationProperties.AutomationId="SettingsContentScrollViewer">
      <StackPanel Spacing="18">
      <Border Padding="14" Background="#143A4A5A" CornerRadius="8">
        <Grid ColumnDefinitions="280,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0"
                     Grid.ColumnSpan="2"
                     FontWeight="SemiBold"
                     Text="{i18n:Loc Settings.LocaleFormattingHeading}" />
          <TextBlock Grid.Row="1" Margin="0,14,0,0" Text="{i18n:Loc Settings.Language}" VerticalAlignment="Center" />
          <ComboBox x:Name="LanguageOptionBox"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,14,0,0"
                    ItemsSource="{Binding LanguageOptions}"
                    SelectedItem="{Binding SelectedLanguageOption}"
                    AutomationProperties.Name="{i18n:Loc Settings.Language}"
                    AutomationProperties.AutomationId="LanguageOptionBox" />
          <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="{i18n:Loc Settings.ThousandsSeparator}" VerticalAlignment="Center" />
          <ComboBox x:Name="ThousandsSeparatorOptionBox"
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="0,12,0,0"
                    ItemsSource="{Binding ThousandsSeparatorOptions}"
                    SelectedItem="{Binding SelectedThousandsSeparatorOption}"
                    AutomationProperties.Name="{i18n:Loc Settings.ThousandsSeparator}"
                    AutomationProperties.AutomationId="ThousandsSeparatorOptionBox" />
          <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="{i18n:Loc Settings.DecimalSeparator}" VerticalAlignment="Center" />
          <ComboBox x:Name="DecimalSeparatorOptionBox"
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="0,12,0,0"
                    ItemsSource="{Binding DecimalSeparatorOptions}"
                    SelectedItem="{Binding SelectedDecimalSeparatorOption}"
                    AutomationProperties.Name="{i18n:Loc Settings.DecimalSeparator}"
                    AutomationProperties.AutomationId="DecimalSeparatorOptionBox" />
          <TextBlock Grid.Row="4" Margin="0,12,0,0" Text="{i18n:Loc Settings.DistanceUnit}" VerticalAlignment="Center" />
          <ComboBox x:Name="DistanceUnitOptionBox"
                    Grid.Row="4"
                    Grid.Column="1"
                    Margin="0,12,0,0"
                    ItemsSource="{Binding DistanceUnitOptions}"
                    SelectedItem="{Binding SelectedDistanceUnitOption}"
                    AutomationProperties.Name="{i18n:Loc Settings.DistanceUnit}"
                    AutomationProperties.AutomationId="DistanceUnitOptionBox" />
          <TextBlock Grid.Row="5" Margin="0,12,0,0" Text="{i18n:Loc Settings.VolumeUnit}" VerticalAlignment="Center" />
          <ComboBox x:Name="VolumeUnitOptionBox"
                    Grid.Row="5"
                    Grid.Column="1"
                    Margin="0,12,0,0"
                    ItemsSource="{Binding VolumeUnitOptions}"
                    SelectedItem="{Binding SelectedVolumeUnitOption}"
                    AutomationProperties.Name="{i18n:Loc Settings.VolumeUnit}"
                    AutomationProperties.AutomationId="VolumeUnitOptionBox" />
        </Grid>
      </Border>

      <TextBlock Opacity="0.78"
                 Text="{i18n:Loc Settings.LanguageRestartNotice}"
                 TextWrapping="Wrap"
                 AutomationProperties.Name="{i18n:Loc Settings.LanguageRestartNotice}"
                 AutomationProperties.AutomationId="LanguageRestartNoticeText" />

      <Border Padding="14" Background="#143A4A5A" CornerRadius="8">
        <Grid ColumnDefinitions="280,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Text="{i18n:Loc Settings.TechnicalReminderDays}" VerticalAlignment="Center" />
          <TextBox x:Name="TechnicalReminderDaysBox"
                   Grid.Row="0"
                   Grid.Column="1"
                   Text="{Binding TechnicalReminderDays}"
                   AutomationProperties.Name="{i18n:Loc Settings.TechnicalReminderDaysName}"
                   AutomationProperties.AutomationId="TechnicalReminderDaysBox" />

          <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="{i18n:Loc Settings.GreenCardReminderDays}" VerticalAlignment="Center" />
          <TextBox Grid.Row="1"
                   Grid.Column="1"
                   Margin="0,12,0,0"
                   Text="{Binding GreenCardReminderDays}"
                   AutomationProperties.Name="{i18n:Loc Settings.GreenCardReminderDaysName}"
                   AutomationProperties.AutomationId="GreenCardReminderDaysBox" />

          <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="{i18n:Loc Settings.MaintenanceReminderDays}" VerticalAlignment="Center" />
          <TextBox Grid.Row="2"
                   Grid.Column="1"
                   Margin="0,12,0,0"
                   Text="{Binding MaintenanceReminderDays}"
                   AutomationProperties.Name="{i18n:Loc Settings.MaintenanceReminderDaysName}"
                   AutomationProperties.AutomationId="MaintenanceReminderDaysBox" />

          <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="{i18n:Loc Settings.MaintenanceReminderKm}" VerticalAlignment="Center" />
          <TextBox Grid.Row="3"
                   Grid.Column="1"
                   Margin="0,12,0,0"
                   Text="{Binding MaintenanceReminderKm}"
                   AutomationProperties.Name="{i18n:Loc Settings.MaintenanceReminderKmName}"
                   AutomationProperties.AutomationId="MaintenanceReminderKmBox" />

          <CheckBox Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Margin="0,18,0,0"
                    IsChecked="{Binding ShowDashboardOnLaunch}"
                    Content="{i18n:Loc Settings.ShowDashboardOnLaunch}"
                    AutomationProperties.Name="{i18n:Loc Settings.ShowDashboardOnLaunch}"
                    AutomationProperties.AutomationId="ShowDashboardOnLaunchCheckBox" />
        </Grid>
      </Border>

      <Border Padding="14" Background="#143A4A5A" CornerRadius="8">
        <StackPanel Spacing="10">
          <CheckBox x:Name="RunAtStartupCheckBox"
                    IsChecked="{Binding RunAtStartup}"
                    Content="{i18n:Loc Settings.RunAtStartup}"
                    AutomationProperties.Name="{i18n:Loc Settings.RunAtStartup}"
                    AutomationProperties.AutomationId="RunAtStartupCheckBox" />
          <CheckBox IsChecked="{Binding HideOnLaunch}"
                    Content="{i18n:Loc Settings.HideOnLaunch}"
                    AutomationProperties.Name="{i18n:Loc Settings.HideOnLaunch}"
                    AutomationProperties.AutomationId="HideOnLaunchCheckBox" />
          <TextBlock Opacity="0.76"
                     Text="{i18n:Loc Settings.StartupNotice}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Padding="14" Background="#143A4A5A" CornerRadius="8">
        <Grid ColumnDefinitions="280,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <CheckBox Grid.Row="0"
                    Grid.ColumnSpan="2"
                    IsChecked="{Binding AutomaticBackupsEnabled}"
                    Content="{i18n:Loc Settings.AutomaticBackupsEnabled}"
                    AutomationProperties.Name="{i18n:Loc Settings.AutomaticBackupsEnabled}"
                    AutomationProperties.HelpText="{i18n:Loc Settings.AutomaticBackupsHelp}"
                    AutomationProperties.AutomationId="AutomaticBackupsEnabledCheckBox" />

          <TextBlock Grid.Row="1"
                     Margin="0,14,0,0"
                     Text="{i18n:Loc Settings.AutomaticBackupsIntervalDays}"
                     VerticalAlignment="Center"
                     IsEnabled="{Binding CanConfigureAutomaticBackups}" />
          <TextBox Grid.Row="1"
                   Grid.Column="1"
                   Margin="0,14,0,0"
                   Text="{Binding AutomaticBackupIntervalDays}"
                   IsEnabled="{Binding CanConfigureAutomaticBackups}"
                   AutomationProperties.Name="{i18n:Loc Settings.AutomaticBackupsIntervalDays}"
                   AutomationProperties.HelpText="{i18n:Loc Settings.AutomaticBackupsIntervalHelp}"
                   AutomationProperties.AutomationId="AutomaticBackupIntervalDaysBox" />

          <TextBlock Grid.Row="2"
                     Margin="0,12,0,0"
                     Text="{i18n:Loc Settings.AutomaticBackupKeepCount}"
                     VerticalAlignment="Center"
                     IsEnabled="{Binding CanConfigureAutomaticBackups}" />
          <TextBox Grid.Row="2"
                   Grid.Column="1"
                   Margin="0,12,0,0"
                   Text="{Binding AutomaticBackupKeepCount}"
                   IsEnabled="{Binding CanConfigureAutomaticBackups}"
                   AutomationProperties.Name="{i18n:Loc Settings.AutomaticBackupKeepCount}"
                   AutomationProperties.HelpText="{i18n:Loc Settings.AutomaticBackupKeepCountHelp}"
                   AutomationProperties.AutomationId="AutomaticBackupKeepCountBox" />

          <TextBlock Grid.Row="3"
                     Grid.ColumnSpan="2"
                     Margin="0,16,0,0"
                     Text="{Binding AutomaticBackupStatus}"
                     TextWrapping="Wrap"
                     AutomationProperties.Name="{Binding AutomaticBackupStatus}"
                     AutomationProperties.AutomationId="AutomaticBackupStatusText"
                     AutomationProperties.LiveSetting="Polite" />
        </Grid>
      </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="3"
            Margin="0,18,0,0"
            Padding="12"
            Background="#143A4A5A"
            CornerRadius="8">
      <TextBlock Text="{Binding StatusMessage}"
                 TextWrapping="Wrap"
                 AutomationProperties.Name="{Binding StatusMessage}"
                 AutomationProperties.AutomationId="SettingsStatusText"
                 AutomationProperties.LiveSetting="Polite" />
    </Border>

    <StackPanel Grid.Row="4"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10">
      <Button x:Name="CreateAutomaticBackupButton"
              MinWidth="150"
              Click="OnBackupNowClick"
              Content="{i18n:Loc Settings.Action.BackupNow}"
              AutomationProperties.Name="{i18n:Loc Settings.Action.BackupNow}"
              AutomationProperties.AutomationId="CreateAutomaticBackupButton" />
      <Button x:Name="SaveSettingsButton"
              MinWidth="110"
              Click="OnSaveClick"
              Content="{i18n:Loc Common.Save}"
              AutomationProperties.Name="{i18n:Loc Settings.Action.SaveName}"
              AutomationProperties.AutomationId="SaveSettingsButton" />
      <Button x:Name="CancelSettingsButton"
              MinWidth="110"
              Click="OnCancelClick"
              Content="{i18n:Loc Common.Cancel}"
              AutomationProperties.Name="{i18n:Loc Settings.Action.CancelName}"
              AutomationProperties.AutomationId="CancelSettingsButton" />
    </StackPanel>
  </Grid>
</Window>
