<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:themes="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="Vehimap.Desktop.App">
  <Application.Styles>
    <themes:FluentTheme />
    <Style Selector="Button.tab-header">
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="Background" Value="#143A4A5A" />
      <Setter Property="BorderBrush" Value="#304050" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tab-header.selected">
      <Setter Property="Background" Value="#2A57708C" />
      <Setter Property="BorderBrush" Value="#6AA4D8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TabControl.headerless /template/ TabStrip">
      <Setter Property="IsVisible" Value="False" />
    </Style>
  </Application.Styles>
</Application>
